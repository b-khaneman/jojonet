    set +e
    command -v clear >/dev/null && clear
    logo
    print_banner "Hysteria2 Tunnel (high speed / filtered paths)"

    install_hysteria2_binary || { sleep 2; set -e; return 1; }
    install -d -m700 "$HY2_CONFIG_DIR"

    if ! auto_detect_network; then
        echo -e "${RED}[!] Cannot detect network.${NC}"
        sleep 2; set -e; return 1
    fi
    loc_ip="$DETECTED_IP"
    show_existing_tunnels_summary

    if [[ -z "$peer_ip" ]]; then
        read -r -p "Peer server IP: " peer_ip
    fi
    peer_ip="${peer_ip// /}"
    if ! validate_ipv4 "$peer_ip"; then
        echo -e "${RED}[!] Invalid peer IP.${NC}"
        sleep 2; set -e; return 1
    fi
    rem_ip="$peer_ip"

    if existing=$(find_tunnel_for_peer "$rem_ip" "hysteria2"); then
        echo -e "${YELLOW}[!] Hysteria2 to $rem_ip exists [$existing]. Restarting...${NC}"
        restart_tunnel "$existing"
        sleep 2; set -e; return $?
    fi

    if ! role_conf=$(resolve_server_role "$loc_ip"); then
        echo -e "${RED}[!] Role required.${NC}"
        sleep 2; set -e; return 1
    fi
    echo -e "${GREEN}[*] Role:${NC} $role_conf"

    ins_name=$(allocate_tunnel_name "$rem_ip" "$role_conf" "hysteria2") || { set -e; return 1; }

    if [[ "$role_conf" == "kharej" ]]; then
        read -r -p "Listen UDP port [$hy_port]: " _hp
        hy_port=${_hp:-$hy_port}
        fwd_port=""
    else
        fwd_port="443"
        read -r -p "Server UDP port [$hy_port]: " _hp
        hy_port=${_hp:-$hy_port}
        read -r -p "Forward ports on Iran [$fwd_port]: " _fp
        fwd_port=${_fp:-$fwd_port}
    fi
    read -r -p "TLS SNI [$sni]: " _sni
    sni=${_sni:-$sni}

    local pair_id
    pair_id=$(printf '%s' "$rem_ip" | tr '.' '_')
    key_dir=$(ensure_hy2_auth "$pair_id" "$rem_ip") || { set -e; return 1; }
    export HySni="$sni"
    export JOJONET_HY2_SNI="$sni"

    echo -e "\n${CYAN}--- Hysteria2 plan ---${NC}"
    echo -e "  Name:  $ins_name"
    echo -e "  Role:  $role_conf"
    echo -e "  Peer:  $rem_ip"
    echo -e "  Port:  UDP $hy_port"
    echo -e "  SNI:   $sni"
    [[ -n "$fwd_port" ]] && echo -e "  Fwd:   $fwd_port (via tunnel to foreign localhost)"
    echo ""

    if deploy_tunnel "$ins_name" "$role_conf" "$loc_ip" "$rem_ip" "0" \
        "" "" "1350" "$fwd_port" "hysteria2" "$hy_port" "$key_dir" \
        "" "" "tcp"; then
        # patch HySni into conf
        if [[ -f "$INSTANCES_DIR/$ins_name.conf" ]]; then
            grep -q '^HySni=' "$INSTANCES_DIR/$ins_name.conf" || \
                echo "HySni=\"$sni\"" >> "$INSTANCES_DIR/$ins_name.conf"
        fi
        echo -e "${GREEN}[+] Hysteria2 [$ins_name] is up.${NC}"
        [[ "$role_conf" == "kharej" ]] && hint "Run on Iran: sudo jojonet --hy2 $loc_ip"
        sleep 2
        set -e
        return 0
    fi
    sleep 3
    set -e
    return 1
}


create_boot_restore_service() {
    if ! cat << 'EOF' > "$BOOT_RESTORE_SCRIPT"
#!/usr/bin/env bash
# Restore all JojoNet tunnels after reboot
set -euo pipefail
INSTANCES_DIR="/etc/jojonet/instances"
shopt -s nullglob
for conf in "$INSTANCES_DIR"/*.conf; do
    name=$(grep -E '^Name=' "$conf" 2>/dev/null | head -1 | cut -d'"' -f2)
    [[ -n "$name" ]] || continue
    mode=$(grep -E '^TunnelMode=' "$conf" 2>/dev/null | head -1 | cut -d'"' -f2)
    mode=${mode:-gre}
    case "$mode" in
        tun_tcp)   svc="jojonet-tcptun@${name}.service" ;;
        paqet)     svc="jojonet-paqet@${name}.service" ;;
        vxlan)     svc="jojonet-vxlan@${name}.service" ;;
        wireguard) svc="jojonet-wg@${name}.service" ;;
        hysteria2) svc="jojonet-hy2@${name}.service" ;;
        *)         svc="jojonet@${name}.service" ;;
    esac
    echo "[jojonet-boot] Ensuring $svc"
    systemctl enable "$svc" >/dev/null 2>&1 || true
    if ! systemctl is-active --quiet "$svc"; then
        systemctl start "$svc" >/dev/null 2>&1 || \
            echo "[jojonet-boot] WARN: failed to start $svc" >&2
    fi
done
exit 0
EOF
    then
        return 1
    fi
    chmod +x "$BOOT_RESTORE_SCRIPT" || return 1

    local tmp_file
    tmp_file=$(mktemp /tmp/jojonet_boot.XXXXXX) || return 1
    if ! cat << 'EOF' > "$tmp_file"
[Unit]
Description=JojoNet - Restore all tunnels on boot
After=network-online.target
Wants=network-online.target
Before=multi-user.target

[Service]
Type=oneshot
RemainAfterExit=yes
StandardOutput=journal
StandardError=journal
SyslogIdentifier=jojonet-boot
ExecStart=/usr/local/bin/jojonet-boot-restore.sh

[Install]
WantedBy=multi-user.target
EOF
    then
        rm -f "$tmp_file"
        return 1
    fi

    if [[ -f "$BOOT_SERVICE" ]] && cmp -s "$tmp_file" "$BOOT_SERVICE"; then
        rm -f "$tmp_file"
    else
        mv -f "$tmp_file" "$BOOT_SERVICE" || { rm -f "$tmp_file"; return 1; }
        systemctl daemon-reload || return 1
    fi
    return 0
}

tunnel_service_unit() {
    local name="$1" mode=""
    mode=$(tunnel_mode_from_name "$name")
    case "$mode" in
        tun_tcp)    echo "jojonet-tcptun@${name}.service" ;;
        paqet)      echo "jojonet-paqet@${name}.service" ;;
        vxlan)      echo "jojonet-vxlan@${name}.service" ;;
        wireguard)  echo "jojonet-wg@${name}.service" ;;
        hysteria2)  echo "jojonet-hy2@${name}.service" ;;
        *)          echo "jojonet@${name}.service" ;;
    esac
}

tunnel_boot_enabled() {
    systemctl is-enabled --quiet "$(tunnel_service_unit "$1")" 2>/dev/null
}

show_tunnel_logs() {
    local name="$1" mode="${2:-recent}"
    local unit
    unit=$(tunnel_service_unit "$name")

    echo -e "${CYAN}=== Logs: $name ($mode) ===${NC}"
    case "$mode" in
        status)
            systemctl status "$unit" --no-pager -l 2>/dev/null || true ;;
        recent)
            journalctl -u "$unit" -b --no-pager -n 50 2>/dev/null || true ;;
        boot)
            journalctl -u "$unit" -b --no-pager 2>/dev/null || true ;;
        full)
            journalctl -u "$unit" --no-pager -n 500 2>/dev/null || true ;;
        all)
            journalctl -u "$unit" --no-pager 2>/dev/null || true ;;
        export)
            local out="/var/log/jojonet_${name}.log"
            journalctl -u "$unit" --no-pager > "$out" 2>/dev/null || true
            echo -e "${GREEN}[+] Logs saved: $out${NC}" ;;
        *)
            journalctl -u "$unit" -b --no-pager -n 50 2>/dev/null || true ;;
    esac
}

tunnel_logs_menu() {
    local name="$1" choice=""
    while true; do
        command -v clear >/dev/null && clear
        echo -e "${CYAN}Logs: $name${NC}"
        menu_line "1) Service status (systemctl)"
        menu_line "2) Recent logs (50 lines)"
        menu_line "3) Full boot logs"
        menu_line "4) Extended logs (500 lines)"
        menu_line "5) All logs (complete)"
        menu_line "6) Export to /var/log/"
        menu_line "0) Back"
        read -r -p "Choice: " choice || break
        case "$choice" in
            1) show_tunnel_logs "$name" status; press_enter ;;
            2) show_tunnel_logs "$name" recent; press_enter ;;
            3) show_tunnel_logs "$name" boot; press_enter ;;
            4) show_tunnel_logs "$name" full; press_enter ;;
            5) show_tunnel_logs "$name" all; press_enter ;;
            6) show_tunnel_logs "$name" export; press_enter ;;
            0) break ;;
            *) echo -e "${RED}Invalid.${NC}"; sleep 1 ;;
        esac
    done
}

restart_tunnel() {
    local name="$1"
    local unit
    unit=$(tunnel_service_unit "$name")

    echo -e "${YELLOW}[*] Restarting [$name]...${NC}"
    systemctl reset-failed "$unit" >/dev/null 2>&1 || true
    if ! systemctl restart "$unit" 2>/dev/null; then
        echo -e "${RED}[!] systemctl restart failed.${NC}"
        show_tunnel_logs "$name" recent
        return 1
    fi
    sleep 2
    local mode unit_active=0
    mode=$(tunnel_mode_from_name "$name")
    unit=$(tunnel_service_unit "$name")
    if systemctl is-active --quiet "$unit"; then
        if [[ "$mode" == "paqet" ]]; then
            pgrep -f "paqet run -c.*/${name}\\.yaml" >/dev/null 2>&1 && unit_active=1
        elif [[ "$mode" == "hysteria2" ]]; then
            pgrep -f "hysteria.*${name}" >/dev/null 2>&1 && unit_active=1
        elif [[ "$mode" == "tun_tcp" || "$mode" == "wireguard" || "$mode" == "gre" || "$mode" == "vxlan" ]]; then
            ip link show "$name" >/dev/null 2>&1 && unit_active=1
        elif ip link show "$name" 2>/dev/null | grep -qE 'state UP|UP,'; then
            unit_active=1
        fi
    fi
    if (( unit_active == 1 )); then
        echo -e "${GREEN}[+] Tunnel [$name] restarted successfully.${NC}"
        return 0
    fi
    echo -e "${RED}[!] Restart completed but tunnel may be down.${NC}"
    show_tunnel_logs "$name" recent
    return 1
}

restart_all_tunnels() {
    shopt -s nullglob
    local files=("$INSTANCES_DIR"/*.conf)
    shopt -u nullglob
    if (( ${#files[@]} == 0 )); then
        echo -e "${YELLOW}No tunnels to restart.${NC}"
        return 0
    fi
    local f n ok=0 fail=0
    echo -e "${YELLOW}[*] Restarting all tunnels...${NC}"
    for f in "${files[@]}"; do
        n=$(grep -E '^Name=' "$f" 2>/dev/null | head -1 | cut -d'"' -f2)
        [[ -n "$n" ]] || continue
        if restart_tunnel "$n"; then
            ok=$((ok + 1))
        else
            fail=$((fail + 1))
        fi
    done
    echo -e "${GREEN}Done: $ok OK, $fail failed.${NC}"
    sleep 2
}

ensure_boot_persistence() {
    shopt -s nullglob
    local files=("$INSTANCES_DIR"/*.conf)
    shopt -u nullglob
    local f n enabled=0 started=0

    create_boot_restore_service || true
    if systemctl enable jojonet-boot.service >/dev/null 2>&1; then
        echo -e "${GREEN}[+] jojonet-boot.service enabled for reboot.${NC}"
    fi

    for f in "${files[@]}"; do
        n=$(grep -E '^Name=' "$f" 2>/dev/null | head -1 | cut -d'"' -f2)
        [[ -n "$n" ]] || continue
        if ! systemctl is-enabled --quiet "$(tunnel_service_unit "$n")" 2>/dev/null; then
            systemctl enable "$(tunnel_service_unit "$n")" >/dev/null 2>&1 && enabled=$((enabled + 1))
        fi
        if ! systemctl is-active --quiet "$(tunnel_service_unit "$n")" 2>/dev/null; then
            systemctl start "$(tunnel_service_unit "$n")" >/dev/null 2>&1 && started=$((started + 1)) || true
        fi
    done
    echo -e "${GREEN}[+] Boot persistence OK.${NC} Enabled: $enabled | Started: $started"
    sleep 2
}

