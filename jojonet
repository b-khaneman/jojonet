    echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
}

show_global_status() {
    local interactive="${1:-1}" f n total=0 up=0 down=0
    if (( interactive )); then
        command -v clear >/dev/null && clear
        logo
    fi
    print_banner "System Status"
    echo -e "  Version:     ${GREEN}${JOJONET_VERSION}${NC}"
    echo -e "  ip_forward:  $(sysctl -n net.ipv4.ip_forward 2>/dev/null || echo '?')"
    echo -e "  rp_filter:   $(sysctl -n net.ipv4.conf.all.rp_filter 2>/dev/null || echo '?')"
    echo -e "  TCP BBR:     $(sysctl -n net.ipv4.tcp_congestion_control 2>/dev/null || echo '?')"
    echo ""

    if ip link show GRETun >/dev/null 2>&1; then
        echo -e "  ${YELLOW}[!] Manual GRETun present${NC} — ${CYAN}sudo jojonet --import-gretun${NC}"
    fi
    if command -v wg >/dev/null 2>&1 && wg show wg0 >/dev/null 2>&1; then
        local wgp
        wgp=$(wg show wg0 listen-port 2>/dev/null || true)
        echo -e "  ${YELLOW}[!] wg0 on UDP ${wgp:-?}${NC} (non-JojoNet)"
    fi

    shopt -s nullglob
    local files=("$INSTANCES_DIR"/*.conf)
    shopt -u nullglob
    echo -e "${CYAN}=== Tunnels (${#files[@]}) ===${NC}"
    for f in "${files[@]}"; do
        n=$(conf_get_field "$f" "Name")
        [[ -n "$n" ]] || continue
        total=$((total + 1))
        if [[ "$(tunnel_status_word "$n")" == "UP" ]]; then
            up=$((up + 1))
            echo -e "  ${GREEN}UP${NC}   $n"
        else
            down=$((down + 1))
            echo -e "  ${RED}DOWN${NC} $n"
        fi
        healthcheck_tunnel "$n" 2>/dev/null | sed 's/^/    /' || true
        if load_instance_config "$f" 2>/dev/null && [[ "${Role:-}" == "iran" && -n "${Ports:-}" ]]; then
            local lip p
            lip=$(conf_get_field "$f" "Local_IP")
            IFS=',' read -ra _fp <<< "${Ports:-443}"
            p="${_fp[0]// /}"
            if [[ -n "$lip" && -n "$p" && "$p" =~ ^[0-9]+$ ]]; then
                if curl -sk --connect-timeout 3 "https://${lip}:${p}/" >/dev/null 2>&1 || \
                   curl -sk --connect-timeout 3 "http://${lip}:${p}/" >/dev/null 2>&1; then
                    echo -e "    forward ${lip}:${p}: ${GREEN}reachable${NC}"
                else
                    echo -e "    forward ${lip}:${p}: ${YELLOW}no HTTP response (panel may still work)${NC}"
                fi
            fi
        fi
    done
    echo ""
    echo -e "${CYAN}Summary:${NC} ${GREEN}${up}${NC} up / ${RED}${down}${NC} down / ${total} total"
    if (( interactive )); then
        press_enter
    fi
}

