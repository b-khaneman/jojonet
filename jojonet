create_template_script() {
    if ! cat << 'EOF' > "$TEMPLATE_SCRIPT"
#!/usr/bin/env bash
set -Eeuo pipefail

# Safe config loader — whitelist keys only (never source shell)
_JOJONET_CONF_KEYS="Name TunnelMode Role Local_IP Remote_IP Subnet_Byte Tun_IP Tun_Remote_IP_Raw Tun_Server_IP Tun_Client_IP Suggested_MTU Ports TcpPort KeyDir GreKey PaqetYaml ForwardProto VxlanVni VxlanPort WgPrivateKey WgPublicKey WgPeerPublicKey HyYaml HyAuth HySni"

load_safe_config() {
    local file="$1" line key val
    Name="" TunnelMode="gre" Role="" Local_IP="" Remote_IP="" Subnet_Byte=""
    Tun_IP="" Tun_Remote_IP_Raw="" Tun_Server_IP="" Tun_Client_IP=""
    Suggested_MTU="" Ports="" TcpPort="" KeyDir="" GreKey=""
    PaqetYaml="" ForwardProto="" VxlanVni="" VxlanPort=""
    WgPrivateKey="" WgPublicKey="" WgPeerPublicKey="" HyYaml="" HyAuth="" HySni=""
    [[ -r "$file" ]] || return 1
    while IFS= read -r line || [[ -n "$line" ]]; do
        line="${line%%#*}"
        line="${line#"${line%%[![:space:]]*}"}"
        line="${line%"${line##*[![:space:]]}"}"
        [[ -z "$line" ]] && continue
        [[ "$line" =~ ^([A-Za-z_][A-Za-z0-9_]*)=(.*)$ ]] || return 1
        key="${BASH_REMATCH[1]}"
        val="${BASH_REMATCH[2]}"
        case " ${_JOJONET_CONF_KEYS} " in
            *" $key "*) ;;
            *) return 1 ;;
        esac
        if [[ "$val" =~ ^\"(.*)\"$ ]]; then
            val="${BASH_REMATCH[1]}"
        elif [[ "$val" =~ ^\'(.*)\'$ ]]; then
            val="${BASH_REMATCH[1]}"
        fi
        case "$val" in
            *'$('*|*'`'*|*';'*|*'|'*|*'&'*|*$'\n'*|*$'\r'*) return 1 ;;
        esac
        printf -v "$key" '%s' "$val"
    done < "$file"
    [[ -n "${Name:-}" ]] || return 1
    TunnelMode=${TunnelMode:-gre}
    return 0
}

ACTION="${1:-}"
CONFIG_FILE="${2:-}"
DEFAULT_MTU_FALLBACK=1310

if [[ -z "$CONFIG_FILE" || ! -f "$CONFIG_FILE" ]]; then
    echo "Config file missing" >&2
    exit 1
fi

# Safe whitelist loader (no shell source)
if ! load_safe_config "$CONFIG_FILE"; then
    echo "Invalid or unsafe config: $CONFIG_FILE" >&2
    exit 1
fi

table_name="jojonet_$Name"

cleanup() {
    trap - ERR
    ip link delete "$Name" >/dev/null 2>&1 || true
    nft delete table ip "$table_name" >/dev/null 2>&1 || true
}

case "$ACTION" in
    start)
        trap cleanup ERR

        log() { echo "[jojonet:${Name}] $*"; }

        log "Starting tunnel instance..."
        modprobe ip_gre 2>/dev/null || true
        # Prefer interface-scoped rp_filter disable (keeps global anti-spoofing)
        # Fallback to global only if JOJONET_DISABLE_RP_FILTER=1
        if [[ "${JOJONET_DISABLE_RP_FILTER:-0}" == "1" ]]; then
            sysctl -w net.ipv4.conf.all.rp_filter=0 >/dev/null 2>&1 || true
            sysctl -w net.ipv4.conf.default.rp_filter=0 >/dev/null 2>&1 || true
        fi

        if ip link show "$Name" >/dev/null 2>&1; then
            log "Removing stale interface $Name"
            ip link delete "$Name" || { log "ERROR: failed to delete old interface"; exit 1; }
        fi

        log "GRE add: remote=$Remote_IP local=$Local_IP key=$GreKey"
        if ! [[ "${GreKey:-}" =~ ^[0-9]+$ ]] || (( GreKey == 0 )); then
            log "ERROR: GreKey missing or invalid"
            exit 1
        fi
        ip tunnel add "$Name" mode gre remote "$Remote_IP" local "$Local_IP" key "$GreKey" ttl 255 \
            || { log "ERROR: GRE creation failed"; exit 1; }
        ip tunnel change "$Name" keepalive 10 3 || true

        ip addr flush dev "$Name" >/dev/null 2>&1
        log "Assign IP $Tun_IP on $Name"
        ip addr add "$Tun_IP" dev "$Name" || { log "ERROR: IP assignment failed"; exit 1; }

        if ! [[ "$Suggested_MTU" =~ ^[0-9]+$ ]]; then Suggested_MTU=$DEFAULT_MTU_FALLBACK; fi
        (( Suggested_MTU < 576 )) && Suggested_MTU=$DEFAULT_MTU_FALLBACK
        (( Suggested_MTU > 9000 )) && Suggested_MTU=$DEFAULT_MTU_FALLBACK

        log "Set MTU=$Suggested_MTU and bring interface UP"
        ip link set "$Name" mtu "$Suggested_MTU"
        ip link set "$Name" up || { log "ERROR: interface up failed"; exit 1; }
        sysctl -w "net.ipv4.conf.${Name}.rp_filter=0" >/dev/null 2>&1 || true

        if ! ip link show "$Name" 2>/dev/null | grep -qE '<.*UP.*>|state UP'; then
            log "ERROR: interface not in UP state after start"
            exit 1
        fi

        if [[ "$Role" == "iran" ]]; then
            log "Iran role: enabling ip_forward and nftables NAT"
            sysctl -w net.ipv4.ip_forward=1 >/dev/null 2>&1 || true

            DEFAULT_IFACE=$(ip route get 1.1.1.1 2>/dev/null | awk 'NR==1 {print $5}')
            [[ -n "$DEFAULT_IFACE" ]] || { log "ERROR: default interface not found"; exit 1; }
            [[ -n "$Tun_Remote_IP_Raw" ]] || { log "ERROR: remote tunnel IP missing"; exit 1; }

            NFT_CONF="table ip $table_name {
            chain prerouting {
                type nat hook prerouting priority dstnat; policy accept;"

            if [[ -n "$Ports" ]]; then
                IFS=',' read -ra PORT_LIST <<< "$Ports"
                for p in "${PORT_LIST[@]}"; do
                    p="${p// /}"
                    [[ -n "$p" ]] || continue
                    log "NAT rule: dport $p -> $Tun_Remote_IP_Raw"
                    if [[ "$p" =~ ^([0-9]{1,5})-([0-9]{1,5})$ ]]; then
                        NFT_CONF="$NFT_CONF
                tcp dport ${BASH_REMATCH[1]}-${BASH_REMATCH[2]} dnat ip to $Tun_Remote_IP_Raw
                udp dport ${BASH_REMATCH[1]}-${BASH_REMATCH[2]} dnat ip to $Tun_Remote_IP_Raw"
                    else
                        NFT_CONF="$NFT_CONF
                tcp dport $p dnat ip to $Tun_Remote_IP_Raw
                udp dport $p dnat ip to $Tun_Remote_IP_Raw"
                    fi
                done
            fi

            NFT_CONF="$NFT_CONF
            }
            chain postrouting {
                type nat hook postrouting priority srcnat; policy accept;
                oifname \"$DEFAULT_IFACE\" masquerade
            }
        }"

            nft delete table ip "$table_name" >/dev/null 2>&1 || true
            echo "$NFT_CONF" | nft -f - || { log "ERROR: nft table creation failed"; exit 1; }
        else
            log "Foreign role: GRE only (no NAT)"
        fi

        log "SUCCESS: tunnel $Name is UP with $Tun_IP"
        ;;
    stop)
        echo "[jojonet:${Name:-?}] Stopping tunnel..."
        cleanup
        echo "[jojonet:${Name:-?}] Stopped."
        exit 0
        ;;
    *)
        echo "Invalid action: $ACTION" >&2
        exit 1
        ;;
esac
EOF
    then
        echo -e "${RED}[!] Failed to write template script.${NC}" >&2
        return 1
    fi

    chmod +x "$TEMPLATE_SCRIPT" || {
        echo -e "${RED}[!] Failed to chmod template script.${NC}" >&2
        return 1
    }
}

