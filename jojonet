quick_add_tunnel_hy2() {
    local peer_ip="${1:-}"
    local ins_name="" role_conf="" loc_ip="" rem_ip=""
    local fwd_port="" key_dir="" hy_port="$DEFAULT_HY2_PORT" sni="$DEFAULT_HY2_SNI"
    local existing="" hy_yaml="" hop_enable="y"
    local hop_range="${JOJONET_HY2_HOP_RANGE:-$DEFAULT_HY2_HOP_RANGE}"
    local hop_interval="${JOJONET_HY2_HOP_INTERVAL:-$DEFAULT_HY2_HOP_INTERVAL}"
    local hop_style="1" span=0

    set +e
    command -v clear >/dev/null && clear
    logo
    print_banner "Hysteria2 Tunnel (high speed / filtered paths)"

    install_hysteria2_binary || { sleep 2; set -e; return 1; }
    install -d -m700 "$HY2_CONFIG_DIR"

    if ! auto_detect_network; then
        echo -e "${RED}[!] Cannot detect network.${NC}"
        sleep 2; set -e; return 1
    fi
    loc_ip="$DETECTED_IP"
    show_existing_tunnels_summary

    if [[ -z "$peer_ip" ]]; then
        read -r -p "Peer server IP: " peer_ip
    fi
    peer_ip="${peer_ip// /}"
    if ! validate_ipv4 "$peer_ip"; then
        echo -e "${RED}[!] Invalid peer IP.${NC}"
        sleep 2; set -e; return 1
    fi
    rem_ip="$peer_ip"

    if existing=$(find_tunnel_for_peer "$rem_ip" "hysteria2"); then
        echo -e "${YELLOW}[!] Hysteria2 to $rem_ip exists [$existing]. Restarting...${NC}"
        restart_tunnel "$existing"
        sleep 2; set -e; return $?
    fi

    if ! role_conf=$(resolve_server_role "$loc_ip"); then
        echo -e "${RED}[!] Role required.${NC}"
        sleep 2; set -e; return 1
    fi
    echo -e "${GREEN}[*] Role:${NC} $role_conf"

    ins_name=$(allocate_tunnel_name "$rem_ip" "$role_conf" "hysteria2") || { set -e; return 1; }

    echo ""
    echo -e "${CYAN}Hop Port${NC} — UDP range hopping (ضد محدودیت پورت UDP)"
    echo -e "  Kharej: listen on full range (needs nft/iptables)"
    echo -e "  Iran:   rotates UDP port every N seconds (transparent to traffic)"
    if [[ -n "${JOJONET_HY2_HOP_RANGE:-}" ]]; then
        hop_enable="y"
        echo -e "  ${YELLOW}Env JOJONET_HY2_HOP_RANGE=${JOJONET_HY2_HOP_RANGE}${NC}"
    else
        read -r -p "Enable Hop Port? [Y/n]: " hop_enable
        hop_enable=$(printf '%s' "${hop_enable:-y}" | tr '[:upper:]' '[:lower:]')
    fi

    if [[ "$hop_enable" == "n" || "$hop_enable" == "no" ]]; then
        hop_range=""
        hop_interval=""
        if [[ "$role_conf" == "kharej" ]]; then
            read -r -p "Listen UDP port [$hy_port]: " _hp
            hy_port=${_hp:-$hy_port}
            fwd_port=""
        else
            fwd_port=$(allocate_iran_forward_port "443")
            read -r -p "Server UDP port [$hy_port]: " _hp
            hy_port=${_hp:-$hy_port}
            read -r -p "Forward ports on Iran [$fwd_port]: " _fp
            fwd_port=${_fp:-$fwd_port}
        fi
        if ! validate_hy2_port_or_range "$hy_port"; then
            echo -e "${RED}[!] Invalid UDP port.${NC}"
            sleep 2; set -e; return 1
        fi
    else
        if [[ "$role_conf" == "kharej" ]] && ! hy2_hop_has_firewall_tools; then
            echo -e "${RED}[!] Hop Port requires nftables (nft) or iptables on Kharej.${NC}"
            echo -e "${YELLOW}    Install: apt install iptables  OR  apt install nftables${NC}"
            sleep 3
            set -e
            return 1
        fi
        read -r -p "Hop port range [$hop_range]: " _hr
        hop_range=${_hr:-$hop_range}
        hop_range="${hop_range//' '/}"
        if ! validate_hy2_port_or_range "$hop_range" || [[ ! "$hop_range" =~ - ]]; then
            echo -e "${RED}[!] Invalid range. Example: 20000-50000${NC}"
            sleep 2; set -e; return 1
        fi
        span=$(hy2_hop_span "$hop_range")
        if (( span > 15000 )); then
            echo -e "${YELLOW}[!] Wide range (${span} ports). Prefer e.g. 20000-30000 for lighter DNAT.${NC}"
        fi
        echo -e "  Hop timing: 1) fixed interval  2) random interval (harder to detect)"
        read -r -p "Choose [1/2] (default 1): " hop_style
        if [[ "${hop_style:-1}" == "2" ]]; then
            hop_interval="15s-45s"
            read -r -p "Random hop min-max [${hop_interval}]: " _hi
            hop_interval=$(normalize_hy2_hop_interval "${_hi:-$hop_interval}")
        else
            read -r -p "Hop interval [${hop_interval}] (min 5s): " _hi
            hop_interval=$(normalize_hy2_hop_interval "${_hi:-$hop_interval}")
        fi
        hy_port="$hop_range"
        if [[ "$role_conf" == "iran" ]]; then
            fwd_port=$(allocate_iran_forward_port "443")
            read -r -p "Forward ports on Iran [$fwd_port]: " _fp
            fwd_port=${_fp:-$fwd_port}
        else
            fwd_port=""
        fi
    fi

    read -r -p "TLS SNI [$sni]: " _sni
    sni=${_sni:-$sni}

    local pair_id
    pair_id=$(printf '%s' "$rem_ip" | tr '.' '_')
    key_dir=$(ensure_hy2_auth "$pair_id" "$rem_ip") || { set -e; return 1; }
    export HySni="$sni"
    export JOJONET_HY2_SNI="$sni"
    export HyHopRange="$hop_range"
    export HyHopInterval="$hop_interval"

    echo -e "\n${CYAN}--- Hysteria2 plan ---${NC}"
    echo -e "  Name:  $ins_name"
    echo -e "  Role:  $role_conf"
    echo -e "  Peer:  $rem_ip"
    if [[ -n "$hop_range" ]]; then
        echo -e "  Hop:   ${GREEN}ON${NC}  range ${hop_range}  every ${hop_interval}"
        [[ "$role_conf" == "kharej" ]] && echo -e "  Note:  server listens on first port + DNAT for the rest"
    else
        echo -e "  Port:  UDP $hy_port (fixed)"
    fi
    echo -e "  SNI:   $sni"
    [[ -n "$fwd_port" ]] && echo -e "  Fwd:   $fwd_port (via tunnel to foreign localhost)"
    echo ""

    if deploy_tunnel "$ins_name" "$role_conf" "$loc_ip" "$rem_ip" "0" \
        "" "" "1350" "$fwd_port" "hysteria2" "$hy_port" "$key_dir" \
        "" "" "tcp"; then
        if [[ -f "$INSTANCES_DIR/$ins_name.conf" ]]; then
            grep -q '^HySni=' "$INSTANCES_DIR/$ins_name.conf" || \
                echo "HySni=\"$sni\"" >> "$INSTANCES_DIR/$ins_name.conf"
            if [[ -n "$hop_range" ]]; then
                if grep -q '^HyHopRange=' "$INSTANCES_DIR/$ins_name.conf"; then
                    sed -i "s|^HyHopRange=.*|HyHopRange=\"$hop_range\"|" "$INSTANCES_DIR/$ins_name.conf"
                else
                    echo "HyHopRange=\"$hop_range\"" >> "$INSTANCES_DIR/$ins_name.conf"
                fi
                if grep -q '^HyHopInterval=' "$INSTANCES_DIR/$ins_name.conf"; then
                    sed -i "s|^HyHopInterval=.*|HyHopInterval=\"$hop_interval\"|" "$INSTANCES_DIR/$ins_name.conf"
                else
                    echo "HyHopInterval=\"$hop_interval\"" >> "$INSTANCES_DIR/$ins_name.conf"
                fi
            fi
        fi
        echo -e "${GREEN}[+] Hysteria2 [$ins_name] is up.${NC}"
        if [[ -n "$hop_range" ]]; then
            hint "Peer MUST use the SAME hop range: $hop_range (interval $hop_interval)"
            [[ "$role_conf" == "kharej" ]] && hint "If UFW/firewalld blocks UDP, range ${hop_range} was attempted to open"
        fi
        [[ "$role_conf" == "kharej" ]] && hint "Run on Iran: sudo jojonet --hy2 $loc_ip"
        unset HyHopRange HyHopInterval HySni JOJONET_HY2_SNI 2>/dev/null || true
        sleep 2
        set -e
        return 0
    fi
    unset HyHopRange HyHopInterval HySni JOJONET_HY2_SNI 2>/dev/null || true
    sleep 3
    set -e
    return 1
}


# ==========================================
# Rathole reverse tunnel (Iran=server, Kharej=client)
# Users → Iran:Ports → reverse TCP → Kharej localhost:Ports
# ==========================================

RATHOLE_RUNNER="/usr/local/bin/jojonet-run-rathole.sh"
RATHOLE_SERVICE="/etc/systemd/system/jojonet-rathole@.service"

detect_cpu_arch_rathole() {
    case "$(uname -m)" in
        x86_64|amd64) echo "x86_64-unknown-linux-gnu" ;;
        aarch64|arm64) echo "aarch64-unknown-linux-musl" ;;
        *) return 1 ;;
    esac
}

install_rathole_binary() {
    if [[ -x "$RATHOLE_BIN" ]]; then
        return 0
    fi
    local arch zip fname tmpdir url ok=0
    arch=$(detect_cpu_arch_rathole) || { log_error "Unsupported CPU for Rathole"; return 1; }
    command -v unzip >/dev/null 2>&1 || { log_error "unzip required for Rathole"; return 1; }
    fname="rathole-${arch}.zip"
    tmpdir=$(mktemp -d /tmp/jojonet-rathole.XXXXXX) || return 1
    log_note "Downloading Rathole ${RATHOLE_VERSION} ($fname)..."
    # GitHub releases + Iran-friendly mirrors
    for url in \
        "https://github.com/rapiz1/rathole/releases/download/${RATHOLE_VERSION}/${fname}" \
        "https://ghproxy.net/https://github.com/rapiz1/rathole/releases/download/${RATHOLE_VERSION}/${fname}" \
        "https://mirror.ghproxy.com/https://github.com/rapiz1/rathole/releases/download/${RATHOLE_VERSION}/${fname}"
    do
        echo -e "  ${CYAN}try${NC} $url" >&2
        if JOJONET_ALLOW_UNSIGNED=1 download_verified "$url" "$tmpdir/$fname" "$fname"; then
            ok=1
            break
        fi
        rm -f "$tmpdir/$fname"
    done
    if (( ok != 1 )); then
        rm -rf "$tmpdir"
        log_error "Failed to download Rathole"
        return 1
    fi
    unzip -oq "$tmpdir/$fname" -d "$tmpdir" || { rm -rf "$tmpdir"; return 1; }
    if [[ -f "$tmpdir/rathole" ]]; then
        install -m755 "$tmpdir/rathole" "$RATHOLE_BIN"
    else
        local found=""
        found=$(find "$tmpdir" -type f -name rathole 2>/dev/null | head -1)
        [[ -n "$found" ]] || { rm -rf "$tmpdir"; log_error "rathole binary missing in zip"; return 1; }
        install -m755 "$found" "$RATHOLE_BIN"
    fi
    rm -rf "$tmpdir"
    log_info "rathole installed: $RATHOLE_BIN"
    return 0
}

ensure_rathole_firewall() {
    local ctrl="${1:-$DEFAULT_RATHOLE_CTRL_PORT}" ports="${2:-$DEFAULT_RATHOLE_FWD}" p
    # Open control + public forward ports (Iran server side)
    if command -v ufw >/dev/null 2>&1 && ufw status 2>/dev/null | grep -qi 'Status: active'; then
        ufw allow "${ctrl}/tcp" comment 'jojonet-rathole-ctrl' >/dev/null 2>&1 || true
        IFS=',' read -ra _pl <<< "$ports"
        for p in "${_pl[@]}"; do
            p="${p// /}"
            [[ "$p" =~ ^[0-9]+$ ]] || continue
            ufw allow "${p}/tcp" comment "jojonet-rathole-fwd-${p}" >/dev/null 2>&1 || true
        done
    fi
    if command -v firewall-cmd >/dev/null 2>&1 && firewall-cmd --state 2>/dev/null | grep -qi running; then
        firewall-cmd --permanent --add-port="${ctrl}/tcp" >/dev/null 2>&1 || true
        IFS=',' read -ra _pl <<< "$ports"
        for p in "${_pl[@]}"; do
            p="${p// /}"
            [[ "$p" =~ ^[0-9]+$ ]] || continue
            firewall-cmd --permanent --add-port="${p}/tcp" >/dev/null 2>&1 || true
        done
        firewall-cmd --reload >/dev/null 2>&1 || true
    fi
    return 0
}

ensure_rathole_token() {
    local pair_id="$1" peer_ip="${2:-}"
    local keydir="$KEYS_ROOT/pair_${pair_id}" created=0
    install -d -m700 "$keydir"
    if [[ ! -f "$keydir/rathole.token" ]]; then
        if [[ -n "$peer_ip" ]] && command -v scp >/dev/null 2>&1; then
            scp -o ConnectTimeout=8 -o StrictHostKeyChecking=accept-new -q \
                "root@${peer_ip}:${keydir}/rathole.token" "$keydir/" 2>/dev/null || true
        fi
    fi
    if [[ ! -f "$keydir/rathole.token" ]]; then
        openssl rand -hex 24 > "$keydir/rathole.token"
        chmod 600 "$keydir/rathole.token"
        created=1
        if [[ -n "$peer_ip" ]] && command -v scp >/dev/null 2>&1; then
            ssh -o ConnectTimeout=8 -o StrictHostKeyChecking=accept-new -o BatchMode=yes \
                "root@${peer_ip}" "mkdir -p '$keydir' && chmod 700 '$keydir'" >/dev/null 2>&1 || true
            if ! scp -o ConnectTimeout=8 -q "$keydir/rathole.token" "root@${peer_ip}:${keydir}/" 2>/dev/null; then
                log_warn "Token not copied via SSH — sync manually:"
                hint "sudo jojonet --export-keys $peer_ip /root/jojonet-keys.tar.gz"
                hint "On peer: sudo jojonet --import-keys <THIS_IP> /root/jojonet-keys.tar.gz"
            fi
        elif (( created )); then
            log_warn "New Rathole token created. Peer must use the same token (export/import keys)."
        fi
    fi
    printf '%s' "$keydir"
}

build_rathole_runtime_config() {
    local name="$1" role="$2" rem="$3" ctrl_port="$4" keydir="$5" ports="${6:-$DEFAULT_RATHOLE_FWD}"
    local token toml p block="" nsvc=0
    install -d -m700 "$RATHOLE_CONFIG_DIR"
    [[ -f "$keydir/rathole.token" ]] || return 1
    token=$(tr -d '\r\n' < "$keydir/rathole.token")
    [[ -n "$token" ]] || return 1
    if ! [[ "$ctrl_port" =~ ^[0-9]+$ ]] || (( ctrl_port < 1 || ctrl_port > 65535 )); then
        log_error "Invalid Rathole control port: $ctrl_port"
        return 1
    fi
    toml="$RATHOLE_CONFIG_DIR/${name}.toml"

    block=""
    IFS=',' read -ra _plist <<< "$ports"
    for p in "${_plist[@]}"; do
        p="${p// /}"
        [[ "$p" =~ ^[0-9]+$ ]] || continue
        nsvc=$((nsvc + 1))
        if [[ "$role" == "iran" ]]; then
            block="${block}
[server.services.p${p}]
type = \"tcp\"
token = \"${token}\"
bind_addr = \"0.0.0.0:${p}\"
"
        else
            block="${block}
[client.services.p${p}]
type = \"tcp\"
token = \"${token}\"
local_addr = \"127.0.0.1:${p}\"
"
        fi
    done
    if (( nsvc < 1 )); then
        log_error "Rathole needs at least one valid forward port"
        return 1
    fi

    if [[ "$role" == "iran" ]]; then
        cat > "$toml" <<EOF
# JojoNet Rathole SERVER (Iran) — reverse TCP
# Users → Iran:Ports → Kharej localhost:Ports
[server]
bind_addr = "0.0.0.0:${ctrl_port}"
default_token = "${token}"
${block}
EOF
    else
        cat > "$toml" <<EOF
# JojoNet Rathole CLIENT (Kharej) — reverse TCP
# Connects out to Iran control port
[client]
remote_addr = "${rem}:${ctrl_port}"
default_token = "${token}"
${block}
EOF
    fi
    chmod 600 "$toml"
    echo "$toml"
}

create_rathole_runner_script() {
    if ! cat << 'EOF' > "$RATHOLE_RUNNER"
#!/usr/bin/env bash
set -Eeuo pipefail

_JOJONET_CONF_KEYS="Name TunnelMode Role Local_IP Remote_IP Subnet_Byte Tun_IP Tun_Remote_IP_Raw Tun_Server_IP Tun_Client_IP Suggested_MTU Ports TcpPort KeyDir GreKey PaqetYaml ForwardProto VxlanVni VxlanPort WgPrivateKey WgPublicKey WgPeerPublicKey HyYaml HyAuth HySni HyHopRange HyHopInterval RatholeToml"

load_safe_config() {
    local file="$1" line key val
    Name="" TunnelMode="gre" Role="" Local_IP="" Remote_IP="" Subnet_Byte=""
    Tun_IP="" Tun_Remote_IP_Raw="" Tun_Server_IP="" Tun_Client_IP=""
    Suggested_MTU="" Ports="" TcpPort="" KeyDir="" GreKey=""
    PaqetYaml="" ForwardProto="" VxlanVni="" VxlanPort=""
    WgPrivateKey="" WgPublicKey="" WgPeerPublicKey="" HyYaml="" HyAuth="" HySni="" HyHopRange="" HyHopInterval="" RatholeToml=""
    [[ -r "$file" ]] || return 1
    while IFS= read -r line || [[ -n "$line" ]]; do
        line="${line%%#*}"
        line="${line#"${line%%[![:space:]]*}"}"
        line="${line%"${line##*[![:space:]]}"}"
        [[ -z "$line" ]] && continue
        [[ "$line" =~ ^([A-Za-z_][A-Za-z0-9_]*)=(.*)$ ]] || return 1
        key="${BASH_REMATCH[1]}"
        val="${BASH_REMATCH[2]}"
        case " ${_JOJONET_CONF_KEYS} " in *" $key "*) ;; *) return 1 ;; esac
        if [[ "$val" =~ ^\"(.*)\"$ ]]; then val="${BASH_REMATCH[1]}"
        elif [[ "$val" =~ ^\'(.*)\'$ ]]; then val="${BASH_REMATCH[1]}"; fi
        case "$val" in *'$('*|*'`'*|*';'*|*'|'*|*'&'*|*$'\n'*|*$'\r'*) return 1 ;; esac
        printf -v "$key" '%s' "$val"
    done < "$file"
    [[ -n "${Name:-}" ]] || return 1
    return 0
}

ACTION="${1:-}"
CONFIG_FILE="${2:-}"
RATHOLE_BIN="/usr/local/bin/rathole"

[[ -n "$CONFIG_FILE" && -f "$CONFIG_FILE" ]] || { echo "Config missing" >&2; exit 1; }
load_safe_config "$CONFIG_FILE" || { echo "Bad config" >&2; exit 1; }
toml="${RatholeToml:-}"

stop_rh() {
    pkill -f "rathole.*${toml}" >/dev/null 2>&1 || true
    pkill -f "rathole .*/${Name}\\.toml" >/dev/null 2>&1 || true
}

case "$ACTION" in
    start)
        stop_rh
        [[ -x "$RATHOLE_BIN" ]] || { echo "rathole binary missing" >&2; exit 1; }
        [[ -f "$toml" ]] || { echo "toml missing: $toml" >&2; exit 1; }
        echo "[jojonet-rathole:${Name}] Starting ($Role) $toml"
        exec "$RATHOLE_BIN" "$toml"
        ;;
    stop)
        stop_rh
        exit 0
        ;;
    *)
        echo "Invalid action" >&2
        exit 1
        ;;
esac
EOF
    then
        return 1
    fi
    chmod +x "$RATHOLE_RUNNER"
}

