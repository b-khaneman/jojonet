load_safe_config() {
    local file="$1" line key val
    Name="" TunnelMode="gre" Role="" Local_IP="" Remote_IP="" Subnet_Byte=""
    Tun_IP="" Tun_Remote_IP_Raw="" Tun_Server_IP="" Tun_Client_IP=""
    Suggested_MTU="" Ports="" TcpPort="" KeyDir="" GreKey=""
    PaqetYaml="" ForwardProto="" VxlanVni="" VxlanPort=""
    WgPrivateKey="" WgPublicKey="" WgPeerPublicKey="" HyYaml="" HyAuth="" HySni=""
    [[ -r "$file" ]] || return 1
    while IFS= read -r line || [[ -n "$line" ]]; do
        line="${line%%#*}"
        line="${line#"${line%%[![:space:]]*}"}"
        line="${line%"${line##*[![:space:]]}"}"
        [[ -z "$line" ]] && continue
        [[ "$line" =~ ^([A-Za-z_][A-Za-z0-9_]*)=(.*)$ ]] || return 1
        key="${BASH_REMATCH[1]}"
        val="${BASH_REMATCH[2]}"
        case " ${_JOJONET_CONF_KEYS} " in
            *" $key "*) ;;
            *) return 1 ;;
        esac
        if [[ "$val" =~ ^\"(.*)\"$ ]]; then
            val="${BASH_REMATCH[1]}"
        elif [[ "$val" =~ ^\'(.*)\'$ ]]; then
            val="${BASH_REMATCH[1]}"
        fi
        case "$val" in
            *'$('*|*'`'*|*';'*|*'|'*|*'&'*|*$'\n'*|*$'\r'*) return 1 ;;
        esac
        printf -v "$key" '%s' "$val"
    done < "$file"
    [[ -n "${Name:-}" ]] || return 1
    TunnelMode=${TunnelMode:-gre}
    return 0
}


# ==========================================
# Secure download helpers
# ==========================================

CHECKSUMS_FILE="${JOJONET_CHECKSUMS_FILE:-/etc/jojonet/checksums.sha256}"
CHECKSUMS_BUNDLED="/usr/local/share/jojonet/checksums.sha256"

lookup_checksum() {
    local name="$1" line hash fname f
    for f in "$CHECKSUMS_FILE" "$CHECKSUMS_BUNDLED"; do
        [[ -f "$f" ]] || continue
        while IFS= read -r line || [[ -n "$line" ]]; do
            [[ "$line" =~ ^[[:space:]]*# ]] && continue
            [[ -z "${line// }" ]] && continue
            hash=$(awk '{print $1}' <<< "$line")
            fname=$(awk '{print $2}' <<< "$line")
            fname="${fname#\*}"
            if [[ "$fname" == "$name" || "$fname" == */"$name" ]]; then
                printf '%s' "$hash"
                return 0
            fi
        done < "$f"
    done
    return 1
}

sha256_of() {
    if command -v sha256sum >/dev/null 2>&1; then
        sha256sum "$1" | awk '{print $1}'
    elif command -v shasum >/dev/null 2>&1; then
        shasum -a 256 "$1" | awk '{print $1}'
    else
        openssl dgst -sha256 "$1" | awk '{print $NF}'
    fi
}

verify_sha256() {
    local file="$1" expected="$2" actual
    [[ -f "$file" ]] || return 1
    if [[ -z "$expected" ]]; then
        actual=$(sha256_of "$file")
        if [[ "${JOJONET_ALLOW_UNSIGNED:-0}" == "1" ]]; then
            log_warn "UNSIGNED download accepted (JOJONET_ALLOW_UNSIGNED=1): $(basename "$file") sha256=$actual"
            return 0
        fi
        log_warn "No pinned checksum for $(basename "$file")."
        log_warn "Computed sha256=$actual"
        log_warn "Add this line to $CHECKSUMS_FILE for next time:"
        log_warn "  $actual  $(basename "$file")"
        if [[ -t 0 || -t 2 ]]; then
            local ans=""
            read -r -p "Accept this unsigned download once? [y/N]: " ans </dev/tty 2>/dev/null || read -r -p "Accept this unsigned download once? [y/N]: " ans
            ans=$(printf '%s' "$ans" | tr '[:upper:]' '[:lower:]')
            if [[ "$ans" == "y" || "$ans" == "yes" ]]; then
                # Persist hash for future runs
                install -d -m700 "$(dirname "$CHECKSUMS_FILE")" 2>/dev/null || true
                echo "$actual  $(basename "$file")" >> "$CHECKSUMS_FILE" 2>/dev/null || true
                log_info "Accepted and pinned locally."
                return 0
            fi
        fi
        log_error "Refused unsigned download. Set JOJONET_ALLOW_UNSIGNED=1 or pin checksum."
        return 1
    fi
    actual=$(sha256_of "$file")
    if [[ "$actual" != "$expected" ]]; then
        log_error "Checksum mismatch for $(basename "$file")"
        log_error "  expected: $expected"
        log_error "  actual:   $actual"
        return 1
    fi
    log_info "Checksum OK: $(basename "$file")"
    return 0
}

download_verified() {
    local url="$1" dest="$2" asset_name="$3" expected=""
    expected=$(lookup_checksum "$asset_name" || true)
    if command -v curl >/dev/null 2>&1; then
        curl -fsSL "$url" -o "$dest" || return 1
    elif command -v wget >/dev/null 2>&1; then
        wget -qO "$dest" "$url" || return 1
    else
        log_error "curl or wget required."
        return 1
    fi
    verify_sha256 "$dest" "$expected"
}

# ==========================================
# Self-update from GitHub
# ==========================================

jojonet_raw_base() {
    printf 'https://raw.githubusercontent.com/%s/%s/%s' \
        "$JOJONET_GITHUB_USER" "$JOJONET_GITHUB_REPO" "$JOJONET_GITHUB_BRANCH"
}

fetch_remote_jojonet_version() {
    local url tmp ver=""
    url="$(jojonet_raw_base)/jojonet"
    tmp=$(mktemp /tmp/jojonet-ver.XXXXXX) || return 1
    if command -v curl >/dev/null 2>&1; then
        curl -fsSL --max-time 20 "$url" -o "$tmp" 2>/dev/null || { rm -f "$tmp"; return 1; }
    elif command -v wget >/dev/null 2>&1; then
        wget -qO "$tmp" --timeout=20 "$url" 2>/dev/null || { rm -f "$tmp"; return 1; }
    else
        rm -f "$tmp"
        return 1
    fi
    ver=$(grep -m1 'JOJONET_VERSION=' "$tmp" 2>/dev/null | cut -d'"' -f2 || true)
    rm -f "$tmp"
    [[ -n "$ver" ]] || return 1
    printf '%s' "$ver"
}

check_jojonet_update() {
    local remote=""
    echo -e "${CYAN}=== JojoNet update check ===${NC}"
    echo -e "  Installed: ${GREEN}${JOJONET_VERSION}${NC}"
    echo -e "  Source:    $(jojonet_raw_base)/jojonet"
    remote=$(fetch_remote_jojonet_version) || {
        log_error "Could not fetch remote version (network / GitHub)."
        return 1
    }
    echo -e "  Remote:    ${GREEN}${remote}${NC}"
    if [[ "$remote" == "$JOJONET_VERSION" ]]; then
        echo -e "${GREEN}[+] Already up to date.${NC}"
        return 0
    fi
    echo -e "${YELLOW}[!] Update available: ${JOJONET_VERSION} -> ${remote}${NC}"
    echo -e "  Run: ${CYAN}sudo jojonet --update${NC}"
    return 2
}

self_update_jojonet() {
    local base url tmp sums_tmp un_tmp backup remote_ver="" expected="" actual=""
    local force="${1:-0}"

    (( EUID == 0 )) || { log_error "Run as root: sudo jojonet --update"; return 1; }

    echo -e "${CYAN}=== JojoNet self-update ===${NC}"
    echo -e "  Current: ${GREEN}${JOJONET_VERSION}${NC}"
    base=$(jojonet_raw_base)
    url="${base}/jojonet"

    remote_ver=$(fetch_remote_jojonet_version) || {
        log_error "Cannot reach GitHub update source."
        return 1
    }
    echo -e "  Remote:  ${GREEN}${remote_ver}${NC}"
    echo -e "  URL:     $url"

    if [[ "$remote_ver" == "$JOJONET_VERSION" && "$force" != "1" && "${JOJONET_FORCE_UPDATE:-0}" != "1" ]]; then
        echo -e "${GREEN}[+] Already on latest (${JOJONET_VERSION}).${NC}"
        echo -e "  Force reinstall: ${CYAN}sudo jojonet --update --force${NC}"
        return 0
    fi

    if [[ -t 0 || -t 2 ]]; then
        local ans=""
        read -r -p "Update JojoNet to v${remote_ver}? [Y/n]: " ans </dev/tty 2>/dev/null || read -r -p "Update JojoNet to v${remote_ver}? [Y/n]: " ans
        ans=$(printf '%s' "${ans:-y}" | tr '[:upper:]' '[:lower:]')
        if [[ "$ans" == "n" || "$ans" == "no" ]]; then
            echo -e "${YELLOW}Cancelled.${NC}"
            return 0
        fi
    fi

    tmp=$(mktemp /tmp/jojonet-update.XXXXXX) || return 1
    log_note "Downloading new jojonet..."
    if command -v curl >/dev/null 2>&1; then
        curl -fsSL "$url" -o "$tmp" || { rm -f "$tmp"; log_error "Download failed"; return 1; }
    else
        wget -qO "$tmp" "$url" || { rm -f "$tmp"; log_error "Download failed"; return 1; }
    fi

    head -1 "$tmp" | grep -q '^#!/' || { rm -f "$tmp"; log_error "Invalid downloaded script"; return 1; }
    grep -q 'JOJONET_VERSION=' "$tmp" || { rm -f "$tmp"; log_error "Downloaded file is not jojonet"; return 1; }

    # Optional checksum from repo
    sums_tmp=$(mktemp /tmp/jojonet-sums.XXXXXX) || true
    if [[ -n "${sums_tmp:-}" ]] && curl -fsSL "${base}/checksums.sha256" -o "$sums_tmp" 2>/dev/null; then
        expected=$(awk '$2=="jojonet" || $2=="*jojonet" {print $1; exit}' "$sums_tmp" || true)
        if [[ -n "$expected" ]]; then
            actual=$(sha256_of "$tmp")
            if [[ "$actual" != "$expected" ]]; then
                log_error "Checksum mismatch for jojonet update"
                log_error "  expected: $expected"
                log_error "  actual:   $actual"
                if [[ "${JOJONET_ALLOW_UNSIGNED:-0}" != "1" ]]; then
                    rm -f "$tmp" "$sums_tmp"
                    return 1
                fi
                log_warn "Continuing because JOJONET_ALLOW_UNSIGNED=1"
            else
                log_info "Checksum OK"
            fi
        fi
        install -d -m755 /usr/local/share/jojonet
        install -m644 "$sums_tmp" /usr/local/share/jojonet/checksums.sha256
        install -d -m700 /etc/jojonet
        install -m644 "$sums_tmp" /etc/jojonet/checksums.sha256
    fi
    rm -f "${sums_tmp:-}"

    backup="${JOJONET_BIN_PATH}.bak.${JOJONET_VERSION}"
    if [[ -f "$JOJONET_BIN_PATH" ]]; then
        cp -f "$JOJONET_BIN_PATH" "$backup"
        log_info "Backup: $backup"
    fi

    install -m755 "$tmp" "$JOJONET_BIN_PATH"
    rm -f "$tmp"
    log_info "Installed: $JOJONET_BIN_PATH (v${remote_ver})"

    # Refresh uninstall helper if present upstream
    un_tmp=$(mktemp /tmp/jojonet-un.XXXXXX) || true
    if [[ -n "${un_tmp:-}" ]] && curl -fsSL "${base}/uninstall.sh" -o "$un_tmp" 2>/dev/null; then
        install -m755 "$un_tmp" /usr/local/bin/jojonet-uninstall
        log_info "Updated: jojonet-uninstall"
    fi
    rm -f "${un_tmp:-}"

    # Regenerate runners/services with new code (exec new binary helpers)
    if "$JOJONET_BIN_PATH" --refresh-templates >/dev/null 2>&1; then
        log_info "Runtime templates refreshed"
    else
        log_warn "Template refresh returned a warning — run: sudo jojonet --refresh-templates"
    fi

    echo ""
    echo -e "${GREEN}[+] Update complete.${NC}"
    echo -e "  Old: ${JOJONET_VERSION}"
    echo -e "  New: $($JOJONET_BIN_PATH --version 2>/dev/null || echo "v${remote_ver}")"
    echo -e "  Configs kept in: /etc/jojonet/"
    echo -e "  Rollback: cp -f $backup $JOJONET_BIN_PATH"
    echo ""
    return 0
}

