                echo -e "  ${CYAN}Hop Port:${NC}    ${HyHopRange}  every ${HyHopInterval:-$DEFAULT_HY2_HOP_INTERVAL}"
                echo -e "  ${YELLOW}Peer MUST use the same hop range${NC}"
            fi
