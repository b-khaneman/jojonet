# Safe config loader — whitelist keys only (never source shell)
_JOJONET_CONF_KEYS="Name TunnelMode Role Local_IP Remote_IP Subnet_Byte Tun_IP Tun_Remote_IP_Raw Tun_Server_IP Tun_Client_IP Suggested_MTU Ports TcpPort KeyDir GreKey PaqetYaml ForwardProto VxlanVni VxlanPort WgPrivateKey WgPublicKey WgPeerPublicKey HyYaml HyAuth HySni HyHopRange HyHopInterval RatholeToml"

load_safe_config() {
    local file="$1" line key val
    Name="" TunnelMode="gre" Role="" Local_IP="" Remote_IP="" Subnet_Byte=""
    Tun_IP="" Tun_Remote_IP_Raw="" Tun_Server_IP="" Tun_Client_IP=""
    Suggested_MTU="" Ports="" TcpPort="" KeyDir="" GreKey=""
    PaqetYaml="" ForwardProto="" VxlanVni="" VxlanPort=""
    WgPrivateKey="" WgPublicKey="" WgPeerPublicKey="" HyYaml="" HyAuth="" HySni="" HyHopRange="" HyHopInterval="" RatholeToml=""
    [[ -r "$file" ]] || return 1
    while IFS= read -r line || [[ -n "$line" ]]; do
        line="${line%%#*}"
        line="${line#"${line%%[![:space:]]*}"}"
        line="${line%"${line##*[![:space:]]}"}"
        [[ -z "$line" ]] && continue
        [[ "$line" =~ ^([A-Za-z_][A-Za-z0-9_]*)=(.*)$ ]] || return 1
        key="${BASH_REMATCH[1]}"
        val="${BASH_REMATCH[2]}"
        case " ${_JOJONET_CONF_KEYS} " in
            *" $key "*) ;;
            *) return 1 ;;
        esac
        if [[ "$val" =~ ^\"(.*)\"$ ]]; then
            val="${BASH_REMATCH[1]}"
        elif [[ "$val" =~ ^\'(.*)\'$ ]]; then
            val="${BASH_REMATCH[1]}"
        fi
        case "$val" in
            *'$('*|*'`'*|*';'*|*'|'*|*'&'*|*$'\n'*|*$'\r'*) return 1 ;;
        esac
        printf -v "$key" '%s' "$val"
    done < "$file"
    [[ -n "${Name:-}" ]] || return 1
    TunnelMode=${TunnelMode:-gre}
    return 0
}


# ==========================================
# Secure download helpers
# ==========================================

CHECKSUMS_FILE="${JOJONET_CHECKSUMS_FILE:-/etc/jojonet/checksums.sha256}"
CHECKSUMS_BUNDLED="/usr/local/share/jojonet/checksums.sha256"

lookup_checksum() {
    local name="$1" line hash fname f
    for f in "$CHECKSUMS_FILE" "$CHECKSUMS_BUNDLED"; do
        [[ -f "$f" ]] || continue
        while IFS= read -r line || [[ -n "$line" ]]; do
            [[ "$line" =~ ^[[:space:]]*# ]] && continue
            [[ -z "${line// }" ]] && continue
            hash=$(awk '{print $1}' <<< "$line")
            fname=$(awk '{print $2}' <<< "$line")
            fname="${fname#\*}"
            if [[ "$fname" == "$name" || "$fname" == */"$name" ]]; then
                printf '%s' "$hash"
                return 0
            fi
        done < "$f"
    done
    return 1
}

sha256_of() {
    if command -v sha256sum >/dev/null 2>&1; then
        sha256sum "$1" | awk '{print $1}'
    elif command -v shasum >/dev/null 2>&1; then
        shasum -a 256 "$1" | awk '{print $1}'
    else
        openssl dgst -sha256 "$1" | awk '{print $NF}'
    fi
}

verify_sha256() {
    local file="$1" expected="$2" actual
    [[ -f "$file" ]] || return 1
    if [[ -z "$expected" ]]; then
        actual=$(sha256_of "$file")
        if [[ "${JOJONET_ALLOW_UNSIGNED:-0}" == "1" ]]; then
            log_warn "UNSIGNED download accepted (JOJONET_ALLOW_UNSIGNED=1): $(basename "$file") sha256=$actual"
            return 0
        fi
        log_warn "No pinned checksum for $(basename "$file")."
        log_warn "Computed sha256=$actual"
        log_warn "Add this line to $CHECKSUMS_FILE for next time:"
        log_warn "  $actual  $(basename "$file")"
        if [[ -t 0 || -t 2 ]]; then
            local ans=""
            read -r -p "Accept this unsigned download once? [y/N]: " ans </dev/tty 2>/dev/null || read -r -p "Accept this unsigned download once? [y/N]: " ans
            ans=$(printf '%s' "$ans" | tr '[:upper:]' '[:lower:]')
            if [[ "$ans" == "y" || "$ans" == "yes" ]]; then
                # Persist hash for future runs
                install -d -m700 "$(dirname "$CHECKSUMS_FILE")" 2>/dev/null || true
                echo "$actual  $(basename "$file")" >> "$CHECKSUMS_FILE" 2>/dev/null || true
                log_info "Accepted and pinned locally."
                return 0
            fi
        fi
        log_error "Refused unsigned download. Set JOJONET_ALLOW_UNSIGNED=1 or pin checksum."
        return 1
    fi
    actual=$(sha256_of "$file")
    if [[ "$actual" != "$expected" ]]; then
        log_error "Checksum mismatch for $(basename "$file")"
        log_error "  expected: $expected"
        log_error "  actual:   $actual"
        return 1
    fi
    log_info "Checksum OK: $(basename "$file")"
    return 0
}

download_verified() {
    local url="$1" dest="$2" asset_name="$3" expected=""
    expected=$(lookup_checksum "$asset_name" || true)
    if command -v curl >/dev/null 2>&1; then
        curl -fsSL "$url" -o "$dest" || return 1
    elif command -v wget >/dev/null 2>&1; then
        wget -qO "$dest" "$url" || return 1
    else
        log_error "curl or wget required."
        return 1
    fi
    verify_sha256 "$dest" "$expected"
}

# ==========================================
# Self-update from GitHub (with Iran-friendly mirrors)
# ==========================================

jojonet_raw_base() {
    printf 'https://raw.githubusercontent.com/%s/%s/%s' \
        "$JOJONET_GITHUB_USER" "$JOJONET_GITHUB_REPO" "$JOJONET_GITHUB_BRANCH"
}

# Candidate URLs for a repo file (raw GitHub + mirrors)
jojonet_mirror_urls() {
    local file="$1"
    local u="$JOJONET_GITHUB_USER" r="$JOJONET_GITHUB_REPO" b="$JOJONET_GITHUB_BRANCH"
    printf '%s\n' \
        "https://raw.githubusercontent.com/${u}/${r}/${b}/${file}" \
        "https://cdn.jsdelivr.net/gh/${u}/${r}@${b}/${file}" \
        "https://raw.gitmirror.com/${u}/${r}/${b}/${file}" \
        "https://ghproxy.net/https://raw.githubusercontent.com/${u}/${r}/${b}/${file}" \
        "https://mirror.ghproxy.com/https://raw.githubusercontent.com/${u}/${r}/${b}/${file}"
}

# Download file trying mirrors; prints which URL worked to stderr when verbose
download_jojonet_asset() {
    local file="$1" dest="$2" quiet="${3:-0}"
    local url=""
    command -v curl >/dev/null 2>&1 || command -v wget >/dev/null 2>&1 || return 1
    while IFS= read -r url; do
        [[ -z "$url" ]] && continue
        (( quiet )) || echo -e "  ${CYAN}try${NC} $url" >&2
        if command -v curl >/dev/null 2>&1; then
            if curl -fsSL --connect-timeout 8 --max-time 45 "$url" -o "$dest" 2>/dev/null; then
                [[ -s "$dest" ]] && return 0
            fi
        else
            if wget -qO "$dest" --timeout=45 "$url" 2>/dev/null; then
                [[ -s "$dest" ]] && return 0
            fi
        fi
        rm -f "$dest"
    done < <(jojonet_mirror_urls "$file")
    return 1
}

fetch_remote_jojonet_version() {
    local tmp ver=""
    tmp=$(mktemp /tmp/jojonet-ver.XXXXXX) || return 1
    if ! download_jojonet_asset "jojonet" "$tmp" 1; then
        rm -f "$tmp"
        return 1
    fi
    ver=$(grep -m1 'JOJONET_VERSION=' "$tmp" 2>/dev/null | cut -d'"' -f2 || true)
    rm -f "$tmp"
    [[ -n "$ver" ]] || return 1
    printf '%s' "$ver"
}

check_jojonet_update() {
    local remote=""
    echo -e "${CYAN}=== JojoNet update check ===${NC}"
    echo -e "  Installed: ${GREEN}${JOJONET_VERSION}${NC}"
    echo -e "  Binary:    $(command -v jojonet 2>/dev/null || echo "$JOJONET_BIN_PATH")"
    echo -e "  Source:    $(jojonet_raw_base)/jojonet (+ mirrors)"
    remote=$(fetch_remote_jojonet_version) || {
        echo -e "${RED}[!] Could not reach GitHub / mirrors.${NC}" >&2
        echo -e "  Bootstrap: ${CYAN}curl -fsSL https://raw.githubusercontent.com/b-khaneman/jojonet/main/install.sh | sudo bash${NC}" >&2
        echo -e "  Or mirror: ${CYAN}curl -fsSL https://cdn.jsdelivr.net/gh/b-khaneman/jojonet@main/install.sh | sudo bash${NC}" >&2
        return 1
    }
    echo -e "  Remote:    ${GREEN}${remote}${NC}"
    if [[ "$remote" == "$JOJONET_VERSION" ]]; then
        echo -e "${GREEN}[+] Already up to date.${NC}"
        return 0
    fi
    echo -e "${YELLOW}[!] Update available: ${JOJONET_VERSION} -> ${remote}${NC}"
    echo -e "  Run: ${CYAN}sudo jojonet --update${NC}"
    return 2
}

# $1=force(0/1)  $2=ask_confirm(0/1) — CLI passes ask=0
self_update_jojonet() {
    local tmp sums_tmp un_tmp backup remote_ver="" expected="" actual="" new_ver=""
    local force="${1:-0}"
    local ask_confirm="${2:-0}"

    (( EUID == 0 )) || { echo -e "${RED}[!] Run as root: sudo jojonet --update${NC}" >&2; return 1; }

    echo -e "${CYAN}=== JojoNet self-update ===${NC}"
    echo -e "  Current: ${GREEN}${JOJONET_VERSION}${NC}"

    remote_ver=$(fetch_remote_jojonet_version) || {
        echo -e "${RED}[!] Cannot reach GitHub update source (all mirrors failed).${NC}" >&2
        echo -e "  Try: ${CYAN}curl -fsSL https://cdn.jsdelivr.net/gh/b-khaneman/jojonet@main/install.sh | sudo bash${NC}" >&2
        return 1
    }
    echo -e "  Remote:  ${GREEN}${remote_ver}${NC}"

    if [[ "$remote_ver" == "$JOJONET_VERSION" && "$force" != "1" && "${JOJONET_FORCE_UPDATE:-0}" != "1" ]]; then
        echo -e "${GREEN}[+] Already on latest (${JOJONET_VERSION}).${NC}"
        echo -e "  Force reinstall: ${CYAN}sudo jojonet --update --force${NC}"
        return 0
    fi

    if [[ "$ask_confirm" == "1" ]]; then
        local ans=""
        read -r -p "Update JojoNet to v${remote_ver}? [Y/n]: " ans </dev/tty 2>/dev/null \
            || read -r -p "Update JojoNet to v${remote_ver}? [Y/n]: " ans || true
        ans=$(printf '%s' "${ans:-y}" | tr '[:upper:]' '[:lower:]')
        if [[ "$ans" == "n" || "$ans" == "no" ]]; then
            echo -e "${YELLOW}Cancelled.${NC}"
            return 0
        fi
    fi

    tmp=$(mktemp /tmp/jojonet-update.XXXXXX) || return 1
    echo -e "${YELLOW}[*] Downloading jojonet...${NC}"
    if ! download_jojonet_asset "jojonet" "$tmp" 0; then
        rm -f "$tmp"
        echo -e "${RED}[!] Download failed (all mirrors).${NC}" >&2
        return 1
    fi

    head -1 "$tmp" | grep -q '^#!/' || { rm -f "$tmp"; echo -e "${RED}[!] Invalid downloaded script${NC}" >&2; return 1; }
    grep -q 'JOJONET_VERSION=' "$tmp" || { rm -f "$tmp"; echo -e "${RED}[!] Downloaded file is not jojonet${NC}" >&2; return 1; }
    new_ver=$(grep -m1 'JOJONET_VERSION=' "$tmp" | cut -d'"' -f2 || true)

    sums_tmp=$(mktemp /tmp/jojonet-sums.XXXXXX) || true
    if [[ -n "${sums_tmp:-}" ]] && download_jojonet_asset "checksums.sha256" "$sums_tmp" 1; then
        expected=$(awk '$2=="jojonet" || $2=="*jojonet" {print $1; exit}' "$sums_tmp" || true)
        if [[ -n "$expected" ]]; then
            actual=$(sha256_of "$tmp")
            if [[ "$actual" != "$expected" ]]; then
                echo -e "${RED}[!] Checksum mismatch for jojonet update${NC}" >&2
                echo -e "  expected: $expected" >&2
                echo -e "  actual:   $actual" >&2
                if [[ "${JOJONET_ALLOW_UNSIGNED:-0}" != "1" ]]; then
                    rm -f "$tmp" "$sums_tmp"
                    return 1
                fi
                echo -e "${YELLOW}[!] Continuing because JOJONET_ALLOW_UNSIGNED=1${NC}" >&2
            else
                echo -e "${GREEN}[+] Checksum OK${NC}"
            fi
        fi
        install -d -m755 /usr/local/share/jojonet
        install -m644 "$sums_tmp" /usr/local/share/jojonet/checksums.sha256
        install -d -m700 /etc/jojonet
        install -m644 "$sums_tmp" /etc/jojonet/checksums.sha256
    else
        echo -e "${YELLOW}[!] No checksum file from mirrors — installing without verify${NC}"
    fi
    rm -f "${sums_tmp:-}"

    backup="${JOJONET_BIN_PATH}.bak.${JOJONET_VERSION}"
    if [[ -f "$JOJONET_BIN_PATH" ]]; then
        cp -f "$JOJONET_BIN_PATH" "$backup"
        echo -e "${GREEN}[+] Backup: $backup${NC}"
    fi

    install -d -m755 /usr/local/bin
    install -m755 "$tmp" "$JOJONET_BIN_PATH"
    # Also replace whatever `jojonet` resolves to if different (PATH copy)
    if command -v jojonet >/dev/null 2>&1; then
        local resolved
        resolved=$(command -v jojonet)
        if [[ -n "$resolved" && "$resolved" != "$JOJONET_BIN_PATH" && -w "$(dirname "$resolved")" ]]; then
            install -m755 "$tmp" "$resolved"
            echo -e "${GREEN}[+] Also updated: $resolved${NC}"
        fi
    fi
    rm -f "$tmp"
    echo -e "${GREEN}[+] Installed: $JOJONET_BIN_PATH (v${new_ver:-$remote_ver})${NC}"

    un_tmp=$(mktemp /tmp/jojonet-un.XXXXXX) || true
    if [[ -n "${un_tmp:-}" ]] && download_jojonet_asset "uninstall.sh" "$un_tmp" 1; then
        install -m755 "$un_tmp" /usr/local/bin/jojonet-uninstall
        echo -e "${GREEN}[+] Updated: jojonet-uninstall${NC}"
    fi
    rm -f "${un_tmp:-}"

    if "$JOJONET_BIN_PATH" --refresh-templates >/dev/null 2>&1; then
        echo -e "${GREEN}[+] Runtime templates refreshed${NC}"
    else
        echo -e "${YELLOW}[!] Template refresh warning — run: sudo jojonet --refresh-templates${NC}"
    fi

    echo ""
    echo -e "${GREEN}[+] Update complete.${NC}"
    echo -e "  Old: ${JOJONET_VERSION}"
    echo -e "  New: $($JOJONET_BIN_PATH --version 2>/dev/null || echo "jojonet ${new_ver:-$remote_ver}")"
    echo -e "  Configs kept in: /etc/jojonet/"
    [[ -f "$backup" ]] && echo -e "  Rollback: cp -f $backup $JOJONET_BIN_PATH"
    echo ""
    echo -e "${CYAN}=== What's new ===${NC}"
    if "$JOJONET_BIN_PATH" --changelog 2>/dev/null | head -n 55; then
        :
    else
        echo -e "  Run: ${CYAN}sudo jojonet --changelog${NC}"
    fi
    echo ""
    return 0
}

menu_update_jojonet() {
    command -v clear >/dev/null && clear
    logo
    print_banner "Update JojoNet"
    check_jojonet_update || true
    echo ""
    echo "  1) Update now"
    echo "  2) Force reinstall (same or new version)"
    echo "  0) Back"
    local c=""
    read -r -p "Select: " c || return 0
    case "$c" in
        1) self_update_jojonet 0 1; press_enter ;;
        2) self_update_jojonet 1 1; press_enter ;;
        *) ;;
    esac
}


resolve_server_role() {
    local ip="$1" forced="${JOJONET_ROLE:-}" role="" forced_lc=""
    forced_lc=$(printf '%s' "$forced" | tr '[:upper:]' '[:lower:]')
    case "$forced_lc" in
        iran|ir) printf '%s' "iran"; return 0 ;;
        kharej|foreign|out|abroad) printf '%s' "kharej"; return 0 ;;
    esac
    if role=$(detect_server_role "$ip"); then
        printf '%s' "$role"
        return 0
    fi
    prompt_server_role
}

export_pair_keys() {
    local peer="$1" out="${2:-}"
    local pair_id keydir
    pair_id=$(printf '%s' "$peer" | tr '.' '_')
    keydir="$KEYS_ROOT/pair_${pair_id}"
    [[ -d "$keydir" ]] || { log_error "No keys for peer $peer"; return 1; }
    out="${out:-/root/jojonet-keys-${pair_id}.tar.gz}"
    tar -czf "$out" -C "$keydir" . || return 1
    chmod 600 "$out"
    log_info "Exported keys: $out"
    echo "$out"
}

import_pair_keys() {
    local peer="$1" archive="$2"
    local pair_id keydir
    [[ -f "$archive" ]] || { log_error "Archive not found: $archive"; return 1; }
    pair_id=$(printf '%s' "$peer" | tr '.' '_')
    keydir="$KEYS_ROOT/pair_${pair_id}"
    install -d -m700 "$keydir"
    tar -xzf "$archive" -C "$keydir" || return 1
    chmod -R go-rwx "$keydir" 2>/dev/null || true
    log_info "Imported keys into $keydir"
}

healthcheck_tunnel() {
    local name="$1" file="$INSTANCES_DIR/$name.conf"
    local ok=0
    [[ -r "$file" ]] || { log_error "Unknown tunnel: $name"; return 1; }
    load_instance_config "$file" || return 1
    echo -e "${CYAN}=== Health: $name (${TunnelMode:-gre}) ===${NC}"
    local svc
    svc=$(tunnel_service_unit "$name")
    if systemctl is-active --quiet "$svc"; then
        echo -e "  service: ${GREEN}active${NC}"
        ok=$((ok + 1))
    else
        echo -e "  service: ${RED}inactive${NC}"
    fi
    case "${TunnelMode:-gre}" in
        gre|vxlan|wireguard)
            if ip link show "$name" >/dev/null 2>&1; then
                echo -e "  iface:   ${GREEN}present${NC}"
                ok=$((ok + 1))
            else
                echo -e "  iface:   ${RED}missing${NC}"
            fi
            if [[ -n "${Tun_Remote_IP_Raw:-}" ]]; then
                if ping -c1 -W2 "$Tun_Remote_IP_Raw" >/dev/null 2>&1; then
                    local _ms
                    _ms=$(ping -c1 -W2 "$Tun_Remote_IP_Raw" 2>/dev/null | grep -oE 'time=[0-9.]+' | head -1 | cut -d= -f2)
                    echo -e "  Kharej ping ${Tun_Remote_IP_Raw}: ${GREEN}ok${NC}${_ms:+ (${_ms} ms)}"
                    ok=$((ok + 1))
                else
                    echo -e "  Kharej ping ${Tun_Remote_IP_Raw}: ${YELLOW}fail${NC}"
                fi
            elif [[ "${Role:-}" == "kharej" && -n "${Tun_Client_IP:-}" ]]; then
                if ping -c1 -W2 "$Tun_Client_IP" >/dev/null 2>&1; then
                    local _ms
                    _ms=$(ping -c1 -W2 "$Tun_Client_IP" 2>/dev/null | grep -oE 'time=[0-9.]+' | head -1 | cut -d= -f2)
                    echo -e "  Iran ping ${Tun_Client_IP}: ${GREEN}ok${NC}${_ms:+ (${_ms} ms)}"
                    ok=$((ok + 1))
                else
                    echo -e "  Iran ping ${Tun_Client_IP}: ${YELLOW}fail${NC}"
                fi
            fi
            ;;
        tun_tcp)
            if pgrep -f "tun-(server|client).*${name}" >/dev/null 2>&1 || \
               ip link show "$name" >/dev/null 2>&1; then
                echo -e "  process: ${GREEN}running${NC}"
                ok=$((ok + 1))
            else
                echo -e "  process: ${RED}not running${NC}"
            fi
            if [[ -n "${Tun_Remote_IP_Raw:-}" ]]; then
                if ping -c1 -W2 "$Tun_Remote_IP_Raw" >/dev/null 2>&1; then
                    local _ms
                    _ms=$(ping -c1 -W2 "$Tun_Remote_IP_Raw" 2>/dev/null | grep -oE 'time=[0-9.]+' | head -1 | cut -d= -f2)
                    echo -e "  Kharej ping ${Tun_Remote_IP_Raw}: ${GREEN}ok${NC}${_ms:+ (${_ms} ms)}"
                    ok=$((ok + 1))
                else
                    echo -e "  Kharej ping ${Tun_Remote_IP_Raw}: ${YELLOW}fail${NC}"
                fi
            elif [[ "${Role:-}" == "kharej" && -n "${Tun_Client_IP:-}" ]]; then
                if ping -c1 -W2 "$Tun_Client_IP" >/dev/null 2>&1; then
                    local _ms
                    _ms=$(ping -c1 -W2 "$Tun_Client_IP" 2>/dev/null | grep -oE 'time=[0-9.]+' | head -1 | cut -d= -f2)
                    echo -e "  Iran ping ${Tun_Client_IP}: ${GREEN}ok${NC}${_ms:+ (${_ms} ms)}"
                    ok=$((ok + 1))
                else
                    echo -e "  Iran ping ${Tun_Client_IP}: ${YELLOW}fail${NC}"
                fi
            fi
            ;;
        paqet)
            if pgrep -f "paqet run -c.*/${name}\\.yaml" >/dev/null 2>&1; then
                echo -e "  process: ${GREEN}running${NC}"
                ok=$((ok + 1))
            else
                echo -e "  process: ${RED}not running${NC}"
            fi
            ;;
        hysteria2)
            if pgrep -f "hysteria.*${name}" >/dev/null 2>&1 || \
               pgrep -f "hysteria.*${name}\\.yaml" >/dev/null 2>&1; then
                echo -e "  process: ${GREEN}running${NC}"
                ok=$((ok + 1))
            else
                echo -e "  process: ${RED}not running${NC}"
            fi
            if [[ -n "${HyHopRange:-}" ]]; then
                echo -e "  hop:     ${GREEN}${HyHopRange}${NC} every ${HyHopInterval:-$DEFAULT_HY2_HOP_INTERVAL}"
                if [[ "${Role:-}" == "kharej" ]]; then
                    if hy2_hop_has_firewall_tools; then
                        echo -e "  hop fw:  ${GREEN}nft/iptables available${NC}"
                        ok=$((ok + 1))
                    else
                        echo -e "  hop fw:  ${RED}missing nft/iptables — hop will fail${NC}"
                    fi
                fi
            fi
            ;;
        rathole)
            if pgrep -f "rathole.*${name}" >/dev/null 2>&1 || \
               pgrep -f "rathole.*${name}\\.toml" >/dev/null 2>&1; then
                echo -e "  process: ${GREEN}running${NC}"
                ok=$((ok + 1))
            else
                echo -e "  process: ${RED}not running${NC}"
            fi
            echo -e "  role:    ${Role:-?} ($([[ "${Role:-}" == "iran" ]] && echo SERVER || echo CLIENT))"
            echo -e "  control: TCP ${TcpPort:-?}"
            [[ -n "${Ports:-}" ]] && echo -e "  forward: ${Ports}"
            [[ -n "${RatholeToml:-}" ]] && echo -e "  config:  ${RatholeToml}"
            ;;
    esac
    (( ok > 0 ))
}

