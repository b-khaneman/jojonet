    shopt -s nullglob
    local files=("$INSTANCES_DIR"/*.conf)
    shopt -u nullglob
    echo "${#files[@]}"
}

show_existing_tunnels_summary() {
    shopt -s nullglob
    local files=("$INSTANCES_DIR"/*.conf)
    shopt -u nullglob
    if (( ${#files[@]} == 0 )); then
        return 0
    fi
        echo -e "\n${CYAN}Active tunnels:${NC}"
    local f n r t
    for f in "${files[@]}"; do
        n=$(grep -E '^Name=' "$f" 2>/dev/null | head -1 | cut -d'"' -f2)
        r=$(grep -E '^Remote_IP=' "$f" 2>/dev/null | head -1 | cut -d'"' -f2)
        t=$(grep -E '^Tun_IP=' "$f" 2>/dev/null | head -1 | cut -d'"' -f2)
        local mode_disp
        mode_disp=$(grep -E '^TunnelMode=' "$f" 2>/dev/null | head -1 | cut -d'"' -f2)
        if [[ "${mode_disp:-gre}" == "paqet" ]]; then
            t=$(grep -E '^TcpPort=' "$f" 2>/dev/null | head -1 | cut -d'"' -f2)
            t=":${t:-?}"
        elif [[ "${mode_disp:-gre}" == "vxlan" ]]; then
            t=$(grep -E '^Tun_IP=' "$f" 2>/dev/null | head -1 | cut -d'"' -f2)
            t=$(echo "$t" | awk -F'/' '{print $1}')
        fi
        if systemctl is-active --quiet "$(tunnel_service_unit "$n")" 2>/dev/null; then
            echo -e "  ${BLUE}$n${NC} -> peer ${CYAN}$r${NC} | $t | ${GREEN}UP${NC}"
        else
            echo -e "  ${BLUE}$n${NC} -> peer ${CYAN}$r${NC} | $t | ${RED}DOWN${NC}"
        fi
    done
    echo ""
}

resolve_tunnel_ips() {
    local role="$1" subnet_byte="$2" mode="${3:-gre}"
    local net_prefix="$TUNNEL_NET_PREFIX"
    [[ "$mode" == "tun_tcp" ]] && net_prefix="$TUN_TCP_NET_PREFIX"
    [[ "$mode" == "vxlan" ]] && net_prefix="$VXLAN_NET_PREFIX"
    [[ "$mode" == "wireguard" ]] && net_prefix="$WG_NET_PREFIX"

    Tun_Server_IP="${net_prefix}.$subnet_byte.1"
    Tun_Client_IP="${net_prefix}.$subnet_byte.2"

    if [[ "$role" == "iran" ]]; then
        if [[ "$mode" == "tun_tcp" ]]; then
            Tun_IP="${Tun_Client_IP}/24"
            Tun_Remote_IP_Raw="$Tun_Server_IP"
        else
            Tun_IP="${net_prefix}.$subnet_byte.1/30"
            Tun_Remote_IP_Raw="${net_prefix}.$subnet_byte.2"
        fi
    else
        if [[ "$mode" == "tun_tcp" ]]; then
            Tun_IP="${Tun_Server_IP}/24"
        else
            Tun_IP="${net_prefix}.$subnet_byte.2/30"
        fi
        Tun_Remote_IP_Raw=""
    fi
}

detect_cpu_arch_zip() {
    case "$(uname -m)" in
        x86_64|amd64) echo "amd64.zip" ;;
        aarch64|arm64) echo "arm64.zip" ;;
        i386|i686) echo "386.zip" ;;
        *) return 1 ;;
    esac
}

install_tun_tcp_binaries() {
    if [[ -x "$TUNTCP_BIN_DIR/tun-server" && -x "$TUNTCP_BIN_DIR/tun-client" ]]; then
        return 0
    fi
    command -v unzip >/dev/null 2>&1 || {
        log_error "unzip required for TUN/TCP mode."
        return 1
    }
    local zip arch_zip tmpdir url
    arch_zip=$(detect_cpu_arch_zip) || {
        log_error "Unsupported CPU for TUN/TCP binaries."
        return 1
    }
    tmpdir=$(mktemp -d /tmp/jojonet-tun.XXXXXX) || return 1
    url="${LOCALTUN_RELEASE}/${arch_zip}"
    log_note "Downloading LocalTun TCP ($arch_zip)..."
    if ! download_verified "$url" "$tmpdir/$arch_zip" "$arch_zip"; then
        rm -rf "$tmpdir"
        return 1
    fi
    unzip -oq "$tmpdir/$arch_zip" -d "$tmpdir" || { rm -rf "$tmpdir"; return 1; }
    install -m755 "$tmpdir/tun-server" "$TUNTCP_BIN_DIR/tun-server"
    install -m755 "$tmpdir/tun-client" "$TUNTCP_BIN_DIR/tun-client"
    rm -rf "$tmpdir"
    log_info "tun-server / tun-client installed."
    return 0
}

try_pull_tun_tcp_keys() {
    local peer="$1" pair_id="$2" keydir="$3"
    command -v scp >/dev/null 2>&1 || return 1
    install -d -m700 "$keydir"
    if scp -o ConnectTimeout=10 -o StrictHostKeyChecking=accept-new -q \
        "root@${peer}:${keydir}/private_key.pem" \
        "root@${peer}:${keydir}/public_key.pem" \
        "$keydir/" 2>/dev/null; then
        chmod 600 "$keydir/private_key.pem" 2>/dev/null || true
        chmod 644 "$keydir/public_key.pem" 2>/dev/null || true
        [[ -f "$keydir/private_key.pem" && -f "$keydir/public_key.pem" ]] && return 0
    fi
    return 1
}

try_push_tun_tcp_keys() {
    local peer="$1" keydir="$2"
    command -v scp >/dev/null 2>&1 || return 1
    ssh -o ConnectTimeout=10 -o StrictHostKeyChecking=accept-new -o BatchMode=yes \
        "root@${peer}" "mkdir -p '$keydir' && chmod 700 '$keydir'" >/dev/null 2>&1 || return 1
    scp -o ConnectTimeout=10 -q "$keydir/private_key.pem" "$keydir/public_key.pem" \
        "root@${peer}:${keydir}/" 2>/dev/null
}

ensure_tun_tcp_keys() {
    local pair_id="$1" peer_ip="${2:-}"
    local keydir="$KEYS_ROOT/pair_${pair_id}"
    install -d -m700 "$keydir"

    if [[ -f "$keydir/private_key.pem" && -f "$keydir/public_key.pem" ]]; then
        printf '%s' "$keydir"
        return 0
    fi

    if [[ -n "$peer_ip" ]] && try_pull_tun_tcp_keys "$peer_ip" "$pair_id" "$keydir"; then
        log_info "Keys synced from peer $peer_ip"
        printf '%s' "$keydir"
        return 0
    fi

    command -v openssl >/dev/null 2>&1 || return 1
    log_note "Generating RSA keys (pair_${pair_id})..."
    openssl genrsa -out "$keydir/private_key.pem" 2048 >/dev/null 2>&1
    chmod 600 "$keydir/private_key.pem"
    openssl rsa -pubout -in "$keydir/private_key.pem" -out "$keydir/public_key.pem" >/dev/null 2>&1
    chmod 644 "$keydir/public_key.pem"

    if [[ -n "$peer_ip" ]]; then
        if try_push_tun_tcp_keys "$peer_ip" "$keydir"; then
            log_info "Keys pushed to peer $peer_ip via SSH"
        else
            log_warn "Auto key sync failed. Copy manually:"
            echo "    scp -r $keydir root@${peer_ip}:${KEYS_ROOT}/" >&2
        fi
    fi

    printf '%s' "$keydir"
}

show_tun_tcp_key_sync_hint() {
    local pair_id="$1" keydir="$2" peer_ip="${3:-}"
    echo -e "\n${YELLOW}=== TUN/PrivateIP/TCP Keys ===${NC}"
    echo -e "  Folder:  ${CYAN}$keydir${NC}"
    echo -e "  Pair ID: ${CYAN}$pair_id${NC}"
    [[ -n "$peer_ip" ]] && echo -e "  Peer:    ${CYAN}$peer_ip${NC}"
    echo -e "  ${YELLOW}Keys auto-sync via SSH when possible.${NC}"
    echo -e "  ${CYAN}Or without SSH:${NC} sudo jojonet --export-keys PEER /root/k.tar.gz"
    echo -e "                 sudo jojonet --import-keys PEER /root/k.tar.gz"
    echo ""
}

# ==========================================
# Paqet (Raw/KCP) helpers
# ==========================================

PAQET_IFACE="" PAQET_LOCAL_IP="" PAQET_GATEWAY_MAC=""

detect_cpu_arch_paqet() {
    case "$(uname -m)" in
        x86_64|amd64) echo "amd64" ;;
        aarch64|arm64) echo "arm64" ;;
        *) return 1 ;;
    esac
}

paqet_optimized_download_name() {
    local arch="$1"
    if [[ "$arch" == "arm64" ]]; then
        echo "paqet_linux_arm64-${PAQET_OPTIMIZED_VERSION}.tar.gz"
    else
        echo "paqet-linux-${arch}-${PAQET_OPTIMIZED_VERSION}.tar.gz"
    fi
}

install_paqet_binary() {
    if [[ -x "$PAQET_BIN_DIR/paqet" ]]; then
        return 0
    fi
    command -v tar >/dev/null 2>&1 || {
        echo -e "${RED}[!] tar required for Paqet install.${NC}" >&2
        return 1
    }
    local arch tmpdir url fname ok=0
    arch=$(detect_cpu_arch_paqet) || {
        echo -e "${RED}[!] Unsupported CPU for Paqet.${NC}" >&2
        return 1
    }
    tmpdir=$(mktemp -d /tmp/jojonet-paqet.XXXXXX) || return 1
    fname=$(paqet_optimized_download_name "$arch")
    url="https://github.com/${PAQET_OPTIMIZED_REPO}/releases/download/${PAQET_OPTIMIZED_TAG}/${fname}"
    echo -e "${YELLOW}[*] Downloading Paqet ($fname)...${NC}" >&2
    if download_verified "$url" "$tmpdir/paqet.tar.gz" "$fname"; then
        ok=1
    else
        local latest core_file
        latest="${PAQET_CORE_VERSION:-v1.0.0-alpha.16}"
        core_file="paqet-linux-${arch}-${latest}.tar.gz"
        url="https://github.com/${PAQET_CORE_REPO}/releases/download/${latest}/${core_file}"
        echo -e "${YELLOW}[*] Optimized build unavailable — trying pinned core: $core_file${NC}" >&2
        if download_verified "$url" "$tmpdir/paqet.tar.gz" "$core_file"; then
            ok=1
        fi
    fi
    if (( ok == 0 )); then
        echo -e "${RED}[!] Paqet download failed (or checksum missing — set JOJONET_ALLOW_UNSIGNED=1 once).${NC}" >&2
        rm -rf "$tmpdir"
        return 1
    fi
    tar -xzf "$tmpdir/paqet.tar.gz" -C "$tmpdir" 2>/dev/null || { rm -rf "$tmpdir"; return 1; }
    local bin_path=""
    if [[ -f "$tmpdir/paqet" ]]; then
        bin_path="$tmpdir/paqet"
    else
        bin_path=$(find "$tmpdir" -maxdepth 2 -type f -name paqet 2>/dev/null | head -1)
    fi
    [[ -n "$bin_path" && -f "$bin_path" ]] || {
        echo -e "${RED}[!] paqet binary not found in archive.${NC}" >&2
        rm -rf "$tmpdir"
        return 1
    }
    install -m755 "$bin_path" "$PAQET_BIN_DIR/paqet"
    rm -rf "$tmpdir"
    log_info "Paqet installed: $PAQET_BIN_DIR/paqet"
    return 0
}

get_paqet_network_info() {
    PAQET_IFACE="" PAQET_LOCAL_IP="" PAQET_GATEWAY_MAC=""
    local gw_ip=""
    PAQET_IFACE=$(ip route | awk '/default/ {print $5; exit}')
    [[ -n "$PAQET_IFACE" ]] || PAQET_IFACE="eth0"
    PAQET_LOCAL_IP=$(ip -4 addr show "$PAQET_IFACE" 2>/dev/null | awk '/inet / {print $2}' | cut -d/ -f1 | head -1)
    gw_ip=$(ip route | awk '/default/ {print $3; exit}')
    if [[ -n "$gw_ip" ]]; then
        ping -c 1 -W 1 "$gw_ip" >/dev/null 2>&1 || true
        PAQET_GATEWAY_MAC=$(ip neigh show "$gw_ip" 2>/dev/null | grep -oE '([0-9a-fA-F]{2}:){5}[0-9a-fA-F]{2}' | head -1)
        if [[ -z "$PAQET_GATEWAY_MAC" ]] && command -v arp >/dev/null 2>&1; then
            PAQET_GATEWAY_MAC=$(arp -n "$gw_ip" 2>/dev/null | awk "/^$gw_ip/ {print \$3}" | head -1)
        fi
    fi
    [[ -n "$PAQET_LOCAL_IP" && -n "$PAQET_GATEWAY_MAC" ]] || {
        echo -e "${RED}[!] Cannot detect network interface/MAC for Paqet.${NC}" >&2
        return 1
    }
    return 0
}

paqet_configure_iptables() {
    local port="$1" protocol="${2:-tcp}"
    command -v iptables >/dev/null 2>&1 || {
        echo -e "${YELLOW}[!] iptables not found — Paqet may need manual firewall rules.${NC}"
        return 0
    }
    local protos=()
    if [[ "$protocol" == "both" ]]; then
        protos=("tcp" "udp")
    else
        protos=("$protocol")
    fi
    local proto
    for proto in "${protos[@]}"; do
        iptables -t raw -C PREROUTING -p "$proto" --dport "$port" -j NOTRACK 2>/dev/null || \
            iptables -t raw -A PREROUTING -p "$proto" --dport "$port" -j NOTRACK
        iptables -t raw -C OUTPUT -p "$proto" --sport "$port" -j NOTRACK 2>/dev/null || \
            iptables -t raw -A OUTPUT -p "$proto" --sport "$port" -j NOTRACK
        if [[ "$proto" == "tcp" ]]; then
            iptables -t mangle -C OUTPUT -p tcp --sport "$port" --tcp-flags RST RST -j DROP 2>/dev/null || \
                iptables -t mangle -A OUTPUT -p tcp --sport "$port" --tcp-flags RST RST -j DROP
        fi
    done
    return 0
}

try_pull_paqet_secret() {
    local peer="$1" keydir="$2"
    command -v scp >/dev/null 2>&1 || return 1
    install -d -m700 "$keydir"
    scp -o ConnectTimeout=10 -o StrictHostKeyChecking=accept-new -q \
        "root@${peer}:${keydir}/paqet.secret" "$keydir/" 2>/dev/null || return 1
    chmod 600 "$keydir/paqet.secret" 2>/dev/null || true
    [[ -f "$keydir/paqet.secret" ]]
}

try_push_paqet_secret() {
    local peer="$1" keydir="$2"
    command -v scp >/dev/null 2>&1 || return 1
    ssh -o ConnectTimeout=10 -o StrictHostKeyChecking=accept-new -o BatchMode=yes \
        "root@${peer}" "mkdir -p '$keydir' && chmod 700 '$keydir'" >/dev/null 2>&1 || return 1
    scp -o ConnectTimeout=10 -q "$keydir/paqet.secret" "root@${peer}:${keydir}/" 2>/dev/null
}

ensure_paqet_secret() {
    local pair_id="$1" peer_ip="${2:-}"
    local keydir="$KEYS_ROOT/pair_${pair_id}"
    install -d -m700 "$keydir"

    if [[ -f "$keydir/paqet.secret" ]]; then
        printf '%s' "$keydir"
        return 0
    fi

    if [[ -n "$peer_ip" ]] && try_pull_paqet_secret "$peer_ip" "$keydir"; then
        log_info "Paqet secret synced from peer $peer_ip"
        printf '%s' "$keydir"
        return 0
    fi

    openssl rand -hex 16 > "$keydir/paqet.secret"
    chmod 600 "$keydir/paqet.secret"

    if [[ -n "$peer_ip" ]]; then
        if try_push_paqet_secret "$peer_ip" "$keydir"; then
            log_info "Paqet secret pushed to peer $peer_ip via SSH"
        else
            log_warn "Auto secret sync failed. Copy manually:"
            echo "    scp $keydir/paqet.secret root@${peer_ip}:${keydir}/" >&2
        fi
    fi
    printf '%s' "$keydir"
}

show_paqet_secret_hint() {
    local pair_id="$1" keydir="$2" peer_ip="${3:-}"
    echo -e "\n${YELLOW}=== Paqet Secret Key ===${NC}"
    echo -e "  Folder:  ${CYAN}$keydir/paqet.secret${NC}"
    echo -e "  Pair ID: ${CYAN}$pair_id${NC}"
    [[ -n "$peer_ip" ]] && echo -e "  Peer:    ${CYAN}$peer_ip${NC}"
    echo -e "  ${YELLOW}Secret auto-syncs via SSH when possible.${NC}"
    echo ""
}

write_paqet_server_yaml() {
    local name="$1" port="$2" secret="$3" conn="$4" mtu="$5" yaml="$6"
    get_paqet_network_info || return 1
    cat > "$yaml" <<EOF
# JojoNet Paqet Server
role: "server"
log:
  level: "info"
listen:
  addr: ":$port"
network:
  interface: "$PAQET_IFACE"
  ipv4:
    addr: "$PAQET_LOCAL_IP:$port"
    router_mac: "$PAQET_GATEWAY_MAC"
  tcp:
    local_flag: ["PA"]
transport:
  protocol: "kcp"
  conn: $conn
  kcp:
    key: "$secret"
    mode: "$DEFAULT_PAQET_KCP_MODE"
    block: "$DEFAULT_PAQET_ENCRYPTION"
    mtu: $mtu
EOF
    chmod 600 "$yaml"
}

write_paqet_client_yaml() {
    local name="$1" server_ip="$2" port="$3" secret="$4" conn="$5" mtu="$6"
    local forward_ports="$7" forward_proto="$8" yaml="$9"
    get_paqet_network_info || return 1
    {
        echo "# JojoNet Paqet Client"
        echo "role: \"client\""
        echo "log:"
        echo "  level: \"info\""
        if [[ -n "$forward_ports" ]]; then
            echo "forward:"
            local p protos=() proto
            IFS=',' read -ra _ports <<< "$forward_ports"
            for p in "${_ports[@]}"; do
                p="${p// /}"
                [[ -n "$p" ]] || continue
                case "$forward_proto" in
                    udp) protos=("udp") ;;
                    both) protos=("tcp" "udp") ;;
                    *) protos=("tcp") ;;
                esac
                for proto in "${protos[@]}"; do
                    echo "  - listen: \"0.0.0.0:$p\""
                    echo "    target: \"127.0.0.1:$p\""
                    echo "    protocol: \"$proto\""
                    paqet_configure_iptables "$p" "$proto"
                done
            done
        fi
        cat <<EOF
network:
  interface: "$PAQET_IFACE"
  ipv4:
    addr: "$PAQET_LOCAL_IP:0"
    router_mac: "$PAQET_GATEWAY_MAC"
  tcp:
    local_flag: ["PA"]
    remote_flag: ["PA"]
server:
  addr: "$server_ip:$port"
transport:
  protocol: "kcp"
  conn: $conn
  kcp:
    key: "$secret"
    mode: "$DEFAULT_PAQET_KCP_MODE"
    block: "$DEFAULT_PAQET_ENCRYPTION"
    mtu: $mtu
EOF
    } > "$yaml"
    chmod 600 "$yaml"
}

build_paqet_runtime_config() {
    local ins_name="$1" role_conf="$2" rem_ip="$3" tcp_port="$4" key_dir="$5"
    local fwd_port="$6" forward_proto="${7:-tcp}" yaml="$PAQET_CONFIG_DIR/${ins_name}.yaml"
    local secret="" conn="$DEFAULT_PAQET_CONN_CLIENT"

    [[ -f "$key_dir/paqet.secret" ]] || return 1
    secret=$(tr -d '\r\n' < "$key_dir/paqet.secret")

    if [[ "$role_conf" == "kharej" ]]; then
        conn="$DEFAULT_PAQET_CONN_SERVER"
        paqet_configure_iptables "$tcp_port" "tcp"
        write_paqet_server_yaml "$ins_name" "$tcp_port" "$secret" "$conn" "$DEFAULT_PAQET_MTU" "$yaml"
    else
        write_paqet_client_yaml "$ins_name" "$rem_ip" "$tcp_port" "$secret" "$conn" \
            "$DEFAULT_PAQET_MTU" "$fwd_port" "$forward_proto" "$yaml"
    fi
}

conf_get_field() {
    local conf="$1" field="$2"
    grep -E "^${field}=" "$conf" 2>/dev/null | head -1 | cut -d'"' -f2
}

tunnel_mode_from_name() {
    local name="$1" conf="$INSTANCES_DIR/$name.conf"
    local mode=""
    [[ -f "$conf" ]] && mode=$(conf_get_field "$conf" "TunnelMode")
    echo "${mode:-gre}"
}

deploy_tunnel() {
    local ins_name="$1" role_conf="$2" loc_ip="$3" rem_ip="$4" subnet_byte="$5"
    local tun_ip="$6" tun_remote="$7" ins_mtu="$8" fwd_port="$9"
    local tunnel_mode="${10:-gre}" tcp_port="${11:-$DEFAULT_TCP_PORT}" key_dir="${12:-}"
    local tun_server_ip="${13:-}" tun_client_ip="${14:-}" forward_proto="${15:-tcp}"
    local conf_file="$INSTANCES_DIR/$ins_name.conf" tmp_conf="" svc_unit="" gre_key=""
    local paqet_yaml="$PAQET_CONFIG_DIR/${ins_name}.yaml" vxlan_vni="" vxlan_port="" hy_yaml=""
    local wg_priv="" wg_pub="" wg_peer="" hy_sni="${DEFAULT_HY2_SNI}"

    apply_global_sysctl || return 1

    if [[ "$tunnel_mode" == "gre" ]]; then
        gre_key=$(compute_gre_key "$loc_ip" "$rem_ip")
    elif [[ "$tunnel_mode" == "vxlan" ]]; then
        vxlan_vni=$(compute_vxlan_vni "$loc_ip" "$rem_ip")
        vxlan_port="${tcp_port:-$DEFAULT_VXLAN_PORT}"
    fi

    if [[ "$tunnel_mode" == "tun_tcp" ]]; then
        install_tun_tcp_binaries || return 1
        create_tuntcp_runner_script || return 1
        create_tuntcp_service || return 1
        svc_unit="jojonet-tcptun@${ins_name}.service"
    elif [[ "$tunnel_mode" == "paqet" ]]; then
        install_paqet_binary || return 1
        create_paqet_runner_script || return 1
        create_paqet_service || return 1
        build_paqet_runtime_config "$ins_name" "$role_conf" "$rem_ip" "$tcp_port" "$key_dir" \
            "$fwd_port" "${forward_proto:-tcp}" || return 1
        svc_unit="jojonet-paqet@${ins_name}.service"
    elif [[ "$tunnel_mode" == "vxlan" ]]; then
        create_vxlan_runner_script || return 1
        create_vxlan_service || return 1
        svc_unit="jojonet-vxlan@${ins_name}.service"
    elif [[ "$tunnel_mode" == "wireguard" ]]; then
        install_wireguard_tools || return 1
        create_wg_runner_script || return 1
        create_wg_service || return 1
        svc_unit="jojonet-wg@${ins_name}.service"
    elif [[ "$tunnel_mode" == "hysteria2" ]]; then
        install_hysteria2_binary || return 1
        create_hy2_runner_script || return 1
        create_hy2_service || return 1
        hy_sni="${HySni:-${JOJONET_HY2_SNI:-$DEFAULT_HY2_SNI}}"
        hy_yaml=$(build_hy2_runtime_config "$ins_name" "$role_conf" "$rem_ip" "$tcp_port" "$key_dir" \
            "$fwd_port" "$hy_sni") || return 1
        svc_unit="jojonet-hy2@${ins_name}.service"
    else
        create_template_script || return 1
        create_template_service || return 1
        svc_unit="jojonet@${ins_name}.service"
    fi

    if [[ "$tunnel_mode" == "wireguard" && -n "$key_dir" ]]; then
        wg_priv="$key_dir/wg_private.key"
        wg_pub="$key_dir/wg_public.key"
        wg_peer="$key_dir/wg_peer_public.key"
    fi
    if [[ "$tunnel_mode" == "hysteria2" ]]; then
        paqet_yaml=""
        [[ -n "${hy_yaml:-}" ]] || hy_yaml="$HY2_CONFIG_DIR/${ins_name}.yaml"
    fi

    tmp_conf="${conf_file}.tmp"
    cat > "$tmp_conf" <<EOF
Name="$ins_name"
TunnelMode="$tunnel_mode"
Role="$role_conf"
Local_IP="$loc_ip"
Remote_IP="$rem_ip"
Subnet_Byte="$subnet_byte"
Tun_IP="$tun_ip"
Tun_Remote_IP_Raw="$tun_remote"
Tun_Server_IP="$tun_server_ip"
Tun_Client_IP="$tun_client_ip"
Suggested_MTU="$ins_mtu"
Ports="$fwd_port"
TcpPort="$tcp_port"
KeyDir="$key_dir"
GreKey="$gre_key"
PaqetYaml="$paqet_yaml"
ForwardProto="$forward_proto"
VxlanVni="$vxlan_vni"
VxlanPort="$vxlan_port"
WgPrivateKey="$wg_priv"
WgPublicKey="$wg_pub"
WgPeerPublicKey="$wg_peer"
HyYaml="$hy_yaml"
HyAuth=""
HySni="$hy_sni"
EOF

    chmod 600 "$tmp_conf" || { rm -f "$tmp_conf"; return 1; }
    mv -f "$tmp_conf" "$conf_file" || { rm -f "$tmp_conf"; return 1; }

    echo -e "${YELLOW}[*] Enabling systemd service...${NC}"
    if ! systemctl enable "$svc_unit" >/dev/null 2>&1; then
        rollback_new_tunnel "$ins_name" "$conf_file"
        return 1
    fi

    echo -e "${YELLOW}[*] Starting tunnel ($tunnel_mode)...${NC}"
    if ! systemctl start "$svc_unit" >/dev/null 2>&1; then
        echo -e "${RED}[!] Start failed. Logs:${NC}"
        journalctl -u "$svc_unit" -b --no-pager | tail -n 20 || true
        rollback_new_tunnel "$ins_name" "$conf_file"
        return 1
    fi

    if ! wait_for_tunnel_up "$ins_name" "$tunnel_mode" 90; then
        echo -e "${RED}[!] Tunnel interface did not come up in time.${NC}"
        journalctl -u "$svc_unit" -b --no-pager | tail -n 25 || true
        rollback_new_tunnel "$ins_name" "$conf_file"
        return 1
    fi

    if systemctl is-active --quiet "$svc_unit"; then
        local iface_ok=0
        if [[ "$tunnel_mode" == "tun_tcp" || "$tunnel_mode" == "wireguard" ]]; then
            ip link show "$ins_name" >/dev/null 2>&1 && iface_ok=1
        elif [[ "$tunnel_mode" == "paqet" ]]; then
            pgrep -f "paqet run -c.*/${ins_name}\\.yaml" >/dev/null 2>&1 && iface_ok=1
        elif [[ "$tunnel_mode" == "hysteria2" ]]; then
            pgrep -f "hysteria.*(server|client).*${ins_name}" >/dev/null 2>&1 && iface_ok=1
            pgrep -f "hysteria.*${ins_name}\\.yaml" >/dev/null 2>&1 && iface_ok=1
            # Type=simple: if unit active and yaml exists, accept
            [[ -f "${hy_yaml:-}" ]] && systemctl is-active --quiet "$svc_unit" && iface_ok=1
        elif ip link show "$ins_name" 2>/dev/null | grep -qE 'state UP|UP,'; then
            iface_ok=1
        fi
        if (( iface_ok == 1 )); then
            echo -e "${GREEN}[+] Tunnel [$ins_name] ($tunnel_mode) is ACTIVE!${NC}"
            if [[ "$tunnel_mode" == "paqet" ]]; then
                echo -e "  Listen/peer port: $tcp_port  |  Config: $paqet_yaml"
            elif [[ "$tunnel_mode" == "hysteria2" ]]; then
                echo -e "  UDP port: $tcp_port  |  Config: ${hy_yaml:-n/a}"
            elif [[ "$tunnel_mode" == "wireguard" ]]; then
                echo -e "  UDP port: $tcp_port  |  Interface: $ins_name  |  IP: $tun_ip"
            elif [[ "$tunnel_mode" == "vxlan" ]]; then
                echo -e "  VNI: $vxlan_vni  |  UDP: $vxlan_port  |  Interface: $ins_name"
            else
                echo -e "  GreKey: ${gre_key:-n/a}  |  Interface: $ins_name"
            fi
            if systemctl is-enabled --quiet "$svc_unit" 2>/dev/null; then
                hint "Enabled on boot."
            fi
            create_boot_restore_service || true
            systemctl enable jojonet-boot.service >/dev/null 2>&1 || true
            local ping_target=""
            if [[ "$tunnel_mode" == "gre" || "$tunnel_mode" == "vxlan" || "$tunnel_mode" == "wireguard" ]]; then
                if [[ "$role_conf" == "iran" ]]; then
                    ping_target="${tun_remote:-$tun_client_ip}"
                else
                    ping_target="${tun_server_ip:-}"
                fi
            elif [[ "$tunnel_mode" == "tun_tcp" ]]; then
                if [[ "$role_conf" == "iran" ]]; then
                    ping_target="${tun_server_ip:-}"
                else
                    ping_target="${tun_client_ip:-}"
                fi
            fi
            verify_tunnel_ping "$ping_target" || true
            return 0
        fi
        echo -e "${RED}[!] Service active but runtime check failed.${NC}"
    else
        echo -e "${RED}[!] Service not active.${NC}"
    fi

    journalctl -u "$svc_unit" -b --no-pager | tail -n 20 || true
    rollback_new_tunnel "$ins_name" "$conf_file"
    return 1
}

quick_add_tunnel() {
    local peer_ip="${1:-}"
    local ins_name="" role_conf="" loc_ip="" rem_ip="" subnet_byte=""
    local tun_ip="" tun_remote="" ins_mtu="$DEFAULT_MTU_FALLBACK" fwd_port="" gre_key=""
    local existing="" tunnel_count=0 rc=0

    set +e

    command -v clear >/dev/null && clear
    logo
    print_banner "Quick GRE Setup"

    if ! auto_detect_network; then
        echo -e "${RED}[!] Cannot detect network.${NC}"
        sleep 2
        return 1
    fi

    loc_ip="$DETECTED_IP"
    tunnel_count=$(count_configured_tunnels)
    echo -e "\n${GREEN}Your IP:${NC} ${CYAN}$loc_ip${NC}  ${YELLOW}(${tunnel_count} tunnel(s))${NC}"
    if any_gre_present && (( tunnel_count == 0 )); then
        echo -e "${YELLOW}[!] Existing GRE interface(s) found (outside JojoNet).${NC}"
        echo -e "${YELLOW}    New tunnel will use a unique interface name.${NC}"
        ip -o link show type gre 2>/dev/null | awk '{print "    - " $2}' | sed 's/:$//' || true
    fi
    show_existing_tunnels_summary

    if [[ -z "$peer_ip" ]]; then
        read -r -p "Peer server IP (other side): " peer_ip
    fi
    peer_ip="${peer_ip// /}"

    if [[ -z "$peer_ip" ]] || ! validate_ipv4 "$peer_ip"; then
        echo -e "${RED}[!] Invalid peer IP.${NC}"
        sleep 2
        return 1
    fi

    if [[ "$peer_ip" == "$loc_ip" ]]; then
        echo -e "${RED}[!] Peer IP cannot be the same as local IP.${NC}"
        sleep 2
        return 1
    fi

    rem_ip="$peer_ip"

    if existing=$(find_tunnel_for_peer "$rem_ip"); then
        echo -e "${YELLOW}[!] Tunnel to $rem_ip already exists as [$existing]. Restarting...${NC}"
        restart_tunnel "$existing"
        sleep 2
        return $?
    fi

    if role_conf=$(resolve_server_role "$loc_ip"); then
        echo -e "${GREEN}[*] Role:${NC} $role_conf  ${YELLOW}(override: JOJONET_ROLE / --role)${NC}"
    else
        echo -e "${RED}[!] Role detection failed. Set JOJONET_ROLE=iran|kharej${NC}"
        sleep 2
        return 1
    fi

    ins_name=$(allocate_tunnel_name "$rem_ip" "$role_conf" "gre") || {
        echo -e "${RED}[!] Could not allocate unique interface name.${NC}"
        sleep 3
        return 1
    }

    if [[ "$role_conf" == "iran" ]]; then
        fwd_port="443"
    else
        fwd_port=""
    fi

    if [[ "${JOJONET_QUICK_PROBE_MTU:-0}" == "1" ]]; then
        ins_mtu=$(calculate_mtu "$rem_ip")
        ins_mtu=$(clamp_mtu "$ins_mtu")
    else
        ins_mtu=$DEFAULT_MTU_FALLBACK
    fi

    gre_key=$(compute_gre_key "$loc_ip" "$rem_ip")
    subnet_byte=$(compute_pair_subnet_byte "$loc_ip" "$rem_ip")

    if subnet_byte_in_use "$subnet_byte"; then
        local other_peer=""
        other_peer=$(awk -F'"' -v b="$subnet_byte" '
            $0 ~ /Subnet_Byte/ && $2 == b { in_b=1 }
            in_b && $0 ~ /Remote_IP/ { print $2; exit }
        ' "$INSTANCES_DIR"/*.conf 2>/dev/null || true)
        if [[ -n "$other_peer" && "$other_peer" != "$rem_ip" ]]; then
            echo -e "${RED}[!] Subnet collision with another tunnel (peer: $other_peer).${NC}"
            sleep 3
            return 1
        fi
    fi

    resolve_tunnel_ips "$role_conf" "$subnet_byte" "gre"
    tun_ip="$Tun_IP"
    tun_remote="$Tun_Remote_IP_Raw"

    echo -e "\n${CYAN}--- New isolated GRE tunnel ---${NC}"
    echo -e "  Interface:     ${GREEN}$ins_name${NC}  ${YELLOW}(unique)${NC}"
    echo -e "  Role:          $role_conf"
    echo -e "  Local IP:      $loc_ip"
    echo -e "  Peer IP:       $rem_ip"
    echo -e "  Tunnel subnet: ${TUNNEL_NET_PREFIX}.$subnet_byte.0/30"
    echo -e "  Tunnel IP:     $tun_ip"
    echo -e "  GRE key:       $gre_key"
    echo -e "  MTU:           $ins_mtu"
    [[ -n "$fwd_port" ]] && echo -e "  Forward ports: $fwd_port"
    hint "Run same on peer: sudo jojonet $loc_ip"
    echo ""

    show_tunnel_plan "$ins_name" "$role_conf" "$loc_ip" "$rem_ip" "$tun_ip" "$tun_remote" "$ins_mtu" "$fwd_port" "$gre_key"

    echo -e "${YELLOW}[*] Applying automatically...${NC}"
    if deploy_tunnel "$ins_name" "$role_conf" "$loc_ip" "$rem_ip" "$subnet_byte" \
        "$tun_ip" "$tun_remote" "$ins_mtu" "$fwd_port" "gre" "$DEFAULT_TCP_PORT" "" \
        "$Tun_Server_IP" "$Tun_Client_IP"; then
        echo -e "${GREEN}[+] Multi-tunnel OK. Total tunnels: $(count_configured_tunnels)${NC}"
        sleep 2
        set -e
        return 0
    fi
    sleep 3
    set -e
    return 1
}

