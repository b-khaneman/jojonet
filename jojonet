parse_gre_remote_local() {
    local ifname="$1"
    ip -d link show "$ifname" 2>/dev/null | sed -n 's/.*remote \([0-9.]*\).*local \([0-9.]*\).*/\1 \2/p' | head -1
}

import_manual_gretun() {
    local ifname="${1:-GRETun}" rl="" rem="" loc="" addr="" role="" subnet_byte=""
    set +e
    if ! ip link show "$ifname" >/dev/null 2>&1; then
        echo -e "${RED}[!] Interface $ifname not found.${NC}"
        ip -o link show type gre 2>/dev/null | awk '{print "  - " $2}' | sed 's/:$//' || true
        sleep 2
        set -e
        return 1
    fi
    rl=$(parse_gre_remote_local "$ifname")
    rem=$(echo "$rl" | awk '{print $1}')
    loc=$(echo "$rl" | awk '{print $2}')
    addr=$(ip -o -4 addr show dev "$ifname" 2>/dev/null | awk '{print $4}' | head -1)
    [[ -n "$rem" && -n "$loc" && -n "$addr" ]] || {
        echo -e "${RED}[!] Cannot parse $ifname (remote/local/IP).${NC}"
        sleep 2
        set -e
        return 1
    }
    if [[ "$addr" == *".1/"* ]]; then role="kharej"
    elif [[ "$addr" == *".2/"* ]]; then role="iran"
    else
        read -r -p "Role [1=Iran 2=Kharej]: " _r
        [[ "$_r" == "2" ]] && role="kharej" || role="iran"
    fi
    subnet_byte=$(echo "$addr" | awk -F'[./]' '{print $3}')
    echo -e "${CYAN}Import plan:${NC}"
    echo -e "  Iface: $ifname  Role: $role  Local: $loc  Remote: $rem"
    echo -e "  Overlay: $addr  Subnet: $subnet_byte"
    read -r -p "Import into JojoNet (stop $ifname, recreate as managed)? [y/N]: " _c
    _c=$(echo "$_c" | tr '[:upper:]' '[:lower:]')
    [[ "$_c" == "y" ]] || { set -e; return 0; }

    ip link delete "$ifname" 2>/dev/null || true
    resolve_tunnel_ips "$role" "$subnet_byte" "gre"
    local fwd="" ins_name="$ifname"
    validate_interface_name "$ins_name" || ins_name=$(allocate_tunnel_name "$rem" "$role" "gre" "$subnet_byte")
    [[ "$role" == "iran" ]] && fwd=$(allocate_iran_forward_port "443")

    if deploy_tunnel "$ins_name" "$role" "$loc" "$rem" "$subnet_byte" \
        "$Tun_IP" "$Tun_Remote_IP_Raw" "$DEFAULT_GRE_MTU" "$fwd" "gre" \
        "$DEFAULT_TCP_PORT" "" "$Tun_Server_IP" "$Tun_Client_IP"; then
        echo -e "${GREEN}[+] Imported $ifname → JojoNet [$ins_name]${NC}"
        show_pairing_card "$role" "$loc" "$rem" "$subnet_byte" "$ins_name" "gre" "$fwd"
    fi
    sleep 2
    set -e
}

