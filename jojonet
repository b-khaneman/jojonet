    local existing="" tunnel_count=0

    set +e
    command -v clear >/dev/null && clear
    logo
    print_banner "Paqet Tunnel (Raw/KCP)"

    install_paqet_binary || { sleep 2; set -e; return 1; }

    if ! command -v iptables >/dev/null 2>&1; then
        echo -e "${YELLOW}[!] iptables recommended for Paqet (apt install iptables).${NC}"
    fi

    if ! auto_detect_network; then
        sleep 2
        set -e
        return 1
    fi

    loc_ip="$DETECTED_IP"
    tunnel_count=$(count_configured_tunnels)
    echo -e "\n${GREEN}Your IP:${NC} ${CYAN}$loc_ip${NC}  ${YELLOW}(${tunnel_count} tunnel(s))${NC}"
    hint "Step 1: Foreign (server)  |  Step 2: Iran (client + port forward)"
    show_existing_tunnels_summary

    [[ -z "$peer_ip" ]] && read -r -p "Peer server IP: " peer_ip
    peer_ip="${peer_ip// /}"
    if [[ -z "$peer_ip" ]] || ! validate_ipv4 "$peer_ip"; then
        sleep 2
        set -e
        return 1
    fi
    [[ "$peer_ip" == "$loc_ip" ]] && { echo -e "${RED}[!] Same IP.${NC}"; sleep 2; set -e; return 1; }
    rem_ip="$peer_ip"

    if existing=$(find_tunnel_for_peer "$rem_ip"); then
        local ex_mode
        ex_mode=$(tunnel_mode_from_name "$existing")
        if [[ "$ex_mode" == "paqet" ]]; then
            restart_tunnel "$existing"
            sleep 2
            set -e
            return $?
        fi
        echo -e "${YELLOW}[!] Non-Paqet tunnel exists for $rem_ip [$existing]. Use Manage to delete first.${NC}"
        sleep 3
        set -e
        return 1
    fi

    if role_conf=$(resolve_server_role "$loc_ip"); then
        echo -e "${GREEN}[*] Role:${NC} $role_conf  ${YELLOW}(override: JOJONET_ROLE / --role)${NC}"
    else
        echo -e "${RED}[!] Role detection failed. Set JOJONET_ROLE=iran|kharej${NC}"
        sleep 2
        set -e
        return 1
    fi

    ins_name=$(allocate_tunnel_name "$rem_ip" "$role_conf" "paqet") || { set -e; return 1; }

    if [[ "$role_conf" == "kharej" ]]; then
        read -r -p "Listen port [$tcp_port]: " _tp
        tcp_port=${_tp:-$tcp_port}
        fwd_port=""
    else
        fwd_port="443"
        read -r -p "Forward ports on Iran [$fwd_port]: " _fp
        fwd_port=${_fp:-$fwd_port}
        fwd_port=$(normalize_port_list "$fwd_port")
        read -r -p "Server port on foreign [$tcp_port]: " _tp
        tcp_port=${_tp:-$tcp_port}
        echo -e "${CYAN}Forward protocol:${NC} 1=tcp  2=udp  3=tcp+udp (default 3)"
        read -r -p "Protocol [1-3]: " _proto
        case "${_proto:-3}" in
            1) forward_proto="tcp" ;;
            2) forward_proto="udp" ;;
            *) forward_proto="both" ;;
        esac
    fi

    if ! [[ "$tcp_port" =~ ^[0-9]+$ ]] || (( tcp_port < 1 || tcp_port > 65535 )); then
        echo -e "${RED}[!] Invalid port.${NC}"
        sleep 2
        set -e
        return 1
    fi

    if [[ "$role_conf" == "iran" && -n "$fwd_port" ]]; then
        local _p
        IFS=',' read -ra _ports <<< "$fwd_port"
        for _p in "${_ports[@]}"; do
            _p="${_p// /}"
            if [[ "$_p" == "$tcp_port" ]]; then
                echo -e "${RED}[!] Forward port cannot match Paqet server port ($tcp_port).${NC}"
                sleep 3
                set -e
                return 1
            fi
        done
    fi

    subnet_byte=$(compute_pair_subnet_byte "$loc_ip" "$rem_ip")
    key_dir=$(ensure_paqet_secret "$subnet_byte" "$rem_ip") || {
        echo -e "${RED}[!] Secret setup failed (need openssl).${NC}"
        sleep 2
        set -e
        return 1
    }
    show_paqet_secret_hint "$subnet_byte" "$key_dir" "$rem_ip"

    echo -e "\n${CYAN}--- Paqet plan ---${NC}"
    echo -e "  Mode:      paqet (Raw socket + KCP)"
    echo -e "  Instance:  $ins_name"
    echo -e "  Role:      $role_conf ($([[ "$role_conf" == "kharej" ]] && echo server || echo client))"
    echo -e "  Port:      $tcp_port"
    echo -e "  KCP:       $DEFAULT_PAQET_KCP_MODE | $DEFAULT_PAQET_ENCRYPTION | MTU $DEFAULT_PAQET_MTU"
    [[ -n "$fwd_port" ]] && echo -e "  Forward:   $fwd_port ($forward_proto)"
    echo -e "  Secret:    $key_dir/paqet.secret"
    [[ "$role_conf" == "kharej" ]] && hint "Now run on Iran: sudo jojonet --paqet $loc_ip"

    echo -e "${YELLOW}[*] Applying Paqet tunnel...${NC}"
    if deploy_tunnel "$ins_name" "$role_conf" "$loc_ip" "$rem_ip" "$subnet_byte" \
        "" "" "$DEFAULT_PAQET_MTU" "$fwd_port" "paqet" "$tcp_port" "$key_dir" \
        "" "" "$forward_proto"; then
        echo -e "${GREEN}[+] Paqet tunnel [$ins_name] is up.${NC}"
        [[ "$role_conf" == "kharej" ]] && hint "Run on Iran: sudo jojonet --paqet $loc_ip"
        sleep 2
        set -e
        return 0
    fi
    sleep 3
    set -e
    return 1
}

