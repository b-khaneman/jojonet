    trap - ERR
    if [[ "${Role:-}" == "iran" && -n "${Tun_Remote_IP_Raw:-}" ]]; then
        local p _ports="${Ports:-443}"
        IFS=',' read -ra _PL <<< "$_ports"
        for p in "${_PL[@]}"; do
