# Human-readable tunnel mode label
tunnel_mode_label() {
    case "${1:-gre}" in
        gre)           printf '%s' "GRE" ;;
        tun_tcp)       printf '%s' "TUN/TCP" ;;
        paqet)         printf '%s' "Paqet" ;;
        vxlan)         printf '%s' "VXLAN" ;;
        wireguard|wg)  printf '%s' "WireGuard" ;;
        hysteria2|hy2) printf '%s' "Hysteria2" ;;
        rathole|rh)    printf '%s' "Rathole Reverse" ;;
        *)             printf '%s' "${1:-?}" ;;
    esac
}

# UP / DOWN / FAIL for a tunnel instance name
tunnel_status_word() {
    local name="$1" svc=""
    svc=$(tunnel_service_unit "$name")
    if systemctl is-active --quiet "$svc" 2>/dev/null; then
        printf '%s' "UP"
    elif systemctl is-failed --quiet "$svc" 2>/dev/null; then
        printf '%s' "FAIL"
    else
        printf '%s' "DOWN"
    fi
}

tunnel_status_colored() {
    local name="$1" st
    st=$(tunnel_status_word "$name")
    case "$st" in
        UP)   echo -e "${GREEN}${st}${NC}" ;;
        FAIL) echo -e "${RED}${st}${NC}" ;;
        *)    echo -e "${YELLOW}${st}${NC}" ;;
    esac
}

tunnel_role_label() {
    case "${1:-}" in
        iran)   printf '%s' "Iran" ;;
        kharej) printf '%s' "Kharej" ;;
        *)      printf '%s' "${1:-?}" ;;
    esac
}

# Resolve public IPs by country (independent of which server you are on)
resolve_iran_foreign_ips() {
    if [[ "${Role:-}" == "iran" ]]; then
        TUNNEL_IRAN_IP="${Local_IP:-?}"
        TUNNEL_KHAREJ_IP="${Remote_IP:-?}"
    else
        TUNNEL_IRAN_IP="${Remote_IP:-?}"
        TUNNEL_KHAREJ_IP="${Local_IP:-?}"
    fi
}

# Colored country tag for display
tunnel_country_tag() {
    case "${1:-}" in
        iran|Iran|ایران)
            echo -e "${GREEN}[Iran/ایران]${NC}"
            ;;
        kharej|Kharej|خارج)
            echo -e "${MAGENTA}[Kharej/خارج]${NC}"
            ;;
        *)
            echo -e "${YELLOW}[?]${NC}"
            ;;
    esac
}

# Overlay tunnel IPs labeled by country
tunnel_overlay_iran_foreign() {
    local iran_tun="" kharej_tun=""
    case "${Role:-}" in
        iran)
            iran_tun=$(echo "${Tun_IP:-}" | awk -F'/' '{print $1}')
            kharej_tun="${Tun_Remote_IP_Raw:-${Tun_Server_IP:-?}}"
            ;;
        kharej)
            kharej_tun=$(echo "${Tun_IP:-}" | awk -F'/' '{print $1}')
            iran_tun="${Tun_Client_IP:-?}"
            ;;
    esac
    if [[ -n "$iran_tun" && -n "$kharej_tun" ]]; then
        printf 'overlay %s (Iran/ایران) ↔ %s (Kharej/خارج)' "$iran_tun" "$kharej_tun"
    fi
}
# Overlay / port summary for a loaded instance config
tunnel_endpoint_summary() {
    local mode="${TunnelMode:-gre}" extra="" overlay=""
    case "$mode" in
        gre|vxlan|wireguard|tun_tcp)
            overlay=$(tunnel_overlay_iran_foreign)
            [[ -n "$overlay" ]] && extra="$overlay"
            ;;
        paqet)
            extra="KCP port ${TcpPort:-?}"
            [[ -n "${Ports:-}" ]] && extra="${extra} | forward ${Ports}"
            ;;
        hysteria2)
            extra="UDP ${TcpPort:-?}"
            [[ -n "${Ports:-}" ]] && extra="${extra} | forward ${Ports}"
            ;;
    esac
    case "$mode" in
        vxlan)
            [[ -n "${VxlanVni:-}" ]] && extra="${extra:+$extra | }VNI ${VxlanVni}"
            [[ -n "${VxlanPort:-}" ]] && extra="${extra:+$extra | }UDP ${VxlanPort}"
            ;;
        wireguard)
            [[ -n "${TcpPort:-}" ]] && extra="${extra:+$extra | }WG UDP ${TcpPort}"
            ;;
    esac
    printf '%s' "$extra"
}

# One-line description with explicit Iran / Kharej labels on both public IPs
format_tunnel_map_line() {
    local mode_l st st_c extra fwd="" iran_ip kharej_ip
    mode_l=$(tunnel_mode_label "${TunnelMode:-gre}")
    resolve_iran_foreign_ips
    iran_ip="$TUNNEL_IRAN_IP"
    kharej_ip="$TUNNEL_KHAREJ_IP"
    st=$(tunnel_status_word "$Name")
    case "$st" in
        UP)   st_c="${GREEN}${st}${NC}" ;;
        FAIL) st_c="${RED}${st}${NC}" ;;
        *)    st_c="${YELLOW}${st}${NC}" ;;
    esac
    extra=$(tunnel_endpoint_summary)
    [[ -n "${Ports:-}" && "${TunnelMode:-gre}" != "paqet" && "${TunnelMode:-gre}" != "hysteria2" ]] && \
        fwd=" | forward ${Ports}" || true
    echo -e "  ${st_c}  $(tunnel_country_tag iran) ${CYAN}${iran_ip}${NC}  ──${YELLOW}[${mode_l}]${NC}──►  $(tunnel_country_tag kharej) ${CYAN}${kharej_ip}${NC}"
    [[ -n "$extra$fwd" ]] && echo -e "         ${extra}${fwd}" || true
}

# Print all configured tunnels (detail: 0=compact header+lines, 1=full cards)
list_all_tunnels() {
    local detail="${1:-0}"
    shopt -s nullglob
    local files=("$INSTANCES_DIR"/*.conf)
    shopt -u nullglob

    if (( ${#files[@]} == 0 )); then
        echo -e "${YELLOW}[!] No tunnels configured.${NC}"
        return 1
    fi

    echo -e "\n${CYAN}=== Tunnel Map (${#files[@]} configured) ===${NC}"
    local file idx=0 total_up=0
    local Name="" TunnelMode="" Role="" Local_IP="" Remote_IP="" Subnet_Byte=""
    local Tun_IP="" Tun_Remote_IP_Raw="" Tun_Server_IP="" Tun_Client_IP=""
    local Suggested_MTU="" Ports="" TcpPort="" KeyDir="" GreKey=""
    local PaqetYaml="" ForwardProto="" VxlanVni="" VxlanPort=""
    local WgPrivateKey="" WgPublicKey="" WgPeerPublicKey="" HyYaml="" HyAuth="" HySni="" HyHopRange="" HyHopInterval="" RatholeToml=""

    for file in "${files[@]}"; do
        idx=$((idx + 1))
        if ! load_instance_config "$file"; then
            echo -e "  ${RED}[!] Invalid config: $(basename "$file")${NC}"
            continue
        fi
        [[ "$(tunnel_status_word "$Name")" == "UP" ]] && total_up=$((total_up + 1)) || true

        if (( detail == 0 )); then
            echo -e "${BLUE}#${idx} ${Name}${NC}"
            format_tunnel_map_line
        else
            show_tunnel_detail_card "$idx"
        fi
        echo ""
    done

    echo -e "${CYAN}Summary:${NC} ${GREEN}${total_up}${NC}/${#files[@]} active"
    return 0
}

