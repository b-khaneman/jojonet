# Fix overlay IPs in saved configs (e.g. after v1.2.2 Iran/Kharej .1/.2 swap)
repair_tunnel_overlay_ips() {
    local conf="$1" name role subnet mode old_tun
    [[ -f "$conf" ]] || return 1
    mode=$(conf_get_field "$conf" "TunnelMode")
    mode=${mode:-gre}
    [[ "$mode" =~ ^(gre|vxlan|wireguard)$ ]] || return 1
    name=$(conf_get_field "$conf" "Name")
    role=$(conf_get_field "$conf" "Role")
    subnet=$(conf_get_field "$conf" "Subnet_Byte")
    if [[ "$mode" == "gre" ]]; then
        loc=$(conf_get_field "$conf" "Local_IP")
        rem=$(conf_get_field "$conf" "Remote_IP")
        [[ -z "$subnet" && -n "$loc" && -n "$rem" ]] && subnet=$(gre_subnet_for_pair "$loc" "$rem")
    fi
    [[ -n "$name" && -n "$role" && -n "$subnet" ]] || return 1
    old_tun=$(conf_get_field "$conf" "Tun_IP")
    resolve_tunnel_ips "$role" "$subnet" "$mode"
    [[ "$old_tun" == "$Tun_IP" ]] && return 1
    grep -q '^Tun_IP=' "$conf" && sed -i "s/^Tun_IP=.*/Tun_IP=\"$Tun_IP\"/" "$conf"
    grep -q '^Tun_Server_IP=' "$conf" && sed -i "s/^Tun_Server_IP=.*/Tun_Server_IP=\"$Tun_Server_IP\"/" "$conf"
    grep -q '^Tun_Client_IP=' "$conf" && sed -i "s/^Tun_Client_IP=.*/Tun_Client_IP=\"$Tun_Client_IP\"/" "$conf"
    if [[ "$role" == "iran" ]]; then
        grep -q '^Tun_Remote_IP_Raw=' "$conf" && \
            sed -i "s/^Tun_Remote_IP_Raw=.*/Tun_Remote_IP_Raw=\"$Tun_Remote_IP_Raw\"/" "$conf"
    fi
    if [[ "$mode" == "gre" ]]; then
        grep -q '^GreKey=' "$conf" && sed -i 's/^GreKey=.*/GreKey=""/' "$conf"
    fi
    echo -e "${YELLOW}[*] Repaired overlay IPs [$name]: $old_tun -> $Tun_IP${NC}" >&2
    return 0
}
clamp_mtu() {
    local mtu="$1"
    if ! [[ "$mtu" =~ ^[0-9]+$ ]]; then
        echo "$DEFAULT_MTU_FALLBACK"
        return
    fi
    (( mtu < 576 )) && mtu=$DEFAULT_MTU_FALLBACK
    (( mtu > 9000 )) && mtu=$DEFAULT_MTU_FALLBACK
    echo "$mtu"
}

ipv4_to_uint() {
    local ip="${1:-0.0.0.0}" a=0 b=0 c=0 d=0
    IFS='.' read -r a b c d <<< "$ip"
    a=${a:-0}; b=${b:-0}; c=${c:-0}; d=${d:-0}
    echo $(( (a << 24) + (b << 16) + (c << 8) + d ))
}

# True if another WireGuard iface already listens on this UDP port
wg_udp_port_in_use() {
    local port="$1" exclude="${2:-}" iface lp=""
    command -v wg >/dev/null 2>&1 || return 1
    for iface in $(wg show interfaces 2>/dev/null); do
        [[ "$iface" == "$exclude" ]] && continue
        lp=$(wg show "$iface" listen-port 2>/dev/null || true)
        [[ -n "$lp" && "$lp" == "$port" ]] && return 0
    done
    return 1
}

# Return iface name if overlay IP is already assigned elsewhere
overlay_ip_on_iface() {
    local want="${1%%/*}" got=""
    got=$(ip -o -4 addr show 2>/dev/null | awk -v ip="$want" '
        $4 ~ "^" ip "(/|$)" { print $2; exit }')
    [[ -n "$got" ]] && printf '%s' "$got"
}

# Deterministic GRE subnet id (10-250) for a public IP pair — same value on both servers
gre_subnet_for_pair() {
    local ip1="$1" ip2="$2" b
    b=$(compute_pair_subnet_byte "$ip1" "$ip2")
    (( b < GRE_SUBNET_MIN )) && b=$(( b + GRE_SUBNET_MIN - 1 ))
    (( b > GRE_SUBNET_MAX )) && b=$(( (b % (GRE_SUBNET_MAX - GRE_SUBNET_MIN + 1)) + GRE_SUBNET_MIN ))
    echo "$b"
}

# Another GRE tunnel on THIS server already uses this subnet for a different peer
gre_subnet_taken_locally() {
    local byte="$1" rem="$2" f r mode
    shopt -s nullglob
    local files=("$INSTANCES_DIR"/*.conf)
    shopt -u nullglob
    for f in "${files[@]}"; do
        mode=$(conf_get_field "$f" "TunnelMode")
        [[ "${mode:-gre}" == "gre" ]] || continue
        [[ "$(conf_get_field "$f" "Subnet_Byte")" == "$byte" ]] || continue
        r=$(conf_get_field "$f" "Remote_IP")
        [[ "$r" == "$rem" ]] && continue
        return 0
    done
    return 1
}

# Pick GRE subnet: reuse saved config for same peer, else deterministic pair hash (both servers match)
allocate_gre_subnet_byte() {
    local loc="$1" rem="$2" existing="" saved="" candidate=""
    if existing=$(find_tunnel_for_peer "$rem" "gre"); then
        saved=$(conf_get_field "$INSTANCES_DIR/$existing.conf" "Subnet_Byte")
        [[ -n "$saved" ]] && { echo "$saved"; return 0; }
    fi
    candidate=$(gre_subnet_for_pair "$loc" "$rem")
    if gre_subnet_taken_locally "$candidate" "$rem"; then
        return 1
    fi
    echo "$candidate"
}

overlay_ip_in_use_for_role() {
    local role="$1" subnet_byte="$2" ip=""
    if [[ "$role" == "iran" ]]; then
        ip="${TUNNEL_NET_PREFIX}.${subnet_byte}.2"
    else
        ip="${TUNNEL_NET_PREFIX}.${subnet_byte}.1"
    fi
    overlay_ip_on_iface "$ip"
}

# Same subnet on both servers — derived from the IP pair (no manual Subnet ID)
compute_pair_subnet_byte() {
    local ip1="$1" ip2="$2" u1 u2 key h
    u1=$(ipv4_to_uint "$ip1")
    u2=$(ipv4_to_uint "$ip2")
    if (( u1 < u2 )); then
        key="${ip1}|${ip2}"
    else
        key="${ip2}|${ip1}"
    fi
    if command -v cksum >/dev/null 2>&1; then
        h=$(printf '%s' "$key" | cksum | awk '{print $1}')
    elif command -v md5sum >/dev/null 2>&1; then
        h=$(( 16#$(printf '%s' "$key" | md5sum | awk '{print $1}' | cut -c1-7) ))
    else
        h=$(( u1 ^ u2 ))
    fi
    echo $(( (h % 250) + 1 ))
}

# Unique GRE key per IP pair (required for multiple GRE tunnels on one server)
compute_gre_key() {
    local ip1="$1" ip2="$2" u1 u2 pair h
    u1=$(ipv4_to_uint "$ip1")
    u2=$(ipv4_to_uint "$ip2")
    if (( u1 < u2 )); then
        pair="${ip1}|${ip2}"
    else
        pair="${ip2}|${ip1}"
    fi
    if command -v cksum >/dev/null 2>&1; then
        h=$(printf '%s' "$pair" | cksum | awk '{print $1}')
    elif command -v md5sum >/dev/null 2>&1; then
        h=$(( 16#$(printf '%s' "$pair" | md5sum | awk '{print $1}' | cut -c1-7) ))
    else
        h=$(( u1 ^ u2 ))
    fi
    h=$(( (h % 2147483646) + 1 ))
    echo "$h"
}

# Unique VXLAN VNI per IP pair (1..16777215)
compute_vxlan_vni() {
    local vni
    vni=$(compute_gre_key "$1" "$2")
    (( vni > 16777215 )) && vni=$(( vni % 16777214 + 1 ))
    echo "$vni"
}

detect_server_role() {
    local ip="$1" cc="" raw="" url
    if command -v curl >/dev/null 2>&1; then
        for url in \
            "https://ip-api.com/json/${ip}?fields=countryCode" \
            "https://ipapi.co/${ip}/country_code/" \
            "https://ifconfig.co/country-iso?ip=${ip}"
        do
            raw=$(curl -fsSL --max-time 8 "$url" 2>/dev/null || true)
            cc=$(grep -oE '"countryCode":"[A-Z]{2}"' <<< "$raw" 2>/dev/null | head -1 | cut -d'"' -f4 || true)
            if [[ -z "$cc" ]]; then
                cc=$(tr -d '[:space:]"' <<< "$raw" | grep -oE '^[A-Z]{2}$' | head -1 || true)
            fi
            [[ "$cc" =~ ^[A-Z]{2}$ ]] && break
            cc=""
        done
    fi
    if [[ "$cc" == "IR" ]]; then
        printf '%s' "iran"
        return 0
    elif [[ -n "$cc" ]]; then
        printf '%s' "kharej"
        return 0
    fi
    return 1
}

