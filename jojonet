iran_dnat_port_in_use() {
    local port="$1" f ports p
    shopt -s nullglob
    local files=("$INSTANCES_DIR"/*.conf)
    shopt -u nullglob
    for f in "${files[@]}"; do
        ports=$(conf_get_field "$f" "Ports")
        IFS=',' read -ra _pl <<< "${ports:-}"
        for p in "${_pl[@]}"; do
            p="${p// /}"
            [[ "$p" == "$port" ]] && return 0
        done
    done
    command -v iptables >/dev/null 2>&1 || return 1
    iptables -t nat -L PREROUTING -n 2>/dev/null | grep -qE "dpt:${port}\b" && return 0
    return 1
}

allocate_iran_forward_port() {
    local preferred="${1:-443}" p
    local candidates=("$preferred" 8443 2053 2083 2096 8080 8444 4433)
    for p in "${candidates[@]}"; do
        if ! iran_dnat_port_in_use "$p"; then
            echo "$p"
            return 0
        fi
    done
    echo "$preferred"
    return 1
}

tunnel_net_prefix_for_mode() {
    case "${1:-gre}" in
        tun_tcp) echo "$TUN_TCP_NET_PREFIX" ;;
        vxlan) echo "$VXLAN_NET_PREFIX" ;;
        wireguard) echo "$WG_NET_PREFIX" ;;
        *) echo "$TUNNEL_NET_PREFIX" ;;
    esac
}

resolve_iran_forward_port() {
    local preferred="${1:-443}" current="${2:-}" first="" allocated=""
    if [[ -z "$current" ]]; then
        allocate_iran_forward_port "$preferred"
        return $?
    fi
    first="${current%%,*}"
    first="${first// /}"
    if ! iran_dnat_port_in_use "$first"; then
        echo "$current"
        return 0
    fi
    allocated=$(allocate_iran_forward_port "$first") || allocated="$first"
    if [[ "$current" == "$first" ]]; then
        echo "$allocated"
    elif [[ "$allocated" != "$first" ]]; then
        echo "${current/$first/$allocated}"
    else
        echo "$current"
    fi
}

preflight_tunnel_check() {
    local mode="${1:-gre}" role="${2:-}" loc_ip="${3:-}" rem_ip="${4:-}" \
        subnet_byte="${5:-}" tun_ip="${6:-}" extra_port="${7:-}"
    local issues=0 warns=0 iface busy="" ov="${tun_ip%%/*}"

    echo -e "${CYAN}=== Pre-flight check ===${NC}"

    if [[ "$mode" == "wireguard" && -n "$extra_port" ]] && [[ "$extra_port" =~ ^[0-9]+$ ]] && wg_udp_port_in_use "$extra_port"; then
        echo -e "  ${YELLOW}[!] UDP $extra_port in use (e.g. wg0) — pick another port${NC}"
        warns=$((warns + 1))
    fi

    if [[ "$mode" == "hysteria2" && -n "$extra_port" && "$extra_port" =~ - ]]; then
        local span
        span=$(hy2_hop_span "$extra_port" 2>/dev/null || echo 0)
        if ! hy2_hop_has_firewall_tools; then
            echo -e "  ${RED}[!] Hop Port needs nft or iptables on this server${NC}"
            issues=$((issues + 1))
        else
            echo -e "  ${GREEN}[+] Hop Port tools: nft/iptables OK${NC}"
        fi
        if (( span > 15000 )); then
            echo -e "  ${YELLOW}[!] Large hop range (${span} ports) — HY2 DNAT may be heavy; consider 10000-wide${NC}"
            warns=$((warns + 1))
        fi
        if [[ "$role" == "kharej" ]] && hy2_first_port_busy "$extra_port"; then
            echo -e "  ${YELLOW}[!] First port of hop range may be busy — HY2 listens on that port${NC}"
            warns=$((warns + 1))
        fi
    fi

    if ip link show GRETun >/dev/null 2>&1; then
        local jn=0 f
        shopt -s nullglob
        for f in "$INSTANCES_DIR"/*.conf; do
            [[ "$(basename "${f%.conf}")" == "GRETun" ]] && jn=1
        done
        shopt -u nullglob
        (( jn == 0 )) && {
            echo -e "  ${YELLOW}[!] Manual interface GRETun detected — import: sudo jojonet --import-gretun${NC}"
            warns=$((warns + 1))
        }
    fi

    if [[ -n "$ov" ]]; then
        busy=$(overlay_ip_on_iface "$ov")
        [[ -n "$busy" ]] && {
            echo -e "  ${RED}[!] Overlay $ov already on $busy${NC}"
            issues=$((issues + 1))
        }
    fi

    if [[ "$role" == "iran" ]]; then
        local fp="${8:-443}" first="${fp%%,*}"
        first="${first// /}"
        case "$mode" in
            gre|vxlan|tun_tcp|wireguard|paqet|hysteria2|rathole)
                if [[ -n "$first" ]] && iran_dnat_port_in_use "$first"; then
                    echo -e "  ${YELLOW}[!] Forward port $first already used — will auto-pick alternate${NC}"
                    warns=$((warns + 1))
                fi
                ;;
        esac
    fi

    if [[ "$mode" == "rathole" && -n "$extra_port" ]]; then
        if ! [[ "$extra_port" =~ ^[0-9]+$ ]] || (( extra_port < 1 || extra_port > 65535 )); then
            echo -e "  ${RED}[!] Invalid Rathole control port: $extra_port${NC}"
            issues=$((issues + 1))
        elif command -v ss >/dev/null 2>&1 && ss -tlnH 2>/dev/null | awk -v p=":$extra_port" '$4 ~ p"$" { found=1 } END { exit !found }'; then
            echo -e "  ${YELLOW}[!] TCP control port $extra_port already listening${NC}"
            warns=$((warns + 1))
        fi
        if [[ "$role" == "iran" ]]; then
            echo -e "  ${CYAN}[*] Rathole: open firewall TCP $extra_port (control) + forward ports${NC}"
        fi
    fi

    if (( issues == 0 && warns == 0 )); then
        echo -e "  ${GREEN}[+] Pre-flight OK${NC}"
    elif (( issues == 0 )); then
        echo -e "  ${YELLOW}[*] $warns warning(s) — continuing${NC}"
    else
        echo -e "  ${RED}[!] $issues blocking issue(s)${NC}"
        return 1
    fi
    return 0
}

show_pairing_card() {
    local role="$1" loc_ip="$2" rem_ip="$3" subnet_byte="$4" name="$5" mode="${6:-gre}" fwd_port="${7:-}"
    local prefix peer_cmd net_line
    [[ "$STEALTH_MODE" == "1" ]] && return 0
    peer_cmd=$(tunnel_peer_setup_cmd "$mode" "$loc_ip")
    prefix=$(tunnel_net_prefix_for_mode "$mode")
    echo ""
    echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${GREEN}  Pairing — next step on peer server${NC}"
    echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    if [[ "$role" == "kharej" ]]; then
        echo -e "  ${CYAN}Iran server:${NC}  ${peer_cmd} --role iran"
    else
