            ;;
    esac

    [[ -n "${Ports:-}" && "$mode" != "paqet" && "$mode" != "hysteria2" && "$mode" != "rathole" ]] && \
        echo -e "  ${GREEN}Port forward:${NC}   ${Ports} → Kharej tunnel IP" || true
