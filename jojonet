# ==========================================
# Core network helpers
# ==========================================

validate_interface_name() {
    [[ "$1" =~ ^[a-zA-Z0-9]([a-zA-Z0-9_-]{0,13}[a-zA-Z0-9])?$ ]] || return 1
}

validate_ipv4() {
    local ip="$1"
    [[ "$ip" =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}$ ]] || return 1

    local a b c d
    IFS='.' read -r a b c d <<< "$ip"

    local i
    for i in $a $b $c $d; do
        (( i <= 255 )) || return 1
    done

    (( a > 0 && a < 224 && a != 127 )) || return 1

    if [[ "$ip" =~ ^10\. || "$ip" =~ ^192\.168\. || "$ip" =~ ^172\.(1[6-9]|2[0-9]|3[0-1])\. ]]; then
        return 1
    fi
    return 0
}

validate_subnet_byte() {
    [[ "$1" =~ ^[0-9]+$ ]] || return 1
    (( "$1" >= 1 && "$1" <= 250 ))
}

validate_ports() {
    local part list
    IFS=',' read -ra list <<< "$1"

    for part in "${list[@]}"; do
        part="${part// /}"
        [[ -n "$part" ]] || return 1
        if [[ "$part" =~ ^([0-9]{1,5})$ ]]; then
            (( part >= 1 && part <= 65535 )) || return 1
        elif [[ "$part" =~ ^([0-9]{1,5})-([0-9]{1,5})$ ]]; then
            local a="${BASH_REMATCH[1]}"
            local b="${BASH_REMATCH[2]}"
            (( a >= 1 && a <= 65535 )) || return 1
            (( b >= 1 && b <= 65535 )) || return 1
            (( a <= b )) || return 1
        else
            return 1
        fi
    done
    return 0
}

auto_detect_network() {
    DEFAULT_IFACE=$(ip route get 1.1.1.1 2>/dev/null | awk 'NR==1 {print $5}')
    if [[ -z "$DEFAULT_IFACE" ]]; then
        echo -e "${RED}[!] Default interface not found.${NC}" >&2
        return 1
    fi

    DETECTED_IP=$(ip -4 -o addr show dev "$DEFAULT_IFACE" 2>/dev/null | awk '{print $4}' | cut -d/ -f1 || true)
    if [[ -z "$DETECTED_IP" ]]; then
        echo -e "${RED}[!] No IPv4 on $DEFAULT_IFACE.${NC}" >&2
        return 1
    fi
}

calculate_mtu() {
    local target="${1:-1.1.1.1}"
    local min=1200 max=1472 size best=0

    echo -e "${YELLOW}[*] Probing path MTU via ping to $target...${NC}" >&2

    while (( min <= max )); do
        size=$(( (min + max) / 2 ))
        if ping -M do -c1 -W2 -s "$size" "$target" >/dev/null 2>&1; then
            best=$size
            min=$(( size + 1 ))
        else
            max=$(( size - 1 ))
        fi
    done

    if (( best == 0 )); then
        echo "$DEFAULT_MTU_FALLBACK"
        return
    fi

    # GRE overhead: IP(20) + GRE(24) vs ICMP probe size
    local mtu=$(( best + 28 - 24 ))
    (( mtu > 1500 )) && mtu=1500
    if (( mtu < 1280 )); then
        mtu=$DEFAULT_MTU_FALLBACK
    fi
    # Prefer stable 1310 when probe is close (common GRE setup)
    if (( mtu > DEFAULT_MTU_FALLBACK )); then
        mtu=$DEFAULT_MTU_FALLBACK
    fi
    echo "$mtu"
}

generate_unique_subnet() {
    touch "$LOCK_FILE" 2>/dev/null || true
    exec 200>"$LOCK_FILE"
    flock -x 200

    local used=""
    shopt -s nullglob
    local conf_files=("$INSTANCES_DIR"/*.conf)
    shopt -u nullglob

    if (( ${#conf_files[@]} > 0 )); then
        used=$(awk -F'"' '/Subnet_Byte/ {print $2}' "${conf_files[@]}" 2>/dev/null || true)
    fi

    local byte
    for byte in $(seq 1 250); do
        if ! grep -qx "$byte" <<< "$used" 2>/dev/null; then
            echo "$byte"
            flock -u 200
            exec 200>&-
            return
        fi
    done

    flock -u 200
    exec 200>&-
    echo 0
}

subnet_byte_in_use() {
    local byte="$1"
    shopt -s nullglob
    local files=("$INSTANCES_DIR"/*.conf)
    shopt -u nullglob
    (( ${#files[@]} > 0 )) || return 1
    awk -F'"' -v b="$byte" '$0 ~ /Subnet_Byte/ && $2 == b { found=1 } END { exit !found }' "${files[@]}"
}

apply_global_sysctl() {
    if [[ ! -f "$SYSCTL_FILE" ]]; then
        echo -e "${YELLOW}[*] Applying global network tuning (BBR + forwarding)...${NC}"
        cat <<EOF > "$SYSCTL_FILE"
