check_dependencies() {
    local deps=(ip nft awk grep systemctl journalctl sysctl ping flock mktemp curl openssl)
    local cmd optional=(unzip scp)
    for cmd in "${deps[@]}"; do
        command -v "$cmd" >/dev/null 2>&1 || {
            echo -e "${RED}[!] Missing dependency: $cmd${NC}" >&2
            echo -e "${YELLOW}    apt install -y iproute2 nftables procps iputils-ping curl openssl util-linux${NC}" >&2
            exit 1
        }
    done
    for cmd in "${optional[@]}"; do
        command -v "$cmd" >/dev/null 2>&1 || true
    done
}

