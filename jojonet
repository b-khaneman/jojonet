export_all_configs() {
    local out="${1:-/root/jojonet-backup-$(date +%Y%m%d-%H%M).tar.gz}"
    local tmp
    tmp=$(mktemp -d /tmp/jojonet-exp.XXXXXX) || return 1
    install -d -m700 "$tmp/instances" "$tmp/meta"
    shopt -s nullglob
    cp -a "$INSTANCES_DIR"/*.conf "$tmp/instances/" 2>/dev/null || true
    shopt -u nullglob
    echo "version=${JOJONET_VERSION}" > "$tmp/meta/info.txt"
    date >> "$tmp/meta/info.txt"
    tar -czf "$out" -C "$tmp" instances meta 2>/dev/null || { rm -rf "$tmp"; return 1; }
    rm -rf "$tmp"
    chmod 600 "$out"
    log_info "Exported: $out"
    echo "$out"
}

import_all_configs() {
    local arc="$1" n=0
    [[ -f "$arc" ]] || { log_error "Not found: $arc"; return 1; }
    local tmp
    tmp=$(mktemp -d /tmp/jojonet-imp.XXXXXX) || return 1
    tar -xzf "$arc" -C "$tmp" || { rm -rf "$tmp"; return 1; }
    if [[ -d "$tmp/instances" ]]; then
        for f in "$tmp/instances"/*.conf; do
            [[ -f "$f" ]] || continue
            install -m600 "$f" "$INSTANCES_DIR/"
            n=$((n + 1))
        done
    fi
    rm -rf "$tmp"
    refresh_runtime_templates || true
    repair_all_instances
    restart_all_tunnels
    log_info "Imported $n tunnel config(s)."
    return 0
}

