install_wireguard_tools() {
    if command -v wg >/dev/null 2>&1; then
        return 0
    fi
    log_note "Installing wireguard-tools..."
    if command -v apt-get >/dev/null 2>&1; then
        DEBIAN_FRONTEND=noninteractive apt-get install -y wireguard wireguard-tools >/dev/null 2>&1 || \
            apt-get install -y wireguard-tools >/dev/null 2>&1 || true
    elif command -v dnf >/dev/null 2>&1; then
        dnf install -y wireguard-tools >/dev/null 2>&1 || true
    elif command -v yum >/dev/null 2>&1; then
        yum install -y wireguard-tools >/dev/null 2>&1 || true
    fi
    command -v wg >/dev/null 2>&1 || {
        log_error "wireguard-tools (wg) not available. Install: apt install wireguard-tools"
        return 1
    }
    # wg-quick is optional; we use ip/wg directly
    modprobe wireguard 2>/dev/null || true
    return 0
}

ensure_wg_keys() {
    local pair_id="$1" peer_ip="${2:-}" role="${3:-}"
    local keydir="$KEYS_ROOT/pair_${pair_id}"
    install -d -m700 "$keydir"
    # Each side has its OWN keypair; peer public is the other side's public key
    if [[ ! -f "$keydir/wg_private.key" ]]; then
        umask 077
        wg genkey | tee "$keydir/wg_private.key" | wg pubkey > "$keydir/wg_public.key"
        chmod 600 "$keydir/wg_private.key" "$keydir/wg_public.key"
        log_info "Generated local WireGuard keypair in $keydir"
    fi
    if [[ -n "$peer_ip" ]] && command -v scp >/dev/null 2>&1; then
        # Push our public key to peer as their wg_peer_public.key
        ssh -o ConnectTimeout=8 -o StrictHostKeyChecking=accept-new -o BatchMode=yes \
            "root@${peer_ip}" "mkdir -p '$keydir' && chmod 700 '$keydir'" >/dev/null 2>&1 || true
        scp -o ConnectTimeout=8 -q "$keydir/wg_public.key" \
            "root@${peer_ip}:${keydir}/wg_peer_public.key" 2>/dev/null || true
        # Pull peer public key
        scp -o ConnectTimeout=8 -o StrictHostKeyChecking=accept-new -q \
            "root@${peer_ip}:${keydir}/wg_public.key" \
            "$keydir/wg_peer_public.key" 2>/dev/null || true
    fi
    if [[ ! -f "$keydir/wg_peer_public.key" ]]; then
        log_warn "Peer WireGuard public key missing."
        log_warn "Run the same --wg command on the other server, or copy keys:"
        log_warn "  sudo jojonet --export-keys $peer_ip"
        log_warn "Temporary: using local public (will NOT handshake until peer key is set)."
        cp -f "$keydir/wg_public.key" "$keydir/wg_peer_public.key"
    fi
    chmod 600 "$keydir/wg_private.key" "$keydir/wg_public.key" "$keydir/wg_peer_public.key" 2>/dev/null || true
    printf '%s' "$keydir"
}

create_wg_runner_script() {
    if ! cat << 'EOF' > "$WG_RUNNER"
#!/usr/bin/env bash
set -Eeuo pipefail

# Safe config loader — whitelist keys only (never source shell)
_JOJONET_CONF_KEYS="Name TunnelMode Role Local_IP Remote_IP Subnet_Byte Tun_IP Tun_Remote_IP_Raw Tun_Server_IP Tun_Client_IP Suggested_MTU Ports TcpPort KeyDir GreKey PaqetYaml ForwardProto VxlanVni VxlanPort WgPrivateKey WgPublicKey WgPeerPublicKey HyYaml HyAuth HySni"

load_safe_config() {
    local file="$1" line key val
    Name="" TunnelMode="gre" Role="" Local_IP="" Remote_IP="" Subnet_Byte=""
    Tun_IP="" Tun_Remote_IP_Raw="" Tun_Server_IP="" Tun_Client_IP=""
    Suggested_MTU="" Ports="" TcpPort="" KeyDir="" GreKey=""
    PaqetYaml="" ForwardProto="" VxlanVni="" VxlanPort=""
    WgPrivateKey="" WgPublicKey="" WgPeerPublicKey="" HyYaml="" HyAuth="" HySni=""
    [[ -r "$file" ]] || return 1
    while IFS= read -r line || [[ -n "$line" ]]; do
        line="${line%%#*}"
        line="${line#"${line%%[![:space:]]*}"}"
        line="${line%"${line##*[![:space:]]}"}"
        [[ -z "$line" ]] && continue
        [[ "$line" =~ ^([A-Za-z_][A-Za-z0-9_]*)=(.*)$ ]] || return 1
        key="${BASH_REMATCH[1]}"
        val="${BASH_REMATCH[2]}"
        case " ${_JOJONET_CONF_KEYS} " in
            *" $key "*) ;;
            *) return 1 ;;
        esac
        if [[ "$val" =~ ^\"(.*)\"$ ]]; then val="${BASH_REMATCH[1]}"
        elif [[ "$val" =~ ^\'(.*)\'$ ]]; then val="${BASH_REMATCH[1]}"; fi
        case "$val" in
            *'$('*|*'`'*|*';'*|*'|'*|*'&'*|*$'\n'*|*$'\r'*) return 1 ;;
        esac
        printf -v "$key" '%s' "$val"
    done < "$file"
    [[ -n "${Name:-}" ]] || return 1
    TunnelMode=${TunnelMode:-gre}
    return 0
}

ACTION="${1:-}"
CONFIG_FILE="${2:-}"
DEFAULT_WG_MTU=1280

if [[ -z "$CONFIG_FILE" || ! -f "$CONFIG_FILE" ]]; then
    echo "Config missing" >&2
    exit 1
fi
if ! load_safe_config "$CONFIG_FILE"; then
    echo "Invalid or unsafe config: $CONFIG_FILE" >&2
    exit 1
fi

table_name="jojonet_$Name"
priv="${WgPrivateKey:-${KeyDir}/wg_private.key}"
peer_pub="${WgPeerPublicKey:-${KeyDir}/wg_peer_public.key}"
listen_port="${TcpPort:-51820}"
mtu="${Suggested_MTU:-$DEFAULT_WG_MTU}"

cleanup() {
    trap - ERR
    ip link delete "$Name" >/dev/null 2>&1 || true
    nft delete table ip "$table_name" >/dev/null 2>&1 || true
}

case "$ACTION" in
    start)
        trap cleanup ERR
        log() { echo "[jojonet-wg:${Name}] $*"; }
        command -v wg >/dev/null 2>&1 || { log "ERROR: wg missing"; exit 1; }
        [[ -f "$priv" ]] || { log "ERROR: private key missing: $priv"; exit 1; }
        [[ -f "$peer_pub" ]] || { log "ERROR: peer public key missing: $peer_pub"; exit 1; }
        modprobe wireguard 2>/dev/null || true
        if ip link show "$Name" >/dev/null 2>&1; then
            ip link delete "$Name" || true
        fi
        # Restrict AllowedIPs to tunnel overlay (backhaul), not full tunnel
        allow="${Tun_Server_IP}/32,${Tun_Client_IP}/32"
        [[ -n "$Tun_Server_IP" && -n "$Tun_Client_IP" ]] || allow="10.66.0.0/16"
        ip link add dev "$Name" type wireguard || { log "ERROR: create wg iface"; exit 1; }
        wg set "$Name" private-key "$priv" listen-port "$listen_port" \
            peer "$(cat "$peer_pub")" allowed-ips "$allow" endpoint "${Remote_IP}:${listen_port}" persistent-keepalive 25 \
            || { log "ERROR: wg set failed"; exit 1; }
        ip addr flush dev "$Name" >/dev/null 2>&1 || true
        ip addr add "$Tun_IP" dev "$Name" || { log "ERROR: IP assign"; exit 1; }
        ip link set "$Name" mtu "$mtu"
        ip link set "$Name" up || { log "ERROR: up failed"; exit 1; }
        sysctl -w "net.ipv4.conf.${Name}.rp_filter=0" >/dev/null 2>&1 || true
        if [[ "$Role" == "iran" ]]; then
            sysctl -w net.ipv4.ip_forward=1 >/dev/null 2>&1 || true
            DEFAULT_IFACE=$(ip route get 1.1.1.1 2>/dev/null | awk 'NR==1 {print $5}')
            [[ -n "$DEFAULT_IFACE" ]] || { log "ERROR: default iface"; exit 1; }
            [[ -n "$Tun_Remote_IP_Raw" ]] || { log "ERROR: remote tun IP"; exit 1; }
            NFT_CONF="table ip $table_name {
            chain prerouting {
                type nat hook prerouting priority dstnat; policy accept;"
            if [[ -n "$Ports" ]]; then
                IFS=',' read -ra PORT_LIST <<< "$Ports"
                for p in "${PORT_LIST[@]}"; do
                    p="${p// /}"
                    [[ -n "$p" ]] || continue
                    if [[ "$p" =~ ^([0-9]{1,5})-([0-9]{1,5})$ ]]; then
                        NFT_CONF="$NFT_CONF
                tcp dport ${BASH_REMATCH[1]}-${BASH_REMATCH[2]} dnat ip to $Tun_Remote_IP_Raw
                udp dport ${BASH_REMATCH[1]}-${BASH_REMATCH[2]} dnat ip to $Tun_Remote_IP_Raw"
                    else
                        NFT_CONF="$NFT_CONF
                tcp dport $p dnat ip to $Tun_Remote_IP_Raw
                udp dport $p dnat ip to $Tun_Remote_IP_Raw"
                    fi
                done
            fi
            NFT_CONF="$NFT_CONF
            }
            chain postrouting {
                type nat hook postrouting priority srcnat; policy accept;
                oifname \"$DEFAULT_IFACE\" masquerade
            }
        }"
            nft delete table ip "$table_name" >/dev/null 2>&1 || true
            echo "$NFT_CONF" | nft -f - || { log "ERROR: nft failed"; exit 1; }
        fi
        log "SUCCESS: WireGuard $Name UP ($Tun_IP)"
        ;;
    stop)
        cleanup
        exit 0
        ;;
    *)
        echo "Invalid action" >&2
        exit 1
        ;;
esac
EOF
    then
        return 1
    fi
    chmod +x "$WG_RUNNER"
}

