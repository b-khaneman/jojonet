quick_add_tunnel_wg() {
    local peer_ip="${1:-}"
    local ins_name="" role_conf="" loc_ip="" rem_ip="" subnet_byte=""
    local tun_ip="" tun_remote="" ins_mtu="$DEFAULT_WG_MTU" fwd_port="" key_dir=""
    local wg_port="$DEFAULT_WG_PORT" existing=""

    set +e
    command -v clear >/dev/null && clear
    logo
    print_banner "WireGuard Tunnel (low latency)"

    install_wireguard_tools || { sleep 2; set -e; return 1; }

    if ! auto_detect_network; then
        echo -e "${RED}[!] Cannot detect network.${NC}"
        sleep 2; set -e; return 1
    fi
    loc_ip="$DETECTED_IP"
    show_existing_tunnels_summary

    if [[ -z "$peer_ip" ]]; then
        read -r -p "Peer server IP: " peer_ip
    fi
    peer_ip="${peer_ip// /}"
    if ! validate_ipv4 "$peer_ip"; then
        echo -e "${RED}[!] Invalid peer IP.${NC}"
        sleep 2; set -e; return 1
    fi
    rem_ip="$peer_ip"

    if existing=$(find_tunnel_for_peer "$rem_ip" "wireguard"); then
        echo -e "${YELLOW}[!] WireGuard to $rem_ip exists [$existing]. Restarting...${NC}"
        restart_tunnel "$existing"
        sleep 2; set -e; return $?
    fi

    if ! role_conf=$(resolve_server_role "$loc_ip"); then
        echo -e "${RED}[!] Role required. Set JOJONET_ROLE=iran|kharej${NC}"
        sleep 2; set -e; return 1
    fi
    echo -e "${GREEN}[*] Role:${NC} $role_conf"

    ins_name=$(allocate_tunnel_name "$rem_ip" "$role_conf" "wireguard") || { set -e; return 1; }
    if [[ "$role_conf" == "iran" ]]; then
        fwd_port=$(allocate_iran_forward_port "443")
        [[ "$fwd_port" != "443" ]] && echo -e "${YELLOW}[*] Port 443 in use — forward port $fwd_port${NC}"
    else
        fwd_port=""
    fi

    read -r -p "WireGuard UDP port [$wg_port]: " _wp
    wg_port=${_wp:-$wg_port}
    if [[ "$role_conf" == "kharej" ]] && wg_udp_port_in_use "$wg_port"; then
        echo -e "${RED}[!] UDP port $wg_port is already used by another WireGuard interface.${NC}"
        echo -e "${YELLOW}    Check: wg show  |  ip link delete <iface>${NC}"
        echo -e "${YELLOW}    Or enter a different port (e.g. 51821).${NC}"
        read -r -p "WireGuard UDP port: " _wp2
        wg_port=${_wp2:-51821}
    fi

    subnet_byte=$(compute_pair_subnet_byte "$loc_ip" "$rem_ip")
    resolve_tunnel_ips "$role_conf" "$subnet_byte" "wireguard"
    tun_ip="$Tun_IP"
    tun_remote="$Tun_Remote_IP_Raw"

    local pair_id
    pair_id=$(printf '%s' "$rem_ip" | tr '.' '_')
    key_dir=$(ensure_wg_keys "$pair_id" "$rem_ip" "$role_conf") || { set -e; return 1; }

    echo -e "\n${CYAN}--- WireGuard plan ---${NC}"
    echo -e "  Interface: $ins_name"
    echo -e "  Role:      $role_conf"
    echo -e "  Peer:      $rem_ip"
    echo -e "  Port:      UDP $wg_port"
    echo -e "  Tunnel IP: $tun_ip"
    [[ -n "$fwd_port" ]] && echo -e "  Forward:   $fwd_port"
    echo ""

    if deploy_tunnel "$ins_name" "$role_conf" "$loc_ip" "$rem_ip" "$subnet_byte" \
        "$tun_ip" "$tun_remote" "$ins_mtu" "$fwd_port" "wireguard" "$wg_port" "$key_dir" \
        "$Tun_Server_IP" "$Tun_Client_IP"; then
        echo -e "${GREEN}[+] WireGuard [$ins_name] is up.${NC}"
        [[ "$role_conf" == "kharej" ]] && hint "Run on Iran: sudo jojonet --wg $loc_ip"
        sleep 2
        set -e
        return 0
    fi
    sleep 3
    set -e
    return 1
}

# ==========================================
# Hysteria2 helpers
# ==========================================

HY2_RUNNER="/usr/local/bin/jojonet-run-hy2.sh"
HY2_SERVICE="/etc/systemd/system/jojonet-hy2@.service"
HY2_CONFIG_DIR="$JOJONET_ROOT/hysteria"
HY2_BIN="/usr/local/bin/hysteria"
HY2_REPO="apernet/hysteria"
HY2_VERSION="${JOJONET_HY2_VERSION:-v2.6.1}"
DEFAULT_HY2_PORT=443
DEFAULT_HY2_SNI="www.cloudflare.com"
DEFAULT_HY2_HOP_RANGE="20000-50000"
DEFAULT_HY2_HOP_INTERVAL="30s"

normalize_hy2_hop_interval() {
    local raw="${1:-$DEFAULT_HY2_HOP_INTERVAL}" sec="" a b
    raw="${raw//' '/}"
    [[ -z "$raw" ]] && { echo "$DEFAULT_HY2_HOP_INTERVAL"; return 0; }

    # Random interval form: 15s-45s or 15-45
    if [[ "$raw" =~ ^([0-9]+)s?-([0-9]+)s?$ ]]; then
        a="${BASH_REMATCH[1]}"
        b="${BASH_REMATCH[2]}"
        if (( a < 5 )); then a=5; fi
        if (( b < a )); then b=$((a + 15)); fi
        echo "${a}s-${b}s"
        return 0
    fi

    if [[ "$raw" =~ ^[0-9]+$ ]]; then
        sec="$raw"
    elif [[ "$raw" =~ ^([0-9]+)s$ ]]; then
        sec="${BASH_REMATCH[1]}"
    elif [[ "$raw" =~ ^([0-9]+)m$ ]]; then
        sec=$(( BASH_REMATCH[1] * 60 ))
    else
        echo "$DEFAULT_HY2_HOP_INTERVAL"
        return 1
    fi
    if (( sec < 5 )); then
        sec=5
    fi
    echo "${sec}s"
}

hy2_hop_span() {
    local range="$1" a b
    [[ "$range" =~ ^([0-9]+)-([0-9]+)$ ]] || { echo 0; return 1; }
    a="${BASH_REMATCH[1]}"
    b="${BASH_REMATCH[2]}"
    echo $(( b - a + 1 ))
}

hy2_hop_has_firewall_tools() {
    command -v nft >/dev/null 2>&1 || command -v iptables >/dev/null 2>&1
}

ensure_hy2_hop_firewall() {
    local range="$1" a b ufw_range
    [[ "$range" =~ ^([0-9]+)-([0-9]+)$ ]] || return 0
    a="${BASH_REMATCH[1]}"
    b="${BASH_REMATCH[2]}"
    if ! hy2_hop_has_firewall_tools; then
        log_error "Hop Port needs nftables (nft) or iptables on Kharej."
        return 1
    fi
    # Open UDP range in UFW when enabled
    if command -v ufw >/dev/null 2>&1 && ufw status 2>/dev/null | grep -qi 'Status: active'; then
        ufw_range="${a}:${b}/udp"
        if ! ufw status 2>/dev/null | grep -qE "${a}:${b}/udp|${a}:${b} .*UDP"; then
            ufw allow proto udp from any to any port "${a}:${b}" comment 'jojonet-hy2-hop' >/dev/null 2>&1 || \
                ufw allow "${a}:${b}/udp" >/dev/null 2>&1 || \
                log_warn "UFW active — open UDP ${a}-${b} manually: ufw allow ${a}:${b}/udp"
        fi
    fi
    # firewalld
    if command -v firewall-cmd >/dev/null 2>&1 && firewall-cmd --state 2>/dev/null | grep -qi running; then
        firewall-cmd --permanent --add-port="${a}-${b}/udp" >/dev/null 2>&1 || true
        firewall-cmd --reload >/dev/null 2>&1 || true
    fi
    return 0
}

hy2_first_port_busy() {
    local range="$1" first
    [[ "$range" =~ ^([0-9]+)- ]] || return 1
    first="${BASH_REMATCH[1]}"
    if command -v ss >/dev/null 2>&1; then
        ss -ulnH 2>/dev/null | awk -v p=":$first" '$4 ~ p"$" { found=1 } END { exit !found }'
        return $?
    fi
    return 1
}

validate_hy2_port_or_range() {
    local v="$1" a b
    v="${v//' '/}"
    if [[ "$v" =~ ^[0-9]+$ ]]; then
        (( v >= 1 && v <= 65535 )) || return 1
        return 0
    fi
    if [[ "$v" =~ ^([0-9]+)-([0-9]+)$ ]]; then
        a="${BASH_REMATCH[1]}"
        b="${BASH_REMATCH[2]}"
        (( a >= 1 && b <= 65535 && a < b )) || return 1
        return 0
    fi
    return 1
}

detect_cpu_arch_hy2() {
    case "$(uname -m)" in
        x86_64|amd64) echo "amd64" ;;
        aarch64|arm64) echo "arm64" ;;
        *) return 1 ;;
    esac
}

install_hysteria2_binary() {
    if [[ -x "$HY2_BIN" ]]; then
        return 0
    fi
    local arch tmpdir url fname
    arch=$(detect_cpu_arch_hy2) || { log_error "Unsupported CPU for Hysteria2"; return 1; }
    fname="hysteria-linux-${arch}"
    url="https://github.com/${HY2_REPO}/releases/download/${HY2_VERSION}/${fname}"
    tmpdir=$(mktemp -d /tmp/jojonet-hy2.XXXXXX) || return 1
    log_note "Downloading Hysteria2 ${HY2_VERSION} ($fname)..."
    if ! download_verified "$url" "$tmpdir/$fname" "$fname"; then
        rm -rf "$tmpdir"
        return 1
    fi
    install -m755 "$tmpdir/$fname" "$HY2_BIN"
    rm -rf "$tmpdir"
    log_info "hysteria installed: $HY2_BIN"
    return 0
}

ensure_hy2_auth() {
    local pair_id="$1" peer_ip="${2:-}"
    local keydir="$KEYS_ROOT/pair_${pair_id}"
    install -d -m700 "$keydir"
    if [[ ! -f "$keydir/hy2.auth" ]]; then
        if [[ -n "$peer_ip" ]] && command -v scp >/dev/null 2>&1; then
            scp -o ConnectTimeout=8 -o StrictHostKeyChecking=accept-new -q \
                "root@${peer_ip}:${keydir}/hy2.auth" "$keydir/" 2>/dev/null || true
        fi
    fi
    if [[ ! -f "$keydir/hy2.auth" ]]; then
        openssl rand -hex 24 > "$keydir/hy2.auth"
        chmod 600 "$keydir/hy2.auth"
        if [[ -n "$peer_ip" ]] && command -v scp >/dev/null 2>&1; then
            ssh -o ConnectTimeout=8 -o StrictHostKeyChecking=accept-new -o BatchMode=yes \
                "root@${peer_ip}" "mkdir -p '$keydir' && chmod 700 '$keydir'" >/dev/null 2>&1 || true
            scp -o ConnectTimeout=8 -q "$keydir/hy2.auth" "root@${peer_ip}:${keydir}/" 2>/dev/null || true
        fi
    fi
    printf '%s' "$keydir"
}

build_hy2_runtime_config() {
    local name="$1" role="$2" rem="$3" port="$4" keydir="$5" ports="${6:-}" \
        sni="${7:-$DEFAULT_HY2_SNI}" hop_range="${8:-}" hop_interval="${9:-}"
    local auth yaml fwd_block="" p listen_addr server_addr hop_block=""
    install -d -m700 "$HY2_CONFIG_DIR"
    auth=$(tr -d '\n' < "$keydir/hy2.auth")
    yaml="$HY2_CONFIG_DIR/${name}.yaml"

    # Prefer explicit hop range; else treat port as range if "N-M"
    hop_range="${hop_range//' '/}"
    port="${port//' '/}"
    if [[ -z "$hop_range" && "$port" =~ ^[0-9]+-[0-9]+$ ]]; then
        hop_range="$port"
    fi
    if [[ -n "$hop_range" ]]; then
        validate_hy2_port_or_range "$hop_range" || return 1
        listen_addr=":${hop_range}"
        server_addr="${rem}:${hop_range}"
        hop_interval=$(normalize_hy2_hop_interval "${hop_interval:-$DEFAULT_HY2_HOP_INTERVAL}")
        if [[ "$hop_interval" =~ ^([0-9]+)s-([0-9]+)s$ ]]; then
            hop_block="transport:
  udp:
    minHopInterval: ${BASH_REMATCH[1]}s
    maxHopInterval: ${BASH_REMATCH[2]}s"
        else
            hop_block="transport:
  udp:
    hopInterval: ${hop_interval}"
        fi
    else
        validate_hy2_port_or_range "$port" || return 1
        listen_addr=":${port}"
        server_addr="${rem}:${port}"
    fi

    if [[ "$role" == "kharej" ]]; then
        cat > "$yaml" <<EOF
# JojoNet Hysteria2 server${hop_range:+ (hop port ${hop_range})}
listen: ${listen_addr}
auth:
  type: password
  password: ${auth}
masquerade:
  type: proxy
  proxy:
    url: https://${sni}
    rewriteHost: true
bandwidth:
  up: 1 gbps
  down: 1 gbps
EOF
    else
        fwd_block=""
        if [[ -n "$ports" ]]; then
            fwd_block="tcpForwarding:"
            IFS=',' read -ra _plist <<< "$ports"
            for p in "${_plist[@]}"; do
                p="${p// /}"
                [[ -n "$p" ]] || continue
                if [[ "$p" =~ ^[0-9]+$ ]]; then
                    fwd_block="${fwd_block}
  - listen: 0.0.0.0:${p}
    remote: 127.0.0.1:${p}"
                fi
            done
            fwd_block="${fwd_block}
udpForwarding:"
            for p in "${_plist[@]}"; do
                p="${p// /}"
                [[ -n "$p" ]] || continue
                if [[ "$p" =~ ^[0-9]+$ ]]; then
                    fwd_block="${fwd_block}
  - listen: 0.0.0.0:${p}
    remote: 127.0.0.1:${p}"
                fi
            done
        fi
        cat > "$yaml" <<EOF
# JojoNet Hysteria2 client (Iran)${hop_range:+ (hop port ${hop_range} / ${hop_interval})}
server: ${server_addr}
auth: ${auth}
bandwidth:
  up: 1 gbps
  down: 1 gbps
tls:
  sni: ${sni}
  insecure: true
${hop_block}
${fwd_block}
EOF
    fi
    chmod 600 "$yaml"
    echo "$yaml"
}

create_hy2_runner_script() {
    if ! cat << 'EOF' > "$HY2_RUNNER"
#!/usr/bin/env bash
set -Eeuo pipefail

_JOJONET_CONF_KEYS="Name TunnelMode Role Local_IP Remote_IP Subnet_Byte Tun_IP Tun_Remote_IP_Raw Tun_Server_IP Tun_Client_IP Suggested_MTU Ports TcpPort KeyDir GreKey PaqetYaml ForwardProto VxlanVni VxlanPort WgPrivateKey WgPublicKey WgPeerPublicKey HyYaml HyAuth HySni HyHopRange HyHopInterval RatholeToml"

load_safe_config() {
    local file="$1" line key val
    Name="" TunnelMode="gre" Role="" Local_IP="" Remote_IP="" Subnet_Byte=""
    Tun_IP="" Tun_Remote_IP_Raw="" Tun_Server_IP="" Tun_Client_IP=""
    Suggested_MTU="" Ports="" TcpPort="" KeyDir="" GreKey=""
    PaqetYaml="" ForwardProto="" VxlanVni="" VxlanPort=""
    WgPrivateKey="" WgPublicKey="" WgPeerPublicKey="" HyYaml="" HyAuth="" HySni="" HyHopRange="" HyHopInterval="" RatholeToml=""
    [[ -r "$file" ]] || return 1
    while IFS= read -r line || [[ -n "$line" ]]; do
        line="${line%%#*}"
        line="${line#"${line%%[![:space:]]*}"}"
        line="${line%"${line##*[![:space:]]}"}"
        [[ -z "$line" ]] && continue
        [[ "$line" =~ ^([A-Za-z_][A-Za-z0-9_]*)=(.*)$ ]] || return 1
        key="${BASH_REMATCH[1]}"
        val="${BASH_REMATCH[2]}"
        case " ${_JOJONET_CONF_KEYS} " in *" $key "*) ;; *) return 1 ;; esac
        if [[ "$val" =~ ^\"(.*)\"$ ]]; then val="${BASH_REMATCH[1]}"
        elif [[ "$val" =~ ^\'(.*)\'$ ]]; then val="${BASH_REMATCH[1]}"; fi
        case "$val" in *'$('*|*'`'*|*';'*|*'|'*|*'&'*|*$'\n'*|*$'\r'*) return 1 ;; esac
        printf -v "$key" '%s' "$val"
    done < "$file"
    [[ -n "${Name:-}" ]] || return 1
    return 0
}

ACTION="${1:-}"
CONFIG_FILE="${2:-}"
HY2_BIN="/usr/local/bin/hysteria"

[[ -n "$CONFIG_FILE" && -f "$CONFIG_FILE" ]] || { echo "Config missing" >&2; exit 1; }
load_safe_config "$CONFIG_FILE" || { echo "Bad config" >&2; exit 1; }
yaml="${HyYaml:-}"

stop_hy2() {
    pkill -f "hysteria (server|client) -c ${yaml}" >/dev/null 2>&1 || true
    pkill -f "hysteria.*-c ${yaml}" >/dev/null 2>&1 || true
}

case "$ACTION" in
    start)
        stop_hy2
        [[ -x "$HY2_BIN" ]] || { echo "hysteria binary missing" >&2; exit 1; }
        [[ -f "$yaml" ]] || { echo "yaml missing: $yaml" >&2; exit 1; }
        # Hop Port (Linux): server needs nft or iptables for UDP range redirect
        if [[ "$Role" == "kharej" ]]; then
            _hop="${HyHopRange:-}"
            [[ -z "$_hop" && "${TcpPort:-}" =~ ^[0-9]+-[0-9]+$ ]] && _hop="$TcpPort"
            if [[ -n "$_hop" && "$_hop" =~ - ]]; then
                if ! command -v nft >/dev/null 2>&1 && ! command -v iptables >/dev/null 2>&1; then
                    echo "ERROR: Hop Port requires nftables (nft) or iptables" >&2
                    exit 1
                fi
                echo "[jojonet-hy2:${Name}] Hop Port enabled: $_hop"
            fi
        fi
        if [[ "$Role" == "kharej" ]]; then
            exec "$HY2_BIN" server -c "$yaml"
        else
            exec "$HY2_BIN" client -c "$yaml"
        fi
        ;;
    stop)
        stop_hy2
        exit 0
        ;;
    *)
        echo "Invalid action" >&2
        exit 1
        ;;
esac
EOF
    then
        return 1
    fi
    chmod +x "$HY2_RUNNER"
}

create_hy2_service() {
    local tmp_file
    tmp_file=$(mktemp /tmp/jojonet_hy2_svc.XXXXXX) || return 1
    if ! cat << 'EOF' > "$tmp_file"
[Unit]
Description=JojoNet Hysteria2 Tunnel: %i
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
Restart=always
RestartSec=5
LimitNOFILE=65535
StandardOutput=journal
StandardError=journal
SyslogIdentifier=jojonet-hy2-%i
ExecStart=/usr/local/bin/jojonet-run-hy2.sh start /etc/jojonet/instances/%i.conf
ExecStop=/usr/local/bin/jojonet-run-hy2.sh stop /etc/jojonet/instances/%i.conf
TimeoutStartSec=90
TimeoutStopSec=30
KillMode=mixed

[Install]
