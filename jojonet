find_tunnel_for_peer() {
    local peer="$1" want_mode="${2:-}" f n r m
    shopt -s nullglob
    local files=("$INSTANCES_DIR"/*.conf)
    shopt -u nullglob
    for f in "${files[@]}"; do
        n=$(grep -E '^Name=' "$f" 2>/dev/null | head -1 | cut -d'"' -f2)
        r=$(grep -E '^Remote_IP=' "$f" 2>/dev/null | head -1 | cut -d'"' -f2)
        m=$(grep -E '^TunnelMode=' "$f" 2>/dev/null | head -1 | cut -d'"' -f2)
        m=${m:-gre}
        if [[ -n "$n" && "$r" == "$peer" ]]; then
            if [[ -n "$want_mode" && "$m" != "$want_mode" ]]; then
                continue
            fi
            echo "$n"
            return 0
        fi
    done
    return 1
}

tunnel_name_taken() {
    local name="$1"
    if [[ -f "$INSTANCES_DIR/$name.conf" ]]; then
        return 0
    fi
    ip link show "$name" >/dev/null 2>&1
}

generate_unique_tunnel_name() {
    local base="$1" candidate="" i max_base
    if ! tunnel_name_taken "$base"; then
        echo "$base"
        return 0
    fi
    for i in $(seq 2 99); do
        max_base=$((15 - ${#i}))
        (( max_base < 1 )) && max_base=1
        candidate="${base:0:max_base}${i}"
        if ! tunnel_name_taken "$candidate"; then
            echo "$candidate"
            return 0
        fi
    done
    return 1
}

# Unique interface per peer — e.g. ir195158230128 (foreign) / kh575200210 (iran)
generate_tunnel_name_from_peer() {
    local peer="$1" role="$2" mode="${3:-gre}" subnet_byte="${4:-}"
    local digits prefix base suffix=""
    digits=$(echo "$peer" | tr -d '.')
    if [[ "$mode" == "tun_tcp" ]]; then
        prefix="tc"
    elif [[ "$mode" == "paqet" ]]; then
        prefix="pq"
    elif [[ "$mode" == "vxlan" ]]; then
        prefix="vx"
    elif [[ "$mode" == "wireguard" ]]; then
        prefix="wg"
    elif [[ "$mode" == "hysteria2" ]]; then
        prefix="hy"
    elif [[ "$mode" == "rathole" ]]; then
        prefix="rh"
    elif [[ "$mode" == "gre" && -n "$subnet_byte" ]]; then
        prefix="gr"
        suffix="b${subnet_byte}"
    elif [[ "$role" == "kharej" ]]; then
        prefix="ir"
    else
        prefix="kh"
    fi
    base="${prefix}${digits}${suffix}"
    if (( ${#base} > 15 )); then
        if [[ -n "$suffix" ]]; then
            base="${prefix}${digits: -$((15 - ${#prefix} - ${#suffix}))}${suffix}"
        else
            base="${prefix}${digits: -$((15 - ${#prefix}))}"
        fi
    fi
    generate_unique_tunnel_name "$base"
}

any_gre_present() {
    ip -o link show type gre 2>/dev/null | grep -q .
}

allocate_tunnel_name() {
    local peer="$1" role="$2" mode="${3:-gre}" subnet_byte="${4:-}"
    local base=""
    load_stealth_mode
    if [[ "$STEALTH_MODE" == "1" ]]; then
        base=$(generate_stealth_tunnel_name "$peer" "$role" "$mode")
        generate_unique_tunnel_name "$base"
        return 0
    fi
    generate_tunnel_name_from_peer "$peer" "$role" "$mode" "$subnet_byte"
}

wait_for_tunnel_up() {
    local name="$1" mode="$2" max_wait="${3:-60}"
    local i
    for ((i = 1; i <= max_wait; i++)); do
        if [[ "$mode" == "tun_tcp" || "$mode" == "wireguard" ]]; then
            ip link show "$name" >/dev/null 2>&1 && return 0
        elif [[ "$mode" == "paqet" ]]; then
            pgrep -f "paqet run -c.*/${name}\\.yaml" >/dev/null 2>&1 && return 0
        elif [[ "$mode" == "hysteria2" ]]; then
            if pgrep -f "hysteria.*${name}\\.yaml" >/dev/null 2>&1; then
                return 0
            fi
            if systemctl is-active --quiet "jojonet-hy2@${name}.service" 2>/dev/null; then
                return 0
            fi
        elif [[ "$mode" == "rathole" ]]; then
            if pgrep -f "rathole.*${name}\\.toml" >/dev/null 2>&1; then
                return 0
            fi
            if systemctl is-active --quiet "jojonet-rathole@${name}.service" 2>/dev/null; then
                return 0
            fi
        elif ip link show "$name" 2>/dev/null | grep -qE 'state UP|UP,'; then
            return 0
        fi
        sleep 1
    done
    return 1
}

verify_tunnel_ping() {
    local target_ip="$1"
    [[ -n "$target_ip" ]] || return 0
    if ping -c 2 -W 3 "$target_ip" >/dev/null 2>&1; then
        echo -e "${GREEN}[+] Ping OK: $target_ip${NC}"
        return 0
    fi
    echo -e "${YELLOW}[!] Ping to $target_ip failed (check peer server / firewall).${NC}"
    return 1
}

repair_single_config() {
    local conf="$1" loc rem gre mode name changed=0
    [[ -f "$conf" ]] || return 0
    repair_tunnel_overlay_ips "$conf" && changed=1
    mode=$(conf_get_field "$conf" "TunnelMode")
    name=$(conf_get_field "$conf" "Name")
    [[ -n "$name" ]] || return 0

    if [[ "${mode:-gre}" == "gre" ]]; then
        : # plain GRE — no key
    elif [[ "${mode:-gre}" == "vxlan" ]]; then
        local vni port
        vni=$(conf_get_field "$conf" "VxlanVni")
        if [[ -z "$vni" ]]; then
            loc=$(conf_get_field "$conf" "Local_IP")
            rem=$(conf_get_field "$conf" "Remote_IP")
            vni=$(compute_vxlan_vni "$loc" "$rem")
            if grep -q '^VxlanVni=' "$conf"; then
                sed -i "s/^VxlanVni=.*/VxlanVni=\"$vni\"/" "$conf"
            else
                echo "VxlanVni=\"$vni\"" >> "$conf"
            fi
            changed=1
            echo -e "${YELLOW}[*] Repaired VxlanVni for [$name] -> $vni${NC}"
        fi
        port=$(conf_get_field "$conf" "VxlanPort")
        if [[ -z "$port" ]]; then
            if grep -q '^VxlanPort=' "$conf"; then
                sed -i "s/^VxlanPort=.*/VxlanPort=\"$DEFAULT_VXLAN_PORT\"/" "$conf"
            else
                echo "VxlanPort=\"$DEFAULT_VXLAN_PORT\"" >> "$conf"
            fi
            changed=1
        fi
    elif [[ "${mode:-gre}" == "paqet" ]]; then
        local yaml tcp_port key_dir role rem fwd proto
        yaml=$(conf_get_field "$conf" "PaqetYaml")
        tcp_port=$(conf_get_field "$conf" "TcpPort")
        key_dir=$(conf_get_field "$conf" "KeyDir")
        role=$(conf_get_field "$conf" "Role")
        rem=$(conf_get_field "$conf" "Remote_IP")
        fwd=$(conf_get_field "$conf" "Ports")
        proto=$(conf_get_field "$conf" "ForwardProto")
        proto=${proto:-tcp}
        if [[ -n "$yaml" && ( ! -f "$yaml" || ! -s "$yaml" ) && -n "$key_dir" ]]; then
            build_paqet_runtime_config "$name" "$role" "$rem" "${tcp_port:-$DEFAULT_PAQET_PORT}" \
                "$key_dir" "$fwd" "$proto" && changed=1
            echo -e "${YELLOW}[*] Repaired Paqet YAML for [$name]${NC}"
        fi
    elif [[ "${mode:-gre}" == "hysteria2" ]]; then
        local yaml tcp_port key_dir role rem fwd sni hop_range hop_interval need_rebuild=0
        yaml=$(conf_get_field "$conf" "HyYaml")
        tcp_port=$(conf_get_field "$conf" "TcpPort")
        key_dir=$(conf_get_field "$conf" "KeyDir")
        role=$(conf_get_field "$conf" "Role")
        rem=$(conf_get_field "$conf" "Remote_IP")
        fwd=$(conf_get_field "$conf" "Ports")
        sni=$(conf_get_field "$conf" "HySni")
        hop_range=$(conf_get_field "$conf" "HyHopRange")
        hop_interval=$(conf_get_field "$conf" "HyHopInterval")
        sni=${sni:-$DEFAULT_HY2_SNI}
        if [[ -z "$hop_range" && "$tcp_port" =~ ^[0-9]+-[0-9]+$ ]]; then
            hop_range="$tcp_port"
        fi
        if [[ -z "$yaml" || ! -f "$yaml" || ! -s "$yaml" ]]; then
            need_rebuild=1
        elif [[ -n "$hop_range" ]]; then
            # YAML stale if missing hop range or hopInterval
            if ! grep -qE "listen: :${hop_range}|server: .*:${hop_range}" "$yaml" 2>/dev/null; then
                need_rebuild=1
            elif [[ "$role" == "iran" ]] && ! grep -qE 'hopInterval:|minHopInterval:' "$yaml" 2>/dev/null; then
                need_rebuild=1
            fi
        fi
        if (( need_rebuild == 1 )) && [[ -n "$key_dir" && -f "$key_dir/hy2.auth" ]]; then
            yaml=$(build_hy2_runtime_config "$name" "$role" "$rem" \
                "${tcp_port:-$DEFAULT_HY2_PORT}" "$key_dir" "$fwd" "$sni" \
                "$hop_range" "$hop_interval") && changed=1
            if [[ -n "$yaml" ]]; then
                if grep -q '^HyYaml=' "$conf"; then
                    sed -i "s|^HyYaml=.*|HyYaml=\"$yaml\"|" "$conf"
                else
                    echo "HyYaml=\"$yaml\"" >> "$conf"
                fi
                if [[ -n "$hop_range" ]]; then
                    if grep -q '^HyHopRange=' "$conf"; then
                        sed -i "s|^HyHopRange=.*|HyHopRange=\"$hop_range\"|" "$conf"
                    else
                        echo "HyHopRange=\"$hop_range\"" >> "$conf"
                    fi
                    [[ "$role" == "kharej" ]] && ensure_hy2_hop_firewall "$hop_range" || true
                fi
                echo -e "${YELLOW}[*] Repaired Hysteria2 YAML for [$name]${hop_range:+ (hop $hop_range)}${NC}"
            fi
        fi
    elif [[ "${mode:-gre}" == "rathole" ]]; then
        local toml tcp_port key_dir role rem fwd need_rebuild=0
        toml=$(conf_get_field "$conf" "RatholeToml")
        tcp_port=$(conf_get_field "$conf" "TcpPort")
        key_dir=$(conf_get_field "$conf" "KeyDir")
        role=$(conf_get_field "$conf" "Role")
        rem=$(conf_get_field "$conf" "Remote_IP")
        fwd=$(conf_get_field "$conf" "Ports")
        if [[ -z "$toml" || ! -f "$toml" || ! -s "$toml" ]]; then
            need_rebuild=1
        elif ! grep -qE '^\[(server|client)\]' "$toml" 2>/dev/null; then
            need_rebuild=1
        fi
        if (( need_rebuild == 1 )) && [[ -n "$key_dir" && -f "$key_dir/rathole.token" ]]; then
            toml=$(build_rathole_runtime_config "$name" "$role" "$rem" \
                "${tcp_port:-$DEFAULT_RATHOLE_CTRL_PORT}" "$key_dir" \
                "${fwd:-$DEFAULT_RATHOLE_FWD}") && changed=1
            if [[ -n "$toml" ]]; then
                if grep -q '^RatholeToml=' "$conf"; then
                    sed -i "s|^RatholeToml=.*|RatholeToml=\"$toml\"|" "$conf"
                else
                    echo "RatholeToml=\"$toml\"" >> "$conf"
                fi
                [[ "$role" == "iran" ]] && ensure_rathole_firewall "${tcp_port:-$DEFAULT_RATHOLE_CTRL_PORT}" "${fwd:-$DEFAULT_RATHOLE_FWD}" || true
                echo -e "${YELLOW}[*] Repaired Rathole TOML for [$name]${NC}"
            fi
        fi
    fi

    if (( changed )); then
        systemctl restart "$(tunnel_service_unit "$name")" 2>/dev/null || true
    fi
}

