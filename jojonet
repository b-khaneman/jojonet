    local peer_ping="${Tun_Remote_IP_Raw:-}"
    [[ -z "$peer_ping" && "$Role" == "kharej" ]] && peer_ping="${Tun_Client_IP:-}"
    [[ -n "$peer_ping" ]] && echo -e "  ${GREEN}Ping test:${NC}     ping ${peer_ping}  (peer overlay on this link)" || true
}

