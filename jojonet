        if ip link show "$Name" >/dev/null 2>&1; then
            log "Removing stale interface $Name"
            ip link delete "$Name" || { log "ERROR: failed to delete old interface"; exit 1; }
        fi

        log "ip tunnel add $Name mode gre remote $Remote_IP local $Local_IP"
        ip tunnel add "$Name" mode gre remote "$Remote_IP" local "$Local_IP" \
            || { log "ERROR: GRE creation failed"; exit 1; }

        _want_ip="${Tun_IP%%/*}"
        _busy=$(ip -o -4 addr show 2>/dev/null | awk -v ip="$_want_ip" '$4 ~ "^" ip "(/|$)" { print $2; exit }')
        if [[ -n "$_busy" && "$_busy" != "$Name" ]]; then
            log "ERROR: overlay IP $_want_ip already on interface $_busy"
