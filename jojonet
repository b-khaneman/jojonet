        menu_line "6) Hysteria2 Tunnel (high speed)"
        menu_line "7) Advanced GRE Setup"
        menu_line "8) Manage Tunnels"
        menu_line "9) Network Status"
        menu_line "10) Stealth Mode (history + quiet)"
        menu_line "11) Healthcheck tunnel"
        menu_line "12) Export / Import keys (no SSH)"
        menu_line "13) Update JojoNet from GitHub"
        menu_line "0) Exit"
        echo ""
        read -r -p "  Select: " choice || break

        case "$choice" in
            1) quick_add_tunnel || true ;;
            2) quick_add_tunnel_tun_tcp || true ;;
            3) quick_add_tunnel_paqet || true ;;
            4) quick_add_tunnel_vxlan || true ;;
            5) quick_add_tunnel_wg || true ;;
            6) quick_add_tunnel_hy2 || true ;;
            7) add_new_tunnel || true ;;
            8) manage_tunnels || true ;;
            9) show_live_status || true ;;
            10) toggle_stealth_mode ;;
            11)
                read -r -p "Tunnel name: " _hn || true
                [[ -n "${_hn:-}" ]] && healthcheck_tunnel "$_hn"
                press_enter
                ;;
            12)
                echo "  1) Export keys"
                echo "  2) Import keys"
                read -r -p "Choose [1/2]: " _kc || true
                if [[ "$_kc" == "1" ]]; then
                    read -r -p "Peer public IP: " _peer || true
                    [[ -n "${_peer:-}" ]] && export_pair_keys "$_peer"
                elif [[ "$_kc" == "2" ]]; then
                    read -r -p "Peer public IP: " _peer || true
                    read -r -p "Archive path: " _arc || true
                    [[ -n "${_peer:-}" && -n "${_arc:-}" ]] && import_pair_keys "$_peer" "$_arc"
                fi
                press_enter
                ;;
            13) menu_update_jojonet || true ;;
            0) command -v clear >/dev/null && clear; opsec_scrub_history; exit 0 ;;
            *) echo -e "${RED}Invalid option.${NC}"; sleep 1 ;;
        esac
