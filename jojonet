tunnel_service_unit() {
    local name="$1" mode=""
    mode=$(tunnel_mode_from_name "$name")
    case "$mode" in
        tun_tcp)    echo "jojonet-tcptun@${name}.service" ;;
        paqet)      echo "jojonet-paqet@${name}.service" ;;
        vxlan)      echo "jojonet-vxlan@${name}.service" ;;
        wireguard)  echo "jojonet-wg@${name}.service" ;;
        hysteria2)  echo "jojonet-hy2@${name}.service" ;;
        rathole)    echo "jojonet-rathole@${name}.service" ;;
        *)          echo "jojonet@${name}.service" ;;
    esac
}

tunnel_boot_enabled() {
    systemctl is-enabled --quiet "$(tunnel_service_unit "$1")" 2>/dev/null
}

show_tunnel_logs() {
    local name="$1" mode="${2:-recent}"
    local unit
    unit=$(tunnel_service_unit "$name")

    echo -e "${CYAN}=== Logs: $name ($mode) ===${NC}"
    case "$mode" in
        status)
            systemctl status "$unit" --no-pager -l 2>/dev/null || true ;;
        recent)
            journalctl -u "$unit" -b --no-pager -n 50 2>/dev/null || true ;;
        boot)
            journalctl -u "$unit" -b --no-pager 2>/dev/null || true ;;
        full)
            journalctl -u "$unit" --no-pager -n 500 2>/dev/null || true ;;
        all)
            journalctl -u "$unit" --no-pager 2>/dev/null || true ;;
        export)
            local out="/var/log/jojonet_${name}.log"
            journalctl -u "$unit" --no-pager > "$out" 2>/dev/null || true
            echo -e "${GREEN}[+] Logs saved: $out${NC}" ;;
        *)
            journalctl -u "$unit" -b --no-pager -n 50 2>/dev/null || true ;;
    esac
}

tunnel_logs_menu() {
    local name="$1" choice=""
    while true; do
        command -v clear >/dev/null && clear
        echo -e "${CYAN}Logs: $name${NC}"
        menu_line "1) Service status (systemctl)"
        menu_line "2) Recent logs (50 lines)"
        menu_line "3) Full boot logs"
        menu_line "4) Extended logs (500 lines)"
        menu_line "5) All logs (complete)"
        menu_line "6) Export to /var/log/"
        menu_line "0) Back"
        read -r -p "Choice: " choice || break
        case "$choice" in
            1) show_tunnel_logs "$name" status; press_enter ;;
            2) show_tunnel_logs "$name" recent; press_enter ;;
            3) show_tunnel_logs "$name" boot; press_enter ;;
            4) show_tunnel_logs "$name" full; press_enter ;;
            5) show_tunnel_logs "$name" all; press_enter ;;
            6) show_tunnel_logs "$name" export; press_enter ;;
            0) break ;;
            *) echo -e "${RED}Invalid.${NC}"; sleep 1 ;;
        esac
    done
}

restart_tunnel() {
    local name="$1"
    local unit
    unit=$(tunnel_service_unit "$name")

    echo -e "${YELLOW}[*] Restarting [$name]...${NC}"
    systemctl reset-failed "$unit" >/dev/null 2>&1 || true
    if ! systemctl restart "$unit" 2>/dev/null; then
        echo -e "${RED}[!] systemctl restart failed.${NC}"
        show_tunnel_logs "$name" recent
        return 1
    fi
    sleep 2
    local mode unit_active=0
    mode=$(tunnel_mode_from_name "$name")
    unit=$(tunnel_service_unit "$name")
    if systemctl is-active --quiet "$unit"; then
        if [[ "$mode" == "paqet" ]]; then
            pgrep -f "paqet run -c.*/${name}\\.yaml" >/dev/null 2>&1 && unit_active=1
        elif [[ "$mode" == "hysteria2" ]]; then
            pgrep -f "hysteria.*${name}" >/dev/null 2>&1 && unit_active=1
        elif [[ "$mode" == "tun_tcp" || "$mode" == "wireguard" || "$mode" == "gre" || "$mode" == "vxlan" ]]; then
            ip link show "$name" >/dev/null 2>&1 && unit_active=1
        elif ip link show "$name" 2>/dev/null | grep -qE 'state UP|UP,'; then
            unit_active=1
        fi
    fi
    if (( unit_active == 1 )); then
        echo -e "${GREEN}[+] Tunnel [$name] restarted successfully.${NC}"
        return 0
    fi
    echo -e "${RED}[!] Restart completed but tunnel may be down.${NC}"
    show_tunnel_logs "$name" recent
    return 1
}

restart_all_tunnels() {
    shopt -s nullglob
    local files=("$INSTANCES_DIR"/*.conf)
    shopt -u nullglob
    if (( ${#files[@]} == 0 )); then
        echo -e "${YELLOW}No tunnels to restart.${NC}"
        return 0
    fi
    local f n ok=0 fail=0
    echo -e "${YELLOW}[*] Restarting all tunnels...${NC}"
    for f in "${files[@]}"; do
        n=$(grep -E '^Name=' "$f" 2>/dev/null | head -1 | cut -d'"' -f2)
        [[ -n "$n" ]] || continue
        if restart_tunnel "$n"; then
            ok=$((ok + 1))
        else
            fail=$((fail + 1))
        fi
    done
    echo -e "${GREEN}Done: $ok OK, $fail failed.${NC}"
    sleep 2
}

stop_tunnel_runtime() {
    local name="$1" unit="" conf="$INSTANCES_DIR/$name.conf"
    unit=$(tunnel_service_unit "$name")
    systemctl stop "$unit" >/dev/null 2>&1 || true
    pkill -f "tun-server.*-device ${name}" >/dev/null 2>&1 || true
    pkill -f "tun-client.*-device ${name}" >/dev/null 2>&1 || true
    pkill -f "paqet run -c.*/${name}\\.yaml" >/dev/null 2>&1 || true
    if [[ -r "$conf" ]] && grep -q '^TunnelMode="gre"' "$conf" 2>/dev/null; then
        local remote="" ports="" p
        remote=$(grep -E '^Tun_Remote_IP_Raw=' "$conf" 2>/dev/null | head -1 | cut -d'"' -f2)
        ports=$(grep -E '^Ports=' "$conf" 2>/dev/null | head -1 | cut -d'"' -f2)
        ports=${ports:-443}
        if [[ -n "$remote" ]]; then
            IFS=',' read -ra _PL <<< "$ports"
            for p in "${_PL[@]}"; do
                p="${p// /}"
                [[ -n "$p" && "$p" =~ ^[0-9]+$ ]] || continue
                iptables -t nat -D PREROUTING -p tcp --dport "$p" \
                    -j DNAT --to-destination "${remote}:$p" 2>/dev/null || true
            done
        fi
    fi
    ip link show "$name" >/dev/null 2>&1 && ip link delete "$name" >/dev/null 2>&1 || true
    nft list table ip "jojonet_$name" >/dev/null 2>&1 && \
        nft delete table ip "jojonet_$name" >/dev/null 2>&1 || true
}

tunnel_peer_setup_cmd() {
    local mode="$1" loc_ip="$2"
    case "$mode" in
        tun_tcp)     printf 'sudo jojonet --tun-tcp %s' "$loc_ip" ;;
        paqet)       printf 'sudo jojonet --paqet %s' "$loc_ip" ;;
        vxlan)       printf 'sudo jojonet --vxlan %s' "$loc_ip" ;;
        wireguard)   printf 'sudo jojonet --wg %s' "$loc_ip" ;;
        hysteria2)   printf 'sudo jojonet --hy2 %s' "$loc_ip" ;;
        rathole)     printf 'sudo jojonet --rathole %s' "$loc_ip" ;;
        *)           printf 'sudo jojonet %s' "$loc_ip" ;;
    esac
}

# Replace tunnel peer IP: recomputes subnet/overlay/keys and redeploys same tunnel name
change_tunnel_peer_ip() {
    local tunnel_name="${1:-}" new_peer="${2:-}"
    local conf="" mode="" role="" loc_ip="" rem_ip="" subnet_byte=""
    local tun_ip="" tun_remote="" mtu="" fwd_port="" tcp_port="" key_dir=""
    local tun_server="" tun_client="" fwd_proto="" pair_id="" backup="" existing=""
    local peer_label="" old_peer="" Name="" TunnelMode="" Role="" Local_IP="" Remote_IP=""
    local Subnet_Byte="" Tun_IP="" Tun_Remote_IP_Raw="" Tun_Server_IP="" Tun_Client_IP=""
    local Suggested_MTU="" Ports="" TcpPort="" KeyDir="" ForwardProto=""
    local old_subnet="" old_tun_client="" old_tun_server=""

    set +e
    [[ -n "$tunnel_name" ]] || read -r -p "Tunnel name: " tunnel_name
    tunnel_name="${tunnel_name// /}"
    conf="$INSTANCES_DIR/$tunnel_name.conf"
    if [[ ! -r "$conf" ]]; then
        echo -e "${RED}[!] Tunnel not found: $tunnel_name${NC}"
        sleep 2
        set -e
        return 1
    fi

    if ! load_instance_config "$conf"; then
        echo -e "${RED}[!] Invalid config: $conf${NC}"
        sleep 2
        set -e
        return 1
    fi

    mode="${TunnelMode:-gre}"
    role="${Role:-}"
    old_peer="${Remote_IP:-}"
    mtu="${Suggested_MTU:-$DEFAULT_MTU_FALLBACK}"
    fwd_port="${Ports:-}"
    tcp_port="${TcpPort:-$DEFAULT_TCP_PORT}"
    fwd_proto="${ForwardProto:-tcp}"

    if [[ "$role" == "iran" ]]; then
        peer_label="Kharej / خارج"
    else
        peer_label="Iran / ایران"
    fi

    echo -e "\n${CYAN}=== Change peer IP [$tunnel_name] ===${NC}"
    echo -e "  Mode:         $(tunnel_mode_label "$mode")"
    echo -e "  This server:  ${Local_IP:-?}  ($(tunnel_role_label "$role"))"
    echo -e "  Current peer: ${old_peer}  (${peer_label})"

    [[ -n "$new_peer" ]] || read -r -p "New ${peer_label} IP: " new_peer
    new_peer="${new_peer// /}"
    if [[ -z "$new_peer" ]] || ! validate_ipv4 "$new_peer"; then
        echo -e "${RED}[!] Invalid IP.${NC}"
        sleep 2
        set -e
        return 1
    fi
    if [[ "$new_peer" == "$old_peer" ]]; then
        echo -e "${YELLOW}[!] Same peer IP — no change.${NC}"
        sleep 2
        set -e
        return 0
    fi

    if auto_detect_network; then
        loc_ip="$DETECTED_IP"
        [[ "$loc_ip" != "${Local_IP:-}" ]] && \
            echo -e "${YELLOW}[*] Local IP updated: ${Local_IP:-?} -> $loc_ip${NC}"
    else
        loc_ip="${Local_IP:-}"
    fi
    if [[ -z "$loc_ip" ]] || ! validate_ipv4 "$loc_ip"; then
        echo -e "${RED}[!] Cannot resolve local IP.${NC}"
        sleep 2
        set -e
        return 1
    fi
    if [[ "$new_peer" == "$loc_ip" ]]; then
        echo -e "${RED}[!] Peer IP cannot be the same as this server.${NC}"
        sleep 2
        set -e
        return 1
    fi

    if existing=$(find_tunnel_for_peer "$new_peer" "$mode"); then
        if [[ "$existing" != "$tunnel_name" ]]; then
            echo -e "${RED}[!] Another tunnel [$existing] already uses peer $new_peer.${NC}"
            echo -e "${YELLOW}    Delete it first or pick a different peer.${NC}"
            sleep 3
            set -e
            return 1
        fi
    fi

    rem_ip="$new_peer"
    subnet_byte=$(compute_pair_subnet_byte "$loc_ip" "$rem_ip")
    old_subnet="${Subnet_Byte:-}"
    old_tun_client="${Tun_Client_IP:-}"
    old_tun_server="${Tun_Server_IP:-}"

    case "$mode" in
        tun_tcp)
            tcp_port="${TcpPort:-$DEFAULT_TCP_PORT}"
            key_dir=$(ensure_tun_tcp_keys "$subnet_byte" "$rem_ip") || {
                echo -e "${RED}[!] TUN/TCP key setup failed.${NC}"
                sleep 2
                set -e
                return 1
            }
            resolve_tunnel_ips "$role" "$subnet_byte" "tun_tcp"
            tun_ip="$Tun_IP"
            tun_remote="$Tun_Remote_IP_Raw"
            tun_server="$Tun_Server_IP"
            tun_client="$Tun_Client_IP"
            ;;
        paqet)
            tcp_port="${TcpPort:-$DEFAULT_PAQET_PORT}"
            key_dir=$(ensure_paqet_secret "$subnet_byte" "$rem_ip") || {
                echo -e "${RED}[!] Paqet secret setup failed.${NC}"
                sleep 2
                set -e
                return 1
            }
            tun_ip=""
            tun_remote=""
            tun_server=""
            tun_client=""
            ;;
        vxlan)
            tcp_port="${VxlanPort:-${TcpPort:-$DEFAULT_VXLAN_PORT}}"
            key_dir="${KeyDir:-}"
            resolve_tunnel_ips "$role" "$subnet_byte" "vxlan"
            tun_ip="$Tun_IP"
            tun_remote="$Tun_Remote_IP_Raw"
            tun_server="$Tun_Server_IP"
            tun_client="$Tun_Client_IP"
            ;;
        wireguard)
            tcp_port="${TcpPort:-$DEFAULT_WG_PORT}"
            pair_id=$(printf '%s' "$rem_ip" | tr '.' '_')
            key_dir=$(ensure_wg_keys "$pair_id" "$rem_ip" "$role") || {
                echo -e "${RED}[!] WireGuard key setup failed.${NC}"
                sleep 2
                set -e
                return 1
            }
            resolve_tunnel_ips "$role" "$subnet_byte" "wireguard"
            tun_ip="$Tun_IP"
            tun_remote="$Tun_Remote_IP_Raw"
            tun_server="$Tun_Server_IP"
            tun_client="$Tun_Client_IP"
            ;;
        hysteria2)
            tcp_port="${TcpPort:-$DEFAULT_HY2_PORT}"
            pair_id=$(printf '%s' "$rem_ip" | tr '.' '_')
            key_dir=$(ensure_hy2_auth "$pair_id" "$rem_ip") || {
                echo -e "${RED}[!] Hysteria2 auth setup failed.${NC}"
                sleep 2
                set -e
                return 1
            }
            export HySni="${HySni:-$DEFAULT_HY2_SNI}"
            export HyHopRange="${HyHopRange:-}"
            export HyHopInterval="${HyHopInterval:-}"
            if [[ -z "${HyHopRange:-}" && "$tcp_port" =~ ^[0-9]+-[0-9]+$ ]]; then
                export HyHopRange="$tcp_port"
            fi
            tun_ip=""
            tun_remote=""
            tun_server=""
            tun_client=""
            ;;
        rathole)
            tcp_port="${TcpPort:-$DEFAULT_RATHOLE_CTRL_PORT}"
            pair_id=$(printf '%s' "$rem_ip" | tr '.' '_')
            key_dir=$(ensure_rathole_token "$pair_id" "$rem_ip") || {
                echo -e "${RED}[!] Rathole token setup failed.${NC}"
                sleep 2
                set -e
                return 1
            }
            tun_ip=""
            tun_remote=""
            tun_server=""
            tun_client=""
            ;;
        *)
            key_dir="${KeyDir:-}"
            subnet_byte=$(allocate_gre_subnet_byte "$loc_ip" "$rem_ip" "$role") || {
                echo -e "${RED}[!] GRE subnet collision for this peer.${NC}"
                sleep 2; set -e; return 1
            }
            resolve_tunnel_ips "$role" "$subnet_byte" "gre"
            tun_ip="$Tun_IP"
            tun_remote="$Tun_Remote_IP_Raw"
            tun_server="$Tun_Server_IP"
            tun_client="$Tun_Client_IP"
            ;;
    esac

    echo -e "\n${CYAN}--- New tunnel plan (replaces current) ---${NC}"
    echo -e "  Peer:      ${old_peer}  ->  ${GREEN}${rem_ip}${NC}"
    echo -e "  Subnet:    ${old_subnet:-?}  ->  ${GREEN}${subnet_byte}${NC}"
    if [[ "$mode" =~ ^(gre|vxlan|wireguard|tun_tcp)$ ]]; then
        echo -e "  Overlay:   ${old_tun_client:-?} (Iran) <-> ${old_tun_server:-?} (Kharej)"
        echo -e "          -> ${GREEN}${tun_client} (Iran) <-> ${tun_server} (Kharej)${NC}"
    fi
    [[ -n "$fwd_port" ]] && echo -e "  Forward:   $fwd_port (kept)"
    echo -e "  MTU:       $mtu (kept)"

    read -r -p "Apply change and redeploy tunnel? [y/N]: " _confirm
    _confirm=$(echo "$_confirm" | tr '[:upper:]' '[:lower:]')
    if [[ "$_confirm" != "y" ]]; then
        echo -e "${YELLOW}Cancelled.${NC}"
        sleep 1
        set -e
        return 0
    fi

    backup=$(mktemp /tmp/jojonet-peer-backup.XXXXXX) || backup=""
    [[ -n "$backup" ]] && cp "$conf" "$backup"

    echo -e "${YELLOW}[*] Stopping current tunnel...${NC}"
    stop_tunnel_runtime "$tunnel_name"

    if deploy_tunnel "$tunnel_name" "$role" "$loc_ip" "$rem_ip" "$subnet_byte" \
        "$tun_ip" "$tun_remote" "$mtu" "$fwd_port" "$mode" "$tcp_port" "$key_dir" \
        "$tun_server" "$tun_client" "$fwd_proto"; then
        [[ -n "$backup" ]] && rm -f "$backup"
        echo -e "${GREEN}[+] Peer IP updated. Tunnel [$tunnel_name] redeployed.${NC}"
        hint "Run on the NEW peer server: $(tunnel_peer_setup_cmd "$mode" "$loc_ip")"
        sleep 2
        set -e
        return 0
    fi

    echo -e "${RED}[!] Redeploy failed.${NC}"
    if [[ -n "$backup" && -f "$backup" ]]; then
        cp "$backup" "$conf"
        rm -f "$backup"
        echo -e "${YELLOW}[*] Restored previous config; trying restart...${NC}"
        restart_tunnel "$tunnel_name" || true
    fi
    sleep 3
    set -e
    return 1
}

ensure_boot_persistence() {
    shopt -s nullglob
    local files=("$INSTANCES_DIR"/*.conf)
    shopt -u nullglob
    local f n enabled=0 started=0

    create_boot_restore_service || true
    if systemctl enable jojonet-boot.service >/dev/null 2>&1; then
        echo -e "${GREEN}[+] jojonet-boot.service enabled for reboot.${NC}"
    fi

    for f in "${files[@]}"; do
        n=$(grep -E '^Name=' "$f" 2>/dev/null | head -1 | cut -d'"' -f2)
        [[ -n "$n" ]] || continue
        if ! systemctl is-enabled --quiet "$(tunnel_service_unit "$n")" 2>/dev/null; then
            systemctl enable "$(tunnel_service_unit "$n")" >/dev/null 2>&1 && enabled=$((enabled + 1))
        fi
        if ! systemctl is-active --quiet "$(tunnel_service_unit "$n")" 2>/dev/null; then
            systemctl start "$(tunnel_service_unit "$n")" >/dev/null 2>&1 && started=$((started + 1)) || true
        fi
    done
    echo -e "${GREEN}[+] Boot persistence OK.${NC} Enabled: $enabled | Started: $started"
    sleep 2
}

# ==========================================
# Instance management
# ==========================================

load_instance_config() {
    load_safe_config "$1"
}

normalize_port_list() {
    local raw="$1" part list normalized=()
    IFS=',' read -ra list <<< "$raw"
    for part in "${list[@]}"; do
        part="${part// /}"
        [[ -n "$part" ]] && normalized+=("$part")
    done
    (IFS=','; echo "${normalized[*]}")
}

show_tunnel_plan() {
    local name="$1" role="$2" local_ip="$3" remote_ip="$4" tun_ip="$5" tun_remote="$6" mtu="$7" ports="$8" gre_key="${9:-}"
    load_stealth_mode
    if [[ "$STEALTH_MODE" == "1" ]]; then
        return 0
    fi

    echo -e "\n${CYAN}========== Tunnel Plan${NC}"
    echo -e "${YELLOW}Commands equivalent to manual GRE setup:${NC}"

    echo ""
    if [[ -n "$gre_key" ]]; then
        echo "  ip tunnel add $name mode gre remote $remote_ip local $local_ip key $gre_key"
    else
        echo "  ip tunnel add $name mode gre remote $remote_ip local $local_ip"
    fi
    echo "  ip addr add $tun_ip dev $name"
    echo "  ip link set $name mtu $mtu"
    echo "  ip link set $name up"
    echo "  sysctl -w net.ipv4.ip_forward=1"
    echo "  sysctl -w net.ipv4.conf.$name.rp_filter=0"
    echo "  sysctl -w net.ipv4.conf.all.rp_filter=0"

    if [[ "$role" == "iran" ]]; then
        if [[ -n "$ports" && -n "$tun_remote" ]]; then
            IFS=',' read -ra _ports <<< "$ports"
            local p
            for p in "${_ports[@]}"; do
                p="${p// /}"
                [[ -n "$p" && "$p" =~ ^[0-9]+$ ]] || continue
                echo "  iptables -t nat -A PREROUTING -p tcp --dport $p -j DNAT --to-destination ${tun_remote}:$p"
            done
        else
            echo "  iptables -t nat -A PREROUTING -p tcp --dport 443 -j DNAT --to-destination ${tun_remote:-172.20.10.1}:443"
        fi
        echo "  iptables -t nat -A POSTROUTING -j MASQUERADE"
    fi
    echo -e "${CYAN}============================================${NC}\n"
}

rollback_new_tunnel() {
    local name="$1" conf="$2" unit="" mode=""
    mode=$(tunnel_mode_from_name "$name" 2>/dev/null || echo "gre")
    case "$mode" in
        tun_tcp)   unit="jojonet-tcptun@${name}.service" ;;
        paqet)     unit="jojonet-paqet@${name}.service" ;;
        vxlan)     unit="jojonet-vxlan@${name}.service" ;;
        wireguard) unit="jojonet-wg@${name}.service" ;;
        hysteria2) unit="jojonet-hy2@${name}.service" ;;
        rathole)   unit="jojonet-rathole@${name}.service" ;;
        *)         unit="jojonet@${name}.service" ;;
    esac
    echo -e "${RED}[*] Rolling back tunnel [$name]...${NC}"
    set +e
    systemctl stop "$unit" >/dev/null 2>&1
    systemctl disable "$unit" >/dev/null 2>&1
    systemctl reset-failed "$unit" >/dev/null 2>&1
    pkill -f "tun-server.*-device ${name}" >/dev/null 2>&1
    pkill -f "tun-client.*-device ${name}" >/dev/null 2>&1
    pkill -f "paqet run -c.*/${name}\\.yaml" >/dev/null 2>&1
    pkill -f "hysteria.*${name}" >/dev/null 2>&1
    pkill -f "rathole.*${name}\\.toml" >/dev/null 2>&1
    rm -f "$PAQET_CONFIG_DIR/${name}.yaml" >/dev/null 2>&1
    rm -f "$HY2_CONFIG_DIR/${name}.yaml" >/dev/null 2>&1
    rm -f "$RATHOLE_CONFIG_DIR/${name}.toml" >/dev/null 2>&1
    rm -f "$conf" "${conf}.tmp" >/dev/null 2>&1
    ip link delete "$name" >/dev/null 2>&1 || true
    nft delete table ip "jojonet_$name" >/dev/null 2>&1 || true
}

add_new_tunnel() {
    command -v clear >/dev/null && clear
    logo
    print_banner "Advanced GRE Setup"

    local INS_NAME="" CONF_FILE="" SERVER_ROLE="" LOC_IP="" REM_IP="" FWD_PORT=""
    local ROLE_CONF="" subnet_byte="" INS_TUN_IP="" INS_TUN_REMOTE_IP_RAW="" INS_MTU="" tmp_conf=""
    local DEFAULT_IFACE="" DETECTED_IP="" mtu_choice="" subnet_input="" existing=""

    if ! auto_detect_network; then
        echo -e "${RED}[!] Cannot detect primary network.${NC}"
        sleep 2
        return
    fi

    echo -e "\n${YELLOW}Detected public IP:${NC} ${CYAN}$DETECTED_IP${NC}"
    show_existing_tunnels_summary

    echo -e "\n${CYAN}Server role:${NC}"
        menu_line "1) Iran Server (Port Forwarder / DNAT)"
        menu_line "2) Foreign Server (GRE Gateway only)"
    read -r -p "Choose [1/2]: " SERVER_ROLE

    if [[ "$SERVER_ROLE" == "1" ]]; then
        ROLE_CONF="iran"
        read -r -p "Iran public IP (local) [$DETECTED_IP]: " LOC_IP
        LOC_IP=${LOC_IP:-$DETECTED_IP}
        if ! validate_ipv4 "$LOC_IP"; then
            echo -e "${RED}[!] Invalid Iran IP.${NC}"
            sleep 2; return
        fi

        read -r -p "Foreign public IP (remote peer): " REM_IP
        if [[ -z "$REM_IP" ]] || ! validate_ipv4 "$REM_IP"; then
            echo -e "${RED}[!] Invalid foreign IP.${NC}"
            sleep 2; return
        fi

        read -r -p "Ports to forward (e.g. 443, 80,443 or 1000-2000): " FWD_PORT
        if [[ -z "$FWD_PORT" ]] || ! validate_ports "$FWD_PORT"; then
            echo -e "${RED}[!] Invalid port format.${NC}"
            sleep 2; return
        fi
        FWD_PORT=$(normalize_port_list "$FWD_PORT")
    elif [[ "$SERVER_ROLE" == "2" ]]; then
        ROLE_CONF="kharej"
        FWD_PORT=""
        read -r -p "Foreign public IP (local) [$DETECTED_IP]: " LOC_IP
        LOC_IP=${LOC_IP:-$DETECTED_IP}
        if ! validate_ipv4 "$LOC_IP"; then
            echo -e "${RED}[!] Invalid foreign IP.${NC}"
            sleep 2; return
        fi

        read -r -p "Iran public IP (remote peer): " REM_IP
        if [[ -z "$REM_IP" ]] || ! validate_ipv4 "$REM_IP"; then
            echo -e "${RED}[!] Invalid Iran IP.${NC}"
            sleep 2; return
        fi
    else
        echo -e "${RED}[!] Invalid choice.${NC}"
        sleep 1; return
    fi

    if existing=$(find_tunnel_for_peer "$REM_IP"); then
        echo -e "${YELLOW}[!] Tunnel to $REM_IP exists as [$existing]. Use Manage menu to restart.${NC}"
        sleep 2; return
    fi

    local auto_subnet="" suggested_name=""
    auto_subnet=$(gre_subnet_for_pair "$LOC_IP" "$REM_IP")
    if gre_subnet_taken_locally "$auto_subnet" "$REM_IP"; then
        echo -e "${YELLOW}[!] Pair subnet $auto_subnet is already used locally by another GRE tunnel.${NC}"
        echo -e "${YELLOW}    Pick a free subnet ID (same on BOTH servers).${NC}"
    fi
    echo -e "\n${CYAN}Tunnel overlay:${NC} ${TUNNEL_NET_PREFIX}.X.1 (Kharej) ↔ .2 (Iran)"
    echo -e "${YELLOW}Auto for this peer pair: subnet ID ${auto_subnet}${NC}"
    read -r -p "Subnet ID [pair: $auto_subnet]: " subnet_input
    subnet_input=${subnet_input:-$auto_subnet}

    if ! validate_subnet_byte "$subnet_input"; then
        echo -e "${RED}[!] Subnet ID must be ${GRE_SUBNET_MIN}-${GRE_SUBNET_MAX}.${NC}"
        sleep 2; return
    fi
    subnet_byte=$subnet_input

    if gre_subnet_taken_locally "$subnet_byte" "$REM_IP"; then
        echo -e "${RED}[!] Subnet $subnet_byte already used by another peer on this server.${NC}"
        sleep 2; return
    fi

    suggested_name=$(generate_tunnel_name_from_peer "$REM_IP" "$ROLE_CONF" "gre" "$subnet_byte") || suggested="gre1"
    while true; do
        read -r -p "Tunnel interface name (unique) [$suggested_name]: " INS_NAME
        INS_NAME=${INS_NAME:-$suggested_name}
        if ! validate_interface_name "$INS_NAME"; then
            echo -e "${RED}[!] Invalid name (max 15 chars).${NC}"
            continue
        fi
        if [[ -f "$INSTANCES_DIR/$INS_NAME.conf" ]] || ip link show "$INS_NAME" >/dev/null 2>&1; then
            echo -e "${RED}[!] Name already in use — try another.${NC}"
            suggested=$(generate_tunnel_name_from_peer "$REM_IP" "$ROLE_CONF" "gre" "$subnet_byte") || true
            continue
        fi
        break
    done
    CONF_FILE="$INSTANCES_DIR/$INS_NAME.conf"

    if [[ "$ROLE_CONF" == "iran" ]]; then
        resolve_tunnel_ips "iran" "$subnet_byte" "gre"
        INS_TUN_IP="$Tun_IP"
        INS_TUN_REMOTE_IP_RAW="$Tun_Remote_IP_Raw"
    else
        resolve_tunnel_ips "kharej" "$subnet_byte" "gre"
        INS_TUN_IP="$Tun_IP"
        INS_TUN_REMOTE_IP_RAW=""
    fi

    echo -e "\n${CYAN}MTU settings${NC}"
        menu_line "1) Standard $DEFAULT_GRE_MTU (recommended, manual-compatible)"
        menu_line "2) Auto-detect from path"
    read -r -p "Choose [1/2, default 1]: " mtu_choice

    if [[ "$mtu_choice" == "2" ]]; then
        INS_MTU=$(calculate_mtu "$REM_IP")
        INS_MTU=$(clamp_mtu "$INS_MTU")
    else
        INS_MTU=$DEFAULT_GRE_MTU
    fi

    show_tunnel_plan "$INS_NAME" "$ROLE_CONF" "$LOC_IP" "$REM_IP" "$INS_TUN_IP" "$INS_TUN_REMOTE_IP_RAW" "$INS_MTU" "$FWD_PORT" ""

    read -r -p "Apply this configuration? [Y/n]: " confirm_apply
    confirm_apply=$(echo "$confirm_apply" | tr '[:upper:]' '[:lower:]')
    if [[ "$confirm_apply" == "n" ]]; then
        echo -e "${YELLOW}Cancelled.${NC}"
        sleep 1
        return
    fi

    if deploy_tunnel "$INS_NAME" "$ROLE_CONF" "$LOC_IP" "$REM_IP" "$subnet_byte" \
        "$INS_TUN_IP" "$INS_TUN_REMOTE_IP_RAW" "$INS_MTU" "$FWD_PORT" "gre" \
        "$DEFAULT_TCP_PORT" "" "$Tun_Server_IP" "$Tun_Client_IP"; then
        sleep 2
    else
        sleep 3
    fi
}

manage_tunnels() {
    while true; do
        command -v clear >/dev/null && clear
        logo
        print_banner "Manage Tunnels"

        shopt -s nullglob
        local conf_files=("$INSTANCES_DIR"/*.conf)
        shopt -u nullglob

        if (( ${#conf_files[@]} == 0 )); then
            echo -e "${RED}[!] No tunnels configured.${NC}"
            press_enter
            return
        fi

        list_all_tunnels 0 || true

        echo -e "${CYAN}Quick table:${NC}"
        printf "${BLUE}%-11s | %-6s | %-15s | %-15s | %-13s | %-7s | %-5s${NC}\n" \
            "Name" "Mode" "Iran IP" "Kharej IP" "Tunnel IP" "Status" "Ports"
        echo "----------------------------------------------------------------------------------------------------------------------------"

        local Name="" TunnelMode="" Role="" Local_IP="" Remote_IP="" Subnet_Byte=""
        local Tun_IP="" Tun_Remote_IP_Raw="" Suggested_MTU="" Ports="" TcpPort=""
        local PaqetYaml="" ForwardProto="" VxlanVni="" VxlanPort=""
        local WgPrivateKey="" WgPublicKey="" WgPeerPublicKey="" HyYaml="" HyAuth="" HySni="" HyHopRange="" HyHopInterval="" RatholeToml=""
        local Tun_Server_IP="" Tun_Client_IP="" KeyDir="" GreKey=""
        local file iran_ip kharej_ip

        for file in "${conf_files[@]}"; do
            if ! load_instance_config "$file"; then
                echo -e "${RED}[!] Invalid config: $file${NC}"
                continue
            fi
            resolve_iran_foreign_ips
            iran_ip="$TUNNEL_IRAN_IP"
            kharej_ip="$TUNNEL_KHAREJ_IP"

            local status_raw status_color st
            st=$(tunnel_status_word "$Name")
            case "$st" in
                UP)   status_raw="Active"; status_color="${GREEN}" ;;
                FAIL) status_raw="Failed"; status_color="${RED}" ;;
                *)    status_raw="Inactive"; status_color="${YELLOW}" ;;
            esac

            local mode_disp
            mode_disp=$(tunnel_mode_label "${TunnelMode:-gre}")

            local display_port="-"
            if [[ -n "${Ports:-}" ]]; then
                display_port="$Ports"
                ((${#display_port} > 10)) && display_port="${display_port:0:7}..."
            fi

            local base_tun_ip=""
            if [[ "${TunnelMode:-gre}" == "paqet" ]]; then
                base_tun_ip=":${TcpPort:-?}"
            elif [[ "${TunnelMode:-gre}" == "hysteria2" ]]; then
                base_tun_ip="udp:${TcpPort:-?}"
            elif [[ "${TunnelMode:-gre}" == "vxlan" ]]; then
                base_tun_ip=$(echo "${Tun_IP:-}" | awk -F'/' '{print $1}')
                [[ -n "${VxlanPort:-}" ]] && base_tun_ip="${base_tun_ip:-?}:udp${VxlanPort}"
            elif [[ -n "${Tun_IP:-}" ]]; then
                base_tun_ip=$(echo "$Tun_IP" | awk -F'/' '{print $1}')
            fi
            printf "%-11s | %-6s | %-15s | %-15s | %-13s | ${status_color}%-7s${NC} | %-5s\n" \
                "$Name" "$mode_disp" "$iran_ip" "$kharej_ip" "$base_tun_ip" "$status_raw" "$display_port"
        done

        echo ""
        menu_line "1) Full tunnel details (overview)"
        menu_line "2) Troubleshoot, Logs & Restart"
        menu_line "3) Restart ALL Tunnels"
        menu_line "4) Enable Boot Persistence"
        menu_line "5) Change peer IP (Iran ↔ Kharej)"
        menu_line "6) Delete Tunnel"
        menu_line "0) Back to Main Menu"
        echo ""

        local ins_choice
        read -r -p "Choice: " ins_choice || break

        case "$ins_choice" in
            1) show_tunnel_overview_menu ;;
            2)
                local TGT_NAME
                read -r -p "Tunnel name: " TGT_NAME
                local tgt_conf="$INSTANCES_DIR/$TGT_NAME.conf"

                if [[ -r "$tgt_conf" ]]; then
                    while true; do
                        command -v clear >/dev/null && clear
                        echo -e "${CYAN}Troubleshoot: $TGT_NAME${NC}"
                        menu_line "1) View logs (full menu)"
                        menu_line "2) Interface status (ip addr)"
                        menu_line "3) Firewall rules (nftables)"
                        menu_line "4) Restart this tunnel"
                        menu_line "5) Boot enabled? (systemctl)"
                        menu_line "0) Back"

                        local diag_choice
                        read -r -p "Choice: " diag_choice || break

                        case "$diag_choice" in
                            1) tunnel_logs_menu "$TGT_NAME" ;;
                            2)
                                if [[ "$(tunnel_mode_from_name "$TGT_NAME")" == "paqet" ]]; then
                                    echo -e "${CYAN}Paqet process (no TUN iface):${NC}"
                                    pgrep -af "paqet run" 2>/dev/null | grep "$TGT_NAME" || \
                                        echo -e "${YELLOW}No matching paqet process.${NC}"
                                elif ip link show "$TGT_NAME" >/dev/null 2>&1; then
                                    ip -c -d addr show dev "$TGT_NAME" || true
                                    ip -d link show dev "$TGT_NAME" || true
                                else
                                    echo -e "${RED}[!] Interface not found.${NC}"
                                fi
                                press_enter ;;
                            3)
                                if [[ "$(tunnel_mode_from_name "$TGT_NAME")" == "gre" ]] && \
                                    grep -q '^Role="iran"' "$tgt_conf" 2>/dev/null; then
                                    echo -e "${CYAN}iptables NAT (Iran GRE):${NC}"
                                    iptables -t nat -L PREROUTING -n -v 2>/dev/null | head -20 || true
                                    iptables -t nat -L POSTROUTING -n -v 2>/dev/null | head -10 || true
                                elif nft list table ip "jojonet_$TGT_NAME" >/dev/null 2>&1; then
                                    nft list table ip "jojonet_$TGT_NAME" || true
                                else
                                    echo -e "${YELLOW}No nft table (normal on Foreign server).${NC}"
                                fi
                                press_enter ;;
                            4) restart_tunnel "$TGT_NAME"; sleep 2 ;;
                            5)
                                systemctl is-enabled "$(tunnel_service_unit "$TGT_NAME")" 2>/dev/null || echo "disabled"
                                systemctl is-active "$(tunnel_service_unit "$TGT_NAME")" 2>/dev/null || echo "inactive"
                                press_enter ;;
                            0) break ;;
                            *) echo -e "${RED}Invalid.${NC}"; sleep 1 ;;
                        esac
                    done
                else
                    echo -e "${RED}[!] Tunnel not found.${NC}"
                    sleep 2
                fi
                ;;
            3) restart_all_tunnels ;;
            4) ensure_boot_persistence ;;
            5)
                local chg_name="" chg_peer=""
                read -r -p "Tunnel name to change peer: " chg_name
                read -r -p "New peer IP (Kharej on Iran / Iran on Kharej): " chg_peer
                change_tunnel_peer_ip "$chg_name" "$chg_peer" || true
                ;;
            6)
                local REM_NAME
                read -r -p "Tunnel name to delete: " REM_NAME
                local rem_conf="$INSTANCES_DIR/$REM_NAME.conf"

                if [[ -r "$rem_conf" ]]; then
                    read -r -p "Confirm delete [$REM_NAME]? [y/N]: " del_confirm
                    del_confirm=$(echo "$del_confirm" | tr '[:upper:]' '[:lower:]')
                    [[ "$del_confirm" == "y" ]] || continue

                    local partial_fail=0 svc=""
                    svc=$(tunnel_service_unit "$REM_NAME")
                    systemctl stop "$svc" >/dev/null 2>&1 || partial_fail=1
                    pkill -f "tun-server.*-device ${REM_NAME}" >/dev/null 2>&1 || true
                    pkill -f "tun-client.*-device ${REM_NAME}" >/dev/null 2>&1 || true
                    pkill -f "paqet run -c.*/${REM_NAME}\\.yaml" >/dev/null 2>&1 || true
                    pkill -f "hysteria.*${REM_NAME}" >/dev/null 2>&1 || true
                    pkill -f "rathole.*${REM_NAME}\\.toml" >/dev/null 2>&1 || true
                    rm -f "$PAQET_CONFIG_DIR/${REM_NAME}.yaml" 2>/dev/null || true
                    rm -f "$HY2_CONFIG_DIR/${REM_NAME}.yaml" 2>/dev/null || true
                    rm -f "$RATHOLE_CONFIG_DIR/${REM_NAME}.toml" 2>/dev/null || true
                    ip link show "$REM_NAME" >/dev/null 2>&1 && ip link delete "$REM_NAME" >/dev/null 2>&1 || true
                    nft list table ip "jojonet_$REM_NAME" >/dev/null 2>&1 && \
                        nft delete table ip "jojonet_$REM_NAME" >/dev/null 2>&1 || true
                    systemctl disable "$svc" >/dev/null 2>&1 || partial_fail=1
                    systemctl reset-failed "$svc" >/dev/null 2>&1 || true
                    # Capture keydir before removing conf
                    local keydir_del="" peer_del=""
                    keydir_del=$(grep -E '^KeyDir=' "$rem_conf" 2>/dev/null | head -1 | cut -d'"' -f2 || true)
                    peer_del=$(grep -E '^Remote_IP=' "$rem_conf" 2>/dev/null | head -1 | cut -d'"' -f2 || true)
                    rm -f "$rem_conf" || partial_fail=1
                    if [[ -n "$keydir_del" && -d "$keydir_del" ]]; then
                        # Remove keydir only if no other instance references it
                        if ! grep -Rql --include='*.conf' "KeyDir=\"$keydir_del\"" "$INSTANCES_DIR" 2>/dev/null; then
                            rm -rf "$keydir_del" 2>/dev/null || true
                            echo -e "${GREEN}[+] Removed unused keys: $keydir_del${NC}"
                        fi
                    fi

                    if (( partial_fail == 0 )); then
                        echo -e "${GREEN}[+] Deleted.${NC}"
                    else
                        echo -e "${YELLOW}[!] Partial delete - check logs.${NC}"
                    fi
                else
                    echo -e "${RED}[!] Tunnel not found.${NC}"
                fi
                sleep 3
                ;;
            0) return ;;
            *) echo -e "${RED}Invalid.${NC}"; sleep 1 ;;
        esac
    done
}

show_live_status() {
    command -v clear >/dev/null && clear
    logo
        echo -e "${CYAN}=== Network Status ===${NC}"

    local default_iface local_ip bbr_state tables
    default_iface=$(ip route get 1.1.1.1 2>/dev/null | awk 'NR==1 {print $5}')
    if [[ -z "$default_iface" ]]; then
        echo -e "${RED}[!] Default interface not found.${NC}"
        press_enter
        return
    fi

    local_ip=$(ip -o -4 addr show dev "$default_iface" 2>/dev/null | awk '{print $4}' || true)
    [[ -z "$local_ip" ]] && local_ip="Unknown"

    echo -e "${YELLOW}Default iface:${NC} $default_iface ($local_ip)"
    bbr_state=$(sysctl -n net.ipv4.tcp_congestion_control 2>/dev/null || echo "N/A")
    echo -e "${YELLOW}TCP congestion:${NC} ${GREEN}$bbr_state${NC}"
    local fwd
    fwd=$(sysctl -n net.ipv4.ip_forward 2>/dev/null || echo "0")
    echo -e "${YELLOW}ip_forward:${NC} $fwd"

    echo -e "\n${CYAN}=== Boot Services ===${NC}"
    if systemctl is-enabled jojonet-boot.service >/dev/null 2>&1; then
        echo -e "${GREEN}jojonet-boot.service: enabled${NC}"
    else
        echo -e "${YELLOW}jojonet-boot.service: not enabled (use Manage -> Boot Persistence)${NC}"
    fi

    echo -e "\n${CYAN}=== GRE Tunnels ===${NC}"
    if ip -d link show type gre >/dev/null 2>&1; then
        ip -c -d addr show type gre 2>/dev/null || echo "No GRE interfaces."
    else
        echo "No GRE tunnel loaded."
    fi

    echo -e "\n${CYAN}=== nftables (jojonet_*) ===${NC}"
    if tables=$(nft list tables 2>/dev/null | grep '^table ip jojonet_'); then
        [[ -n "$tables" ]] && echo "$tables" || echo "No jojonet firewall tables."
    else
        echo "No jojonet firewall tables."
    fi

    echo -e "\n${CYAN}=== VXLAN Tunnels ===${NC}"
    if ip -d link show type vxlan >/dev/null 2>&1; then
        ip -c -d addr show type vxlan 2>/dev/null || echo "No VXLAN interfaces."
    else
        echo "No VXLAN tunnel loaded."
    fi

    echo -e "\n${CYAN}=== Paqet Tunnels ===${NC}"
    if pgrep -af "paqet run" >/dev/null 2>&1; then
        pgrep -af "paqet run" 2>/dev/null || true
    else
        echo "No Paqet process running."
    fi

    press_enter
}

# Logo glyphs: each letter fixed-width so J O J O NET never overlaps
_logo_glyph() {
    local ch="$1" row="$2"
    case "$ch" in
        J)
            case "$row" in
                0) printf '%-8s' '   ██╗  ' ;;
                1) printf '%-8s' '   ██║  ' ;;
                2) printf '%-8s' '   ██║  ' ;;
                3) printf '%-8s' '   ██║  ' ;;
                4) printf '%-8s' '█ ██║  ' ;;
                5) printf '%-8s' ' ███╔╝ ' ;;
            esac
            ;;
        O)
            case "$row" in
                0) printf '%-9s' ' ██████╗ ' ;;
                1) printf '%-9s' '██╔═══██╗' ;;
                2) printf '%-9s' '██║   ██║' ;;
                3) printf '%-9s' '██║   ██║' ;;
                4) printf '%-9s' '╚██████╔╝' ;;
                5) printf '%-9s' ' ╚═════╝ ' ;;
            esac
            ;;
        N)
            case "$row" in
                0) printf '%-10s' '███╗   ██╗' ;;
                1) printf '%-10s' '████╗  ██║' ;;
                2) printf '%-10s' '██╔██╗ ██║' ;;
                3) printf '%-10s' '██║╚██╗██║' ;;
                4) printf '%-10s' '██║ ╚████║' ;;
                5) printf '%-10s' '╚═╝  ╚═══╝' ;;
            esac
            ;;
        E)
            case "$row" in
                0) printf '%-9s' '███████╗ ' ;;
                1) printf '%-9s' '██╔════╝ ' ;;
                2) printf '%-9s' '█████╗   ' ;;
                3) printf '%-9s' '██╔══╝   ' ;;
                4) printf '%-9s' '███████╗ ' ;;
                5) printf '%-9s' '╚══════╝ ' ;;
            esac
            ;;
        T)
            case "$row" in
                0) printf '%-9s' '████████╗' ;;
                1) printf '%-9s' '╚══██╔══╝' ;;
                2) printf '%-9s' '   ██║   ' ;;
                3) printf '%-9s' '   ██║   ' ;;
                4) printf '%-9s' '   ██║   ' ;;
                5) printf '%-9s' '   ╚═╝   ' ;;
            esac
            ;;
    esac
}

_logo_art_row() {
    local row="$1"
    _logo_glyph J "$row"
    printf '     '   # gap between J O J O
    _logo_glyph O "$row"
    printf '     '
    _logo_glyph J "$row"
    printf '     '
    _logo_glyph O "$row"
    printf '    '    # gap before NET
    _logo_glyph N "$row"
    printf ' '
    _logo_glyph E "$row"
    printf ' '
    _logo_glyph T "$row"
    echo
}

_logo_box_edge() {
    local kind="$1" inner_w="$2"
    local bar="" end i
    for (( i=0; i<inner_w + 4; i++ )); do bar+='═'; done
    [[ "$kind" == '╔' ]] && end='╗' || end='╝'
    echo -e "${CYAN}  ${kind}${bar}${end}${NC}"
}

_logo_box_blank() {
    local inner_w="$1"
    printf "${CYAN}  ║${NC}%*s${CYAN}║${NC}\n" "$((inner_w + 4))" ""
}

logo() {
    [[ -t 1 ]] || return 0

    local -a art=()
    local row len inner_w=0 left right sub sup

    for row in 0 1 2 3 4 5; do
        art[$row]=$(_logo_art_row "$row")
        len=${#art[$row]}
        (( len > inner_w )) && inner_w=$len
    done

    echo ""
    _logo_box_edge '╔' "$inner_w"
    _logo_box_blank "$inner_w"

    for row in "${art[@]}"; do
        printf "${CYAN}  ║${NC}  ${YELLOW}%-*s${NC}  ${CYAN}║${NC}\n" "$inner_w" "$row"
    done

    _logo_box_blank "$inner_w"

    sub="v${JOJONET_VERSION}  |  Iran ↔ Foreign Tunnel Manager"
    left=$(( (inner_w - ${#sub}) / 2 ))
    right=$(( inner_w - ${#sub} - left ))
    printf "${CYAN}  ║${NC}  %*s${BLUE}v${JOJONET_VERSION}${NC}  ${MAGENTA}|${NC}  Iran ↔ Foreign Tunnel Manager%*s  ${CYAN}║${NC}\n" \
        "$left" "" "$right" ""

    sup="Support: ${JOJONET_SUPPORT}"
    left=$(( (inner_w - ${#sup}) / 2 ))
    right=$(( inner_w - ${#sup} - left ))
    printf "${CYAN}  ║${NC}  %*s${GREEN}Support:${NC} ${JOJONET_SUPPORT}%*s  ${CYAN}║${NC}\n" \
        "$left" "" "$right" ""

    _logo_box_blank "$inner_w"
    _logo_box_edge '╚' "$inner_w"
    echo ""
}

