# OpSec: quiet output + shell history cleanup
# ==========================================

load_stealth_mode() {
    STEALTH_MODE=0
    if [[ "${JOJONET_STEALTH:-0}" == "1" ]]; then
        STEALTH_MODE=1
    fi
    if [[ -f "$STEALTH_FLAG_FILE" ]]; then
        STEALTH_MODE=1
    fi
}

opsec_session_start() {
    load_stealth_mode
    if [[ "$STEALTH_MODE" == "1" ]]; then
        export HISTCONTROL="${HISTCONTROL:-ignorespace}"
        set +o history 2>/dev/null || true
    fi
}

opsec_scrub_history() {
    if [[ "${JOJONET_CLEAR_HISTORY:-1}" == "0" ]]; then
        return 0
    fi
    local histfile="" f
    for f in "${HISTFILE:-}" "/root/.bash_history" "$HOME/.bash_history"; do
        if [[ -n "$f" && -f "$f" && -w "$f" ]]; then
            histfile="$f"
            break
        fi
    done
    [[ -n "$histfile" ]] || return 0
    sed -i \
        -e '/jojonet/d' \
        -e '/ip tunnel/d' \
        -e '/tun-server/d' \
        -e '/tun-client/d' \
        -e '/nft.*jojonet/d' \
        -e '/GRETun/d' \
        -e '/LocalTun/d' \
        -e '/jojonet-run/d' \
        -e '/paqet/d' \
        -e '/vxlan/d' \
        "$histfile" 2>/dev/null || true
    history -c 2>/dev/null || true
    history -w 2>/dev/null || true
}

toggle_stealth_mode() {
    if [[ -f "$STEALTH_FLAG_FILE" ]]; then
        rm -f "$STEALTH_FLAG_FILE"
        STEALTH_MODE=0
        echo -e "${GREEN}[+] Stealth mode OFF${NC}"
    else
        touch "$STEALTH_FLAG_FILE"
        chmod 600 "$STEALTH_FLAG_FILE"
        STEALTH_MODE=1
        echo -e "${GREEN}[+] Stealth mode ON${NC}"
        echo "  - Quiet output (no command dumps)"
        echo "  - Obscure interface names"
        echo "  - Shell history scrub on exit"
    fi
    sleep 2
}

generate_stealth_tunnel_name() {
    local peer="$1" role="$2" mode="${3:-gre}" h
    h=$(compute_gre_key "$peer" "jojonet-stealth-${role}-${mode}")
    printf 'jx%x' $(( h % 16777215 ))
}

