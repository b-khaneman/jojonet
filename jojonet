quick_add_tunnel_rathole() {
    local peer_ip="${1:-}"
    local ins_name="" role_conf="" loc_ip="" rem_ip=""
    local fwd_port="$DEFAULT_RATHOLE_FWD" key_dir="" ctrl_port="$DEFAULT_RATHOLE_CTRL_PORT"
    local existing="" rh_toml=""

    set +e
    command -v clear >/dev/null && clear
    logo
    print_banner "Rathole Reverse Tunnel (TCP)"

    echo -e "${CYAN}How it works:${NC}"
    echo -e "  Iran   = rathole ${GREEN}SERVER${NC} (users hit Iran ports)"
    echo -e "  Kharej = rathole ${GREEN}CLIENT${NC} (dials Iran, exposes local panel)"
    echo -e "  Good when GRE/UDP is blocked but TCP reverse works."
    echo ""

    install_rathole_binary || { sleep 2; set -e; return 1; }
    install -d -m700 "$RATHOLE_CONFIG_DIR"

    if ! auto_detect_network; then
        echo -e "${RED}[!] Cannot detect network.${NC}"
        sleep 2; set -e; return 1
    fi
    loc_ip="$DETECTED_IP"
    show_existing_tunnels_summary

    if [[ -z "$peer_ip" ]]; then
        read -r -p "Peer server IP: " peer_ip
    fi
    peer_ip="${peer_ip// /}"
    if ! validate_ipv4 "$peer_ip"; then
        echo -e "${RED}[!] Invalid peer IP.${NC}"
        sleep 2; set -e; return 1
    fi
    rem_ip="$peer_ip"

    if existing=$(find_tunnel_for_peer "$rem_ip" "rathole"); then
        echo -e "${YELLOW}[!] Rathole to $rem_ip exists [$existing]. Restarting...${NC}"
        restart_tunnel "$existing"
        sleep 2; set -e; return $?
    fi

    if ! role_conf=$(resolve_server_role "$loc_ip"); then
        echo -e "${RED}[!] Role required. Set JOJONET_ROLE=iran|kharej${NC}"
        sleep 2; set -e; return 1
    fi
    echo -e "${GREEN}[*] Role:${NC} $role_conf ($([[ "$role_conf" == "iran" ]] && echo SERVER || echo CLIENT))"

    ins_name=$(allocate_tunnel_name "$rem_ip" "$role_conf" "rathole") || { set -e; return 1; }

    read -r -p "Control port (Kharej→Iran dial) [$ctrl_port]: " _cp
    ctrl_port=${_cp:-$ctrl_port}
    if ! [[ "$ctrl_port" =~ ^[0-9]+$ ]] || (( ctrl_port < 1 || ctrl_port > 65535 )); then
        echo -e "${RED}[!] Invalid control port.${NC}"
        sleep 2; set -e; return 1
    fi

    if [[ "$role_conf" == "iran" ]]; then
        fwd_port=$(allocate_iran_forward_port "443")
        read -r -p "Public forward ports on Iran [$fwd_port]: " _fp
        fwd_port=${_fp:-$fwd_port}
        fwd_port=$(normalize_port_list "$fwd_port")
    else
        read -r -p "Local panel ports on Kharej (must match Iran) [$fwd_port]: " _fp
        fwd_port=${_fp:-$fwd_port}
        fwd_port=$(normalize_port_list "$fwd_port")
    fi

    local pair_id
    pair_id=$(printf '%s' "$rem_ip" | tr '.' '_')
    key_dir=$(ensure_rathole_token "$pair_id" "$rem_ip") || { set -e; return 1; }

    echo -e "\n${CYAN}--- Rathole plan ---${NC}"
    echo -e "  Name:     $ins_name"
    echo -e "  Role:     $role_conf ($([[ "$role_conf" == "iran" ]] && echo server || echo client))"
    echo -e "  Peer:     $rem_ip"
    echo -e "  Control:  TCP $ctrl_port"
    echo -e "  Forward:  $fwd_port"
    echo -e "  Token:    $key_dir/rathole.token"
    if [[ "$role_conf" == "iran" ]]; then
        hint "Kharej must dial this Iran IP on TCP $ctrl_port — open firewall if needed"
        hint "Now run on Kharej: sudo jojonet --rathole $loc_ip"
    else
        hint "Panel must listen on 127.0.0.1 (or all) for ports: $fwd_port"
        hint "Iran must already be running rathole server"
    fi
    echo ""

    if deploy_tunnel "$ins_name" "$role_conf" "$loc_ip" "$rem_ip" "0" \
        "" "" "0" "$fwd_port" "rathole" "$ctrl_port" "$key_dir" \
        "" "" "tcp"; then
        echo -e "${GREEN}[+] Rathole [$ins_name] is up.${NC}"
        [[ "$role_conf" == "iran" ]] && hint "Run on Kharej: sudo jojonet --rathole $loc_ip"
        sleep 2
        set -e
        return 0
    fi
    sleep 3
    set -e
    return 1
}


