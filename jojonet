    while true; do
        command -v clear >/dev/null && clear
        logo
        menu_line "1) Quick GRE Tunnel"
        menu_line "2) TUN/PrivateIP/TCP (Backhaul-style)"
        menu_line "3) Paqet Tunnel (Raw/KCP)"
        menu_line "4) VXLAN Tunnel (UDP overlay)"
