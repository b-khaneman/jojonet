        if ! [[ "$Suggested_MTU" =~ ^[0-9]+$ ]]; then Suggested_MTU=$DEFAULT_GRE_MTU; fi
        (( Suggested_MTU < 576 )) && Suggested_MTU=$DEFAULT_GRE_MTU
        (( Suggested_MTU > 9000 )) && Suggested_MTU=$DEFAULT_GRE_MTU

        log "ip link set $Name mtu $Suggested_MTU && up"
        ip link set "$Name" mtu "$Suggested_MTU"
        ip link set "$Name" up || { log "ERROR: interface up failed"; exit 1; }

        log "sysctl net.ipv4.ip_forward=1"
        sysctl -w net.ipv4.ip_forward=1 >/dev/null 2>&1 || true
        sysctl -w "net.ipv4.conf.${Name}.rp_filter=0" >/dev/null 2>&1 || true
        DEFAULT_IFACE=$(ip route get 1.1.1.1 2>/dev/null | awk 'NR==1 {print $5}')
        [[ -n "$DEFAULT_IFACE" ]] && sysctl -w "net.ipv4.conf.${DEFAULT_IFACE}.rp_filter=0" >/dev/null 2>&1 || true
        sysctl -w net.ipv4.conf.all.rp_filter=0 >/dev/null 2>&1 || true
        sysctl -w net.ipv4.conf.default.rp_filter=0 >/dev/null 2>&1 || true

        if ! ip link show "$Name" 2>/dev/null | grep -qE '<.*UP.*>|state UP'; then
            log "ERROR: interface not in UP state after start"
            exit 1
        fi

        if [[ "$Role" == "iran" ]]; then
            log "Iran: iptables DNAT + MASQUERADE (panel forward)"
            [[ -n "$Tun_Remote_IP_Raw" ]] || { log "ERROR: remote tunnel IP missing"; exit 1; }
            command -v iptables >/dev/null 2>&1 || { log "ERROR: iptables required on Iran"; exit 1; }

            _ports="${Ports:-443}"
            IFS=',' read -ra PORT_LIST <<< "$_ports"
            for p in "${PORT_LIST[@]}"; do
                p="${p// /}"
                [[ -n "$p" && "$p" =~ ^[0-9]+$ ]] || continue
                log "iptables DNAT tcp/$p -> ${Tun_Remote_IP_Raw}:$p"
                iptables -t nat -C PREROUTING -p tcp --dport "$p" \
                    -j DNAT --to-destination "${Tun_Remote_IP_Raw}:$p" 2>/dev/null || \
                    iptables -t nat -A PREROUTING -p tcp --dport "$p" \
                    -j DNAT --to-destination "${Tun_Remote_IP_Raw}:$p" \
                    || { log "ERROR: iptables DNAT failed for port $p"; exit 1; }
            done

            log "iptables -t nat -A POSTROUTING -j MASQUERADE"
            iptables -t nat -C POSTROUTING -j MASQUERADE 2>/dev/null || \
                iptables -t nat -A POSTROUTING -j MASQUERADE \
                || { log "ERROR: iptables MASQUERADE failed"; exit 1; }
