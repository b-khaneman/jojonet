# ==========================================
# OpSec: quiet output + shell history cleanup
# ==========================================

load_stealth_mode() {
    STEALTH_MODE=0
    if [[ "${JOJONET_STEALTH:-0}" == "1" ]]; then
        STEALTH_MODE=1
    fi
    if [[ -f "$STEALTH_FLAG_FILE" ]]; then
        STEALTH_MODE=1
    fi
}

opsec_session_start() {
    load_stealth_mode
    if [[ "$STEALTH_MODE" == "1" ]]; then
        export HISTCONTROL="${HISTCONTROL:-ignorespace}"
        set +o history 2>/dev/null || true
    fi
}

opsec_scrub_history() {
    if [[ "${JOJONET_CLEAR_HISTORY:-1}" == "0" ]]; then
        return 0
    fi
    local histfile="" f
    for f in "${HISTFILE:-}" "/root/.bash_history" "$HOME/.bash_history"; do
        if [[ -n "$f" && -f "$f" && -w "$f" ]]; then
            histfile="$f"
            break
        fi
    done
    [[ -n "$histfile" ]] || return 0
    sed -i \
        -e '/jojonet/d' \
        -e '/ip tunnel/d' \
        -e '/tun-server/d' \
        -e '/tun-client/d' \
        -e '/nft.*jojonet/d' \
        -e '/GRETun/d' \
        -e '/LocalTun/d' \
        -e '/jojonet-run/d' \
        -e '/paqet/d' \
        -e '/vxlan/d' \
        "$histfile" 2>/dev/null || true
    history -c 2>/dev/null || true
    history -w 2>/dev/null || true
}

toggle_stealth_mode() {
    if [[ -f "$STEALTH_FLAG_FILE" ]]; then
        rm -f "$STEALTH_FLAG_FILE"
        STEALTH_MODE=0
        echo -e "${GREEN}[+] Stealth mode OFF${NC}"
    else
        touch "$STEALTH_FLAG_FILE"
        chmod 600 "$STEALTH_FLAG_FILE"
        STEALTH_MODE=1
        echo -e "${GREEN}[+] Stealth mode ON${NC}"
        echo "  - Quiet output (no command dumps)"
        echo "  - Obscure interface names"
        echo "  - Shell history scrub on exit"
    fi
    sleep 2
}

generate_stealth_tunnel_name() {
    local peer="$1" role="$2" mode="${3:-gre}" h
    h=$(compute_gre_key "$peer" "jojonet-stealth-${role}-${mode}")
    printf 'jx%x' $(( h % 16777215 ))
}

opsec_session_start
trap 'opsec_scrub_history' EXIT

# ==========================================
# Core network helpers
# ==========================================

validate_interface_name() {
    [[ "$1" =~ ^[a-zA-Z0-9]([a-zA-Z0-9_-]{0,13}[a-zA-Z0-9])?$ ]] || return 1
}

validate_ipv4() {
    local ip="$1"
    [[ "$ip" =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}$ ]] || return 1

    local a b c d
    IFS='.' read -r a b c d <<< "$ip"

    local i
    for i in $a $b $c $d; do
        (( i <= 255 )) || return 1
    done

    (( a > 0 && a < 224 && a != 127 )) || return 1

    if [[ "$ip" =~ ^10\. || "$ip" =~ ^192\.168\. || "$ip" =~ ^172\.(1[6-9]|2[0-9]|3[0-1])\. ]]; then
        return 1
    fi
    return 0
}

validate_subnet_byte() {
    [[ "$1" =~ ^[0-9]+$ ]] || return 1
    (( "$1" >= 1 && "$1" <= 250 ))
}

validate_ports() {
    local part list
    IFS=',' read -ra list <<< "$1"

    for part in "${list[@]}"; do
        part="${part// /}"
        [[ -n "$part" ]] || return 1
        if [[ "$part" =~ ^([0-9]{1,5})$ ]]; then
            (( part >= 1 && part <= 65535 )) || return 1
        elif [[ "$part" =~ ^([0-9]{1,5})-([0-9]{1,5})$ ]]; then
            local a="${BASH_REMATCH[1]}"
            local b="${BASH_REMATCH[2]}"
            (( a >= 1 && a <= 65535 )) || return 1
            (( b >= 1 && b <= 65535 )) || return 1
            (( a <= b )) || return 1
        else
            return 1
        fi
    done
    return 0
}

auto_detect_network() {
    DEFAULT_IFACE=$(ip route get 1.1.1.1 2>/dev/null | awk 'NR==1 {print $5}')
    if [[ -z "$DEFAULT_IFACE" ]]; then
        echo -e "${RED}[!] Default interface not found.${NC}" >&2
        return 1
    fi

    DETECTED_IP=$(ip -4 -o addr show dev "$DEFAULT_IFACE" 2>/dev/null | awk '{print $4}' | cut -d/ -f1 || true)
    if [[ -z "$DETECTED_IP" ]]; then
        echo -e "${RED}[!] No IPv4 on $DEFAULT_IFACE.${NC}" >&2
        return 1
    fi
}

calculate_mtu() {
    local target="${1:-1.1.1.1}"
    local min=1200 max=1472 size best=0

    echo -e "${YELLOW}[*] Probing path MTU via ping to $target...${NC}" >&2

    while (( min <= max )); do
        size=$(( (min + max) / 2 ))
        if ping -M do -c1 -W2 -s "$size" "$target" >/dev/null 2>&1; then
            best=$size
            min=$(( size + 1 ))
        else
            max=$(( size - 1 ))
        fi
    done

    if (( best == 0 )); then
        echo "$DEFAULT_MTU_FALLBACK"
        return
    fi

    # GRE overhead: IP(20) + GRE(24) vs ICMP probe size
    local mtu=$(( best + 28 - 24 ))
    (( mtu > 1500 )) && mtu=1500
    if (( mtu < 1280 )); then
        mtu=$DEFAULT_MTU_FALLBACK
    fi
    # Prefer stable 1310 when probe is close (common GRE setup)
    if (( mtu > DEFAULT_MTU_FALLBACK )); then
        mtu=$DEFAULT_MTU_FALLBACK
    fi
    echo "$mtu"
}

generate_unique_subnet() {
    touch "$LOCK_FILE" 2>/dev/null || true
    exec 200>"$LOCK_FILE"
    flock -x 200

    local used=""
    shopt -s nullglob
    local conf_files=("$INSTANCES_DIR"/*.conf)
    shopt -u nullglob

    if (( ${#conf_files[@]} > 0 )); then
        used=$(awk -F'"' '/Subnet_Byte/ {print $2}' "${conf_files[@]}" 2>/dev/null || true)
    fi

    local byte
    for byte in $(seq 1 250); do
        if ! grep -qx "$byte" <<< "$used" 2>/dev/null; then
            echo "$byte"
            flock -u 200
            exec 200>&-
            return
        fi
    done

    flock -u 200
    exec 200>&-
    echo 0
}

subnet_byte_in_use() {
    local byte="$1"
    shopt -s nullglob
    local files=("$INSTANCES_DIR"/*.conf)
    shopt -u nullglob
    (( ${#files[@]} > 0 )) || return 1
    awk -F'"' -v b="$byte" '$0 ~ /Subnet_Byte/ && $2 == b { found=1 } END { exit !found }' "${files[@]}"
}

apply_global_sysctl() {
    if [[ ! -f "$SYSCTL_FILE" ]]; then
        echo -e "${YELLOW}[*] Applying global network tuning (BBR + forwarding)...${NC}"
        cat <<EOF > "$SYSCTL_FILE"
# JojoNet network profile (v1.1+)
# rp_filter is NOT disabled globally anymore (anti-spoofing preserved).
# GRE/VXLAN runners set rp_filter=0 only on the tunnel interface when needed.
net.core.default_qdisc=fq
net.ipv4.tcp_congestion_control=bbr
net.ipv4.ip_forward=1
net.ipv4.tcp_fastopen=3
net.core.rmem_max=67108864
net.core.wmem_max=67108864
net.core.netdev_max_backlog=250000
net.core.somaxconn=65535
net.ipv4.tcp_max_syn_backlog=65535
net.ipv4.ip_local_port_range=1024 65535
net.ipv4.tcp_fin_timeout=15
fs.file-max=2097152
EOF
        if [[ "${JOJONET_DISABLE_RP_FILTER:-0}" == "1" ]]; then
            cat <<EOF >> "$SYSCTL_FILE"
# Explicitly requested via JOJONET_DISABLE_RP_FILTER=1
net.ipv4.conf.all.rp_filter=0
net.ipv4.conf.default.rp_filter=0
EOF
        fi
        sysctl --system >/dev/null 2>&1 || true
    fi
    sysctl -w net.ipv4.ip_forward=1 >/dev/null 2>&1 || true
    if [[ "${JOJONET_DISABLE_RP_FILTER:-0}" == "1" ]]; then
        # Prefer interface-scoped rp_filter disable (keeps global anti-spoofing)
        # Fallback to global only if JOJONET_DISABLE_RP_FILTER=1
        if [[ "${JOJONET_DISABLE_RP_FILTER:-0}" == "1" ]]; then
            sysctl -w net.ipv4.conf.all.rp_filter=0 >/dev/null 2>&1 || true
            sysctl -w net.ipv4.conf.default.rp_filter=0 >/dev/null 2>&1 || true
        fi
    fi
}

clamp_mtu() {
    local mtu="$1"
    if ! [[ "$mtu" =~ ^[0-9]+$ ]]; then
        echo "$DEFAULT_MTU_FALLBACK"
        return
    fi
    (( mtu < 576 )) && mtu=$DEFAULT_MTU_FALLBACK
    (( mtu > 9000 )) && mtu=$DEFAULT_MTU_FALLBACK
    echo "$mtu"
}

ipv4_to_uint() {
    local a b c d
    IFS='.' read -r a b c d <<< "$1"
    echo $(( (a << 24) + (b << 16) + (c << 8) + d ))
}

# Same subnet on both servers — derived from the IP pair (no manual Subnet ID)
compute_pair_subnet_byte() {
    local ip1="$1" ip2="$2" u1 u2 key h
    u1=$(ipv4_to_uint "$ip1")
    u2=$(ipv4_to_uint "$ip2")
    if (( u1 < u2 )); then
        key="${ip1}|${ip2}"
    else
        key="${ip2}|${ip1}"
    fi
    if command -v cksum >/dev/null 2>&1; then
        h=$(printf '%s' "$key" | cksum | awk '{print $1}')
    elif command -v md5sum >/dev/null 2>&1; then
        h=$(( 16#$(printf '%s' "$key" | md5sum | awk '{print $1}' | cut -c1-7) ))
    else
        h=$(( u1 ^ u2 ))
    fi
    echo $(( (h % 250) + 1 ))
}

# Unique GRE key per IP pair (required for multiple GRE tunnels on one server)
compute_gre_key() {
    local ip1="$1" ip2="$2" u1 u2 pair h
    u1=$(ipv4_to_uint "$ip1")
    u2=$(ipv4_to_uint "$ip2")
    if (( u1 < u2 )); then
        pair="${ip1}|${ip2}"
    else
        pair="${ip2}|${ip1}"
    fi
    if command -v cksum >/dev/null 2>&1; then
        h=$(printf '%s' "$pair" | cksum | awk '{print $1}')
    elif command -v md5sum >/dev/null 2>&1; then
        h=$(( 16#$(printf '%s' "$pair" | md5sum | awk '{print $1}' | cut -c1-7) ))
    else
        h=$(( u1 ^ u2 ))
    fi
    h=$(( (h % 2147483646) + 1 ))
    echo "$h"
}

# Unique VXLAN VNI per IP pair (1..16777215)
compute_vxlan_vni() {
    local vni
    vni=$(compute_gre_key "$1" "$2")
    (( vni > 16777215 )) && vni=$(( vni % 16777214 + 1 ))
    echo "$vni"
}

detect_server_role() {
    local ip="$1" cc=""
    if command -v curl >/dev/null 2>&1; then
        cc=$(curl -fsSL --max-time 8 "https://ip-api.com/json/${ip}?fields=countryCode" 2>/dev/null \
            | grep -oE '"countryCode":"[A-Z]{2}"' | head -1 | cut -d'"' -f4 || true)
    fi
    if [[ "$cc" == "IR" ]]; then
        printf '%s' "iran"
        return 0
    elif [[ -n "$cc" ]]; then
        printf '%s' "kharej"
        return 0
    fi
    return 1
}

prompt_server_role() {
    local choice=""
    log_warn "Could not auto-detect server country."
    echo -e "  ${GREEN}1)${NC} Iran (Port Forwarder)" >&2
    echo -e "  ${GREEN}2)${NC} Foreign (Gateway only)" >&2
    read -r -p "Choose [1/2]: " choice </dev/tty
    case "$choice" in
        1) printf '%s' "iran" ;;
        2) printf '%s' "kharej" ;;
        *) return 1 ;;
    esac
}

find_tunnel_for_peer() {
    local peer="$1" want_mode="${2:-}" f n r m
    shopt -s nullglob
    local files=("$INSTANCES_DIR"/*.conf)
    shopt -u nullglob
    for f in "${files[@]}"; do
        n=$(grep -E '^Name=' "$f" 2>/dev/null | head -1 | cut -d'"' -f2)
        r=$(grep -E '^Remote_IP=' "$f" 2>/dev/null | head -1 | cut -d'"' -f2)
        m=$(grep -E '^TunnelMode=' "$f" 2>/dev/null | head -1 | cut -d'"' -f2)
        m=${m:-gre}
        if [[ -n "$n" && "$r" == "$peer" ]]; then
            if [[ -n "$want_mode" && "$m" != "$want_mode" ]]; then
                continue
            fi
            echo "$n"
            return 0
        fi
    done
    return 1
}

tunnel_name_taken() {
    local name="$1"
    if [[ -f "$INSTANCES_DIR/$name.conf" ]]; then
        return 0
    fi
    ip link show "$name" >/dev/null 2>&1
}

generate_unique_tunnel_name() {
    local base="$1" candidate="" i max_base
    if ! tunnel_name_taken "$base"; then
        echo "$base"
        return 0
    fi
    for i in $(seq 2 99); do
        max_base=$((15 - ${#i}))
        (( max_base < 1 )) && max_base=1
        candidate="${base:0:max_base}${i}"
        if ! tunnel_name_taken "$candidate"; then
            echo "$candidate"
            return 0
        fi
    done
    return 1
}

# Unique interface per peer — e.g. ir195158230128 (foreign) / kh575200210 (iran)
generate_tunnel_name_from_peer() {
    local peer="$1" role="$2" mode="${3:-gre}"
    local digits prefix base
    digits=$(echo "$peer" | tr -d '.')
    if [[ "$mode" == "tun_tcp" ]]; then
        prefix="tc"
    elif [[ "$mode" == "paqet" ]]; then
        prefix="pq"
    elif [[ "$mode" == "vxlan" ]]; then
        prefix="vx"
    elif [[ "$mode" == "wireguard" ]]; then
        prefix="wg"
    elif [[ "$mode" == "hysteria2" ]]; then
        prefix="hy"
    elif [[ "$role" == "kharej" ]]; then
        prefix="ir"
    else
        prefix="kh"
    fi
    base="${prefix}${digits}"
    if (( ${#base} > 15 )); then
        base="${prefix}${digits: -$((15 - ${#prefix}))}"
    fi
    generate_unique_tunnel_name "$base"
}

any_gre_present() {
    ip -o link show type gre 2>/dev/null | grep -q .
}

allocate_tunnel_name() {
    local peer="$1" role="$2" mode="${3:-gre}" base=""
    load_stealth_mode
    if [[ "$STEALTH_MODE" == "1" ]]; then
        base=$(generate_stealth_tunnel_name "$peer" "$role" "$mode")
        generate_unique_tunnel_name "$base"
        return 0
    fi
    generate_tunnel_name_from_peer "$peer" "$role" "$mode"
}

wait_for_tunnel_up() {
    local name="$1" mode="$2" max_wait="${3:-60}"
    local i
    for ((i = 1; i <= max_wait; i++)); do
        if [[ "$mode" == "tun_tcp" || "$mode" == "wireguard" ]]; then
            ip link show "$name" >/dev/null 2>&1 && return 0
        elif [[ "$mode" == "paqet" ]]; then
            pgrep -f "paqet run -c.*/${name}\\.yaml" >/dev/null 2>&1 && return 0
        elif [[ "$mode" == "hysteria2" ]]; then
            if pgrep -f "hysteria.*${name}\\.yaml" >/dev/null 2>&1; then
                return 0
            fi
            if systemctl is-active --quiet "jojonet-hy2@${name}.service" 2>/dev/null; then
                return 0
            fi
        elif ip link show "$name" 2>/dev/null | grep -qE 'state UP|UP,'; then
            return 0
        fi
        sleep 1
    done
    return 1
}

verify_tunnel_ping() {
    local target_ip="$1"
    [[ -n "$target_ip" ]] || return 0
    if ping -c 2 -W 3 "$target_ip" >/dev/null 2>&1; then
        echo -e "${GREEN}[+] Ping OK: $target_ip${NC}"
        return 0
    fi
    echo -e "${YELLOW}[!] Ping to $target_ip failed (check peer server / firewall).${NC}"
    return 1
}

repair_single_config() {
    local conf="$1" loc rem gre mode name changed=0
    [[ -f "$conf" ]] || return 0
    mode=$(conf_get_field "$conf" "TunnelMode")
    name=$(conf_get_field "$conf" "Name")
    [[ -n "$name" ]] || return 0

    if [[ "${mode:-gre}" == "gre" ]]; then
        gre=$(conf_get_field "$conf" "GreKey")
        if [[ -z "$gre" ]]; then
            loc=$(conf_get_field "$conf" "Local_IP")
            rem=$(conf_get_field "$conf" "Remote_IP")
            gre=$(compute_gre_key "$loc" "$rem")
            if grep -q '^GreKey=' "$conf"; then
                sed -i "s/^GreKey=.*/GreKey=\"$gre\"/" "$conf"
            else
                echo "GreKey=\"$gre\"" >> "$conf"
            fi
            changed=1
            echo -e "${YELLOW}[*] Repaired GreKey for [$name] -> $gre${NC}"
        fi
    elif [[ "${mode:-gre}" == "vxlan" ]]; then
        local vni port
        vni=$(conf_get_field "$conf" "VxlanVni")
        if [[ -z "$vni" ]]; then
            loc=$(conf_get_field "$conf" "Local_IP")
            rem=$(conf_get_field "$conf" "Remote_IP")
            vni=$(compute_vxlan_vni "$loc" "$rem")
            if grep -q '^VxlanVni=' "$conf"; then
                sed -i "s/^VxlanVni=.*/VxlanVni=\"$vni\"/" "$conf"
            else
                echo "VxlanVni=\"$vni\"" >> "$conf"
            fi
            changed=1
            echo -e "${YELLOW}[*] Repaired VxlanVni for [$name] -> $vni${NC}"
        fi
        port=$(conf_get_field "$conf" "VxlanPort")
        if [[ -z "$port" ]]; then
            if grep -q '^VxlanPort=' "$conf"; then
                sed -i "s/^VxlanPort=.*/VxlanPort=\"$DEFAULT_VXLAN_PORT\"/" "$conf"
            else
                echo "VxlanPort=\"$DEFAULT_VXLAN_PORT\"" >> "$conf"
            fi
            changed=1
        fi
    elif [[ "${mode:-gre}" == "paqet" ]]; then
        local yaml tcp_port key_dir role rem fwd proto
        yaml=$(conf_get_field "$conf" "PaqetYaml")
        tcp_port=$(conf_get_field "$conf" "TcpPort")
        key_dir=$(conf_get_field "$conf" "KeyDir")
        role=$(conf_get_field "$conf" "Role")
        rem=$(conf_get_field "$conf" "Remote_IP")
        fwd=$(conf_get_field "$conf" "Ports")
        proto=$(conf_get_field "$conf" "ForwardProto")
        proto=${proto:-tcp}
        if [[ -n "$yaml" && ( ! -f "$yaml" || ! -s "$yaml" ) && -n "$key_dir" ]]; then
            build_paqet_runtime_config "$name" "$role" "$rem" "${tcp_port:-$DEFAULT_PAQET_PORT}" \
                "$key_dir" "$fwd" "$proto" && changed=1
            echo -e "${YELLOW}[*] Repaired Paqet YAML for [$name]${NC}"
        fi
    fi

    if (( changed )); then
        systemctl restart "$(tunnel_service_unit "$name")" 2>/dev/null || true
    fi
}

